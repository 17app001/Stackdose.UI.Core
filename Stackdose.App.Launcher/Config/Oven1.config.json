{
  "machine": {
    "id": "OVEN1",
    "name": "Reflow Oven A",
    "enable": true
  },
  "plc": {
    "ip": "192.168.1.100",
    "port": 3000,
    "pollIntervalMs": 200,
    "autoConnect": true,
    "monitorAddresses": [
      "D100,6",
      "M200,4"
    ]
  },
  "commands": {
    "Start":         "M300",
    "Pause":         "M301",
    "Stop":          "M302",
    "EmergencyStop": "M303"
  },
  "processMonitor": {
    "isRunning":   "M200",
    "isCompleted": "M202",
    "isAlarm":     "M201"
  },
  "detailLabels": {
    "Oven Temp":       "D100",
    "Cooling Temp":    "D101",
    "Conveyor Speed":  "D102",
    "Zone 1 Temp":     "D103",
    "Zone 2 Temp":     "D104",
    "Zone 3 Temp":     "D105",
    "Elapsed Time":    "D200",
    "Product Count":   "D201"
  },
  "tags": {
    "status": {
      "isRunning":  { "address": "M200", "type": "bool",  "access": "read" },
      "isAlarm":    { "address": "M201", "type": "bool",  "access": "read" },
      "heartbeat":  { "address": "D300", "type": "int16", "access": "read" }
    },
    "process": {
      "batchNo":    { "address": "D400", "type": "string", "access": "read", "length": 8 },
      "recipeNo":   { "address": "D410", "type": "string", "access": "read", "length": 8 }
    }
  },
  "modules": [
    "processControl"
  ]
}
