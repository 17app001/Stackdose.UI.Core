<Window x:Class="Stackdose.Tools.MachinePageDesigner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Stackdose.Tools.MachinePageDesigner.Views"
        xmlns:vm="clr-namespace:Stackdose.Tools.MachinePageDesigner.ViewModels"
        Title="{Binding WindowTitle}"
        Width="1400" Height="900"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl"       Command="{Binding NewCmd}"/>
        <KeyBinding Key="O" Modifiers="Ctrl"       Command="{Binding OpenCmd}"/>
        <KeyBinding Key="S" Modifiers="Ctrl"       Command="{Binding SaveCmd}"/>
        <KeyBinding Key="S" Modifiers="Ctrl+Shift" Command="{Binding SaveAsCmd}"/>
        <KeyBinding Key="Z" Modifiers="Ctrl"       Command="{Binding UndoCmd}"/>
        <KeyBinding Key="Y" Modifiers="Ctrl"       Command="{Binding RedoCmd}"/>
        <KeyBinding Key="Delete"                    Command="{Binding DeleteSelectedCmd}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,4">
            <WrapPanel>
                <Button Content="&#x2795; New" Command="{Binding NewCmd}" Style="{StaticResource ToolbarButton}" Margin="0,0,4,0"/>
                <Button Content="&#x2197; Open" Command="{Binding OpenCmd}" Style="{StaticResource ToolbarButton}" Margin="0,0,4,0"/>
                <Button Content="&#x25BC; Save" Command="{Binding SaveCmd}" Style="{StaticResource ToolbarButton}" Margin="0,0,4,0"/>
                <Button Content="&#x25BD; Save As" Command="{Binding SaveAsCmd}" Style="{StaticResource ToolbarButton}" Margin="0,0,16,0"/>

                <Separator Style="{x:Null}" Width="1" Background="{StaticResource BorderBrush}" Margin="0,2,16,2"/>

                <Button Content="&#x21B6; Undo" Command="{Binding UndoCmd}" Style="{StaticResource ToolbarButton}" Margin="0,0,4,0"/>
                <Button Content="&#x21B7; Redo" Command="{Binding RedoCmd}" Style="{StaticResource ToolbarButton}" Margin="0,0,16,0"/>

                <Separator Style="{x:Null}" Width="1" Background="{StaticResource BorderBrush}" Margin="0,2,16,2"/>

                <Button Content="&#x2716; Delete" Command="{Binding DeleteSelectedCmd}" Style="{StaticResource ToolbarButton}" Margin="0,0,16,0"/>

                <Separator Style="{x:Null}" Width="1" Background="{StaticResource BorderBrush}" Margin="0,2,16,2"/>

                <TextBlock Text="Layout:" Style="{StaticResource FieldLabel}" Margin="0,0,4,0"/>
                <ComboBox ItemsSource="{Binding LayoutModes}" SelectedItem="{Binding LayoutMode}" Width="120" Margin="0,0,12,0"/>

                <TextBlock Text="Title:" Style="{StaticResource FieldLabel}" Margin="0,0,4,0"/>
                <TextBox Text="{Binding DocTitle, UpdateSourceTrigger=PropertyChanged}" Width="160" Margin="0,0,12,0"/>

                <TextBlock Text="Machine ID:" Style="{StaticResource FieldLabel}" Margin="0,0,4,0"/>
                <TextBox Text="{Binding MachineId, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
            </WrapPanel>
        </Border>

        <!-- Main 3-column layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="150" MaxWidth="300"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="280" MinWidth="200" MaxWidth="400"/>
            </Grid.ColumnDefinitions>

            <local:ToolboxPanel Grid.Column="0" DataContext="{Binding Toolbox}"/>
            <GridSplitter Grid.Column="1" Width="3" Background="{StaticResource BorderBrush}" HorizontalAlignment="Center" VerticalAlignment="Stretch"/>
            <local:DesignCanvas Grid.Column="2" DataContext="{Binding Canvas}"
                                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <GridSplitter Grid.Column="3" Width="3" Background="{StaticResource BorderBrush}" HorizontalAlignment="Center" VerticalAlignment="Stretch"/>
            <local:PropertyPanel Grid.Column="4" DataContext="{Binding Canvas.SelectedItem}"
                                 Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"/>
        </Grid>

        <!-- StatusBar -->
        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="10,4">
            <TextBlock Text="{Binding StatusText}" Style="{StaticResource FieldLabel}" FontSize="11"/>
        </Border>
    </Grid>
</Window>