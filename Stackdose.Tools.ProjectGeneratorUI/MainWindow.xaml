            <!-- ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ Tab 2: й–®еү–? ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ?ВҖ -->
            <TabItem Header="??й–®еү–?">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" MinWidth="180"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
