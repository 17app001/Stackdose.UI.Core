<UserControl x:Class="Stackdose.App.UbiDemo.Controls.PlcBindableField"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="70"
             d:DesignWidth="280">
    <Border Padding="10"
            Margin="4"
            CornerRadius="8"
            Background="{DynamicResource Surface.Bg.Panel}"
            BorderBrush="{DynamicResource Surface.Border.Default}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Foreground="{DynamicResource Text.Secondary}"
                       Margin="0,0,0,6" />
            <TextBox Grid.Row="1"
                     MinWidth="140"
                     Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>
    </Border>
</UserControl>
