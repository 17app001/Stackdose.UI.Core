<UserControl x:Class="ModelB.Demo.Pages.MainPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:core="http://schemas.stackdose.com/wpf"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1400">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Section: PLC Status + Global Status + Machine Info -->
        <Grid Grid.Column="0" Margin="0,0,8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- PLC Connection Status with Time Display -->
            <Border Grid.Row="0"
                    Background="{DynamicResource Sensor.Bg.Main}"
                    BorderBrush="{DynamicResource Sensor.Border}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="20"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Title and Time Row -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="PLC CONNECTION STATUS"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource Sensor.Text.Title}"
                                   FontFamily="Consolas"
                                   VerticalAlignment="Center"/>

                        <!-- Large Time Display -->
                        <Border Grid.Column="1"
                                Background="{DynamicResource Plc.Bg.Main}"
                                BorderBrush="{DynamicResource Cyber.NeonBlue}"
                                BorderThickness="2"
                                CornerRadius="6"
                                Padding="16,8">
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="CURRENT TIME"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource Plc.Text.Label}"
                                           FontFamily="Consolas"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="CurrentTimeText"
                                           Text="2025-01-30 16:05:36"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           FontFamily="Consolas"
                                           Foreground="{DynamicResource Cyber.NeonBlue}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- PLC Status Control -->
                    <core:PlcStatus Grid.Row="1"
                                    x:Name="MainPlcStatus"
                                    IpAddress="192.168.22.39"
                                    Port="3000"
                                    AutoConnect="False"
                                    IsGlobal="True"
                                    ScanInterval="150"/>
                </Grid>
            </Border>

            <!-- Global Status Information -->
            <Border Grid.Row="1"
                    Background="{DynamicResource Sensor.Bg.Main}"
                    BorderBrush="{DynamicResource Sensor.Border}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="20"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="SYSTEM GLOBAL STATUS"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource Sensor.Text.Title}"
                               FontFamily="Consolas"
                               Margin="0,0,0,16"/>

                    <!-- Device Status -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Device Status:"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Plc.Text.Label}"/>
                        <TextBlock Grid.Column="1"
                                   x:Name="DeviceStatusText"
                                   Text="Not Initialized"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="{DynamicResource Status.Warning}"/>
                    </Grid>

                    <!-- Process Batch Number -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Batch Number:"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Plc.Text.Label}"/>
                        <TextBlock Grid.Column="1"
                                   x:Name="BatchNumberText"
                                   Text="-"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="{DynamicResource Plc.Text.Value}"/>
                    </Grid>

                    <!-- Running Time -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Running Time:"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Plc.Text.Label}"/>
                        <TextBlock Grid.Column="1"
                                   x:Name="RunningTimeText"
                                   Text="00:00:00"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="{DynamicResource Status.Success}"/>
                    </Grid>

                    <!-- Completed Count -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Completed Count:"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Plc.Text.Label}"/>
                        <TextBlock Grid.Column="1"
                                   x:Name="CompletedCountText"
                                   Text="0"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="{DynamicResource Status.Success}"/>
                    </Grid>

                    <!-- Defect Count -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Defect Count:"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Plc.Text.Label}"/>
                        <TextBlock Grid.Column="1"
                                   x:Name="DefectCountText"
                                   Text="0"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="{DynamicResource Status.Error}"/>
                    </Grid>

                    <!-- Yield Rate -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Yield Rate:"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Plc.Text.Label}"/>
                        <TextBlock Grid.Column="1"
                                   x:Name="YieldRateText"
                                   Text="100.00 %"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="{DynamicResource Status.Success}"/>
                    </Grid>

                    <!-- Process Status Indicator -->
                    <Border BorderBrush="{DynamicResource Plc.Border}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="12"
                            Margin="0,8,0,0"
                            Background="{DynamicResource Plc.Bg.Main}">
                        <core:ProcessStatusIndicator x:Name="GlobalProcessStatus"
                                                     ProcessState="Idle"
                                                     HorizontalAlignment="Stretch"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Machine Information Card -->
            <Border Grid.Row="2"
                    Background="{DynamicResource Sensor.Bg.Main}"
                    BorderBrush="{DynamicResource Sensor.Border}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="MACHINE INFORMATION"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource Sensor.Text.Title}"
                               FontFamily="Consolas"
                               Margin="0,0,0,16"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Row 1 -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="System Name" FontSize="12" Foreground="{DynamicResource Plc.Text.Label}"/>
                            <TextBlock Text="StackDose 3D Tablet Printer" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Plc.Text.Value}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                            <TextBlock Text="Model" FontSize="12" Foreground="{DynamicResource Plc.Text.Label}"/>
                            <TextBlock Text="MODEL-B" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource Cyber.NeonBlue}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Row 2 -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="Manufacturer" FontSize="12" Foreground="{DynamicResource Plc.Text.Label}"/>
                            <TextBlock Text="Merdury Co." FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Plc.Text.Value}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                            <TextBlock Text="Serial Number" FontSize="12" Foreground="{DynamicResource Plc.Text.Label}"/>
                            <TextBlock Text="MRD-B-2025-001" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Plc.Text.Value}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Row 3 -->
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="Software Version" FontSize="12" Foreground="{DynamicResource Plc.Text.Label}"/>
                            <TextBlock Text="v2.0.1" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Status.Success}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,12">
                            <TextBlock Text="Last Maintenance" FontSize="12" Foreground="{DynamicResource Plc.Text.Label}"/>
                            <TextBlock Text="2025-01-15" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Plc.Text.Value}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Row 4 -->
                        <StackPanel Grid.Row="3" Grid.Column="0">
                            <TextBlock Text="Installation Date" FontSize="12" Foreground="{DynamicResource Plc.Text.Label}"/>
                            <TextBlock Text="2024-06-01" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Plc.Text.Value}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Grid.Column="1">
                            <TextBlock Text="Total Print Cycles" FontSize="12" Foreground="{DynamicResource Plc.Text.Label}"/>
                            <TextBlock Text="125,430" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource Cyber.NeonBlue}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Right Section: Live Log Viewer -->
        <Border Grid.Column="1"
                Background="{DynamicResource Log.Bg.Main}"
                BorderBrush="{DynamicResource Log.Border}"
                BorderThickness="1"
                CornerRadius="6"
                Margin="8,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Log Title -->
                <Border Grid.Row="0"
                        Background="{DynamicResource Plc.Bg.Main}"
                        BorderBrush="{DynamicResource Plc.Border}"
                        BorderThickness="0,0,0,1"
                        Padding="16,12">
                    <TextBlock Text="SYSTEM LIVE LOG"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource Sensor.Text.Title}"
                               FontFamily="Consolas"/>
                </Border>

                <!-- Live Log Viewer -->
                <core:LiveLogViewer Grid.Row="1"
                                    x:Name="MainLogViewer"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
