<UserControl x:Class="Stackdose.UI.Core.Controls.PlcDeviceEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="root"
             MinHeight="160"
             d:DesignHeight="166" d:DesignWidth="340">

    <UserControl.Resources>
        <Style x:Key="EditorInputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Plc.Bg.Main}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Plc.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource Cyber.Text.Bright}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="InputBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="{DynamicResource Cyber.NeonBlue}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="InputBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Opacity="0.96">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Plc.Border}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Plc.Text.Gray}"/>
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Margin="2,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="{Binding Label, ElementName=root}"
                       Foreground="{DynamicResource Plc.Text.Label}"
                       FontSize="12"
                       FontFamily="Microsoft JhengHei"
                       VerticalAlignment="Center"/>

            <Border Grid.Column="1"
                    Background="{DynamicResource Overlay.Bg.Panel}"
                    CornerRadius="4"
                    Padding="6,2"
                    Margin="8,0,0,0">
                <TextBlock Text="LOCKED"
                           Foreground="{DynamicResource Status.Warning}"
                           FontSize="9"
                           FontFamily="Consolas"
                           FontWeight="Bold"
                           ToolTip="Requires Supervisor or Higher">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAuthorized, ElementName=root}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </Grid>

        <Border Grid.Row="1"
                BorderBrush="{DynamicResource Plc.Border}"
                BorderThickness="1"
                Background="{DynamicResource Plc.Bg.Dark}"
                CornerRadius="6"
                Padding="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TxtAddress"
                         Grid.Column="0"
                         Style="{StaticResource EditorInputStyle}"
                         Text="{Binding Address, ElementName=root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, FallbackValue=D10}"
                         IsEnabled="{Binding IsAuthorized, ElementName=root}"
                         ToolTip="PLC Address (Ex: M0, D100, R2002)"/>

                <TextBlock Grid.Column="0"
                           Text="Device"
                           Foreground="{DynamicResource Plc.Text.Default}"
                           FontSize="10"
                           IsHitTestVisible="False"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,10,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=TxtAddress}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBox x:Name="TxtValue"
                         Grid.Column="2"
                         Style="{StaticResource EditorInputStyle}"
                         Text="{Binding Value, ElementName=root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, FallbackValue=0}"
                         Foreground="{DynamicResource Plc.Text.Value}"
                         FontWeight="Bold"
                         IsEnabled="{Binding IsAuthorized, ElementName=root}"
                         ToolTip="Value (Word: 0-65535, DWord: 0-4294967295)"/>

                <TextBlock Grid.Column="2"
                           Text="Value"
                           Foreground="{DynamicResource Plc.Text.Default}"
                           FontSize="10"
                           IsHitTestVisible="False"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,10,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=TxtValue}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Button x:Name="BtnRead"
                        Grid.Column="4"
                        Style="{StaticResource ActionButtonStyle}"
                        Click="BtnRead_Click"
                        Background="{DynamicResource Button.Bg.Success}"
                        IsEnabled="{Binding IsAuthorized, ElementName=root}"
                        ToolTip="Read from PLC">
                    <TextBlock Text="R" FontSize="12"/>
                </Button>

                <Button x:Name="BtnWrite"
                        Grid.Column="6"
                        Style="{StaticResource ActionButtonStyle}"
                        Click="BtnWrite_Click"
                        Background="{DynamicResource Button.Bg.Primary}"
                        IsEnabled="{Binding IsAuthorized, ElementName=root}"
                        ToolTip="Write to PLC">
                    <TextBlock Text="W" FontSize="12"/>
                </Button>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="4,6,0,0"
                    HorizontalAlignment="Left">
            <CheckBox x:Name="ChkDWord"
                      Content="DWord (32-bit)"
                      IsChecked="False"
                      Checked="ChkDWord_Checked"
                      Unchecked="ChkDWord_Unchecked"
                      Foreground="{DynamicResource Cyber.NeonBlue}"
                      FontSize="11"
                      VerticalAlignment="Center"
                      ToolTip="Read/Write DWord (32-bit) instead of Word (16-bit)"/>

            <TextBlock Text="(Word: 0-65535, DWord: 0-4294967295)"
                       Foreground="{DynamicResource Plc.Text.Gray}"
                       FontSize="10"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"
                       Opacity="0.75"/>
        </StackPanel>

        <TextBox x:Name="TxtReason"
                 Grid.Row="3"
                 Text="{Binding Reason, ElementName=root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Background="{DynamicResource Plc.Bg}"
                 Foreground="{DynamicResource Plc.Text.Gray}"
                 BorderBrush="{DynamicResource Plc.Border}"
                 BorderThickness="1"
                 Padding="6,3"
                 FontSize="11"
                 Height="24"
                 Margin="0,6,0,0"
                 IsEnabled="{Binding IsAuthorized, ElementName=root}"
                 ToolTip="Reason for change (for Audit Trail)"/>
    </Grid>
</UserControl>
