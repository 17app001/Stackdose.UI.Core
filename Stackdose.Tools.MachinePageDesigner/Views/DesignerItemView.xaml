<UserControl x:Class="Stackdose.Tools.MachinePageDesigner.Views.DesignerItemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Stackdose.Tools.MachinePageDesigner.Views"
             xmlns:vm="clr-namespace:Stackdose.Tools.MachinePageDesigner.ViewModels">

    <Border x:Name="CardBorder" Style="{StaticResource DesignerItemCard}"
            MouseLeftButtonDown="OnCardClicked">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>    <!-- 控制項預覽 -->
                <RowDefinition Height="Auto"/> <!-- 操作列 -->
            </Grid.RowDefinitions>

            <!-- ── 控制項預覽區 ── -->
            <ContentPresenter Grid.Row="0" Content="{Binding Preview}" Margin="4"/>

            <!-- ── 操作列（拖拉把手 + 名稱 + 刪除） ── -->
            <Border Grid.Row="1"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="0,0,4,4"
                    Padding="6,3">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/> <!-- 拖拉把手 -->
                        <ColumnDefinition Width="Auto"/> <!-- 類型圖示 -->
                        <ColumnDefinition Width="*"/>    <!-- 顯示名稱 -->
                        <ColumnDefinition Width="Auto"/> <!-- 刪除鈕 -->
                    </Grid.ColumnDefinitions>

                    <!-- 拖拉把手 ☰ -->
                    <TextBlock Grid.Column="0" Text="&#x2630;" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center" Margin="0,0,4,0"
                               Cursor="SizeAll" ToolTip="拖拉排序"
                               MouseLeftButtonDown="OnDragHandleMouseDown"
                               MouseMove="OnDragHandleMouseMove"/>

                    <!-- 類型圖示 -->
                    <TextBlock Grid.Column="1" FontSize="10"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center" Margin="0,0,4,0">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0}">
                                <Binding Path="ItemType"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>

                    <!-- 顯示名稱 -->
                    <TextBlock Grid.Column="2"
                               Text="{Binding DisplayName}"
                               FontSize="10"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>

                    <!-- 刪除按鈕 -->
                    <Button Grid.Column="3" Content="&#x2715;"
                            FontSize="10" Width="20" Height="20"
                            Padding="0" Margin="4,0,0,0"
                            ToolTip="移除此項目"
                            Click="OnRemoveClicked"
                            Style="{StaticResource BaseButton}"
                            Foreground="{StaticResource DangerBrush}"
                            Background="Transparent"
                            BorderThickness="0"/>
                </Grid>
            </Border>
        </Grid>
    </Border>

    <!-- 選取狀態外框 -->
    <UserControl.Style>
        <Style TargetType="UserControl">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#6C8EEF" ShadowDepth="0" BlurRadius="8" Opacity="0.6"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>
</UserControl>