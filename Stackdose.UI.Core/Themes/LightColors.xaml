<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light Theme Colors -->
    
    <!-- ========== CyberFrame Colors ========== -->
    <SolidColorBrush x:Key="Cyber.Bg.Dark" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="Cyber.Bg.Panel" Color="#E8E8E8" Opacity="1.0"/>
    <SolidColorBrush x:Key="Cyber.Border" Color="#BDBDBD"/>
    <SolidColorBrush x:Key="Cyber.Border.Strong" Color="#757575"/>
    <SolidColorBrush x:Key="Cyber.NeonBlue" Color="#0091EA"/>
    <SolidColorBrush x:Key="Cyber.Text.Main" Color="#212121"/>
    <SolidColorBrush x:Key="Cyber.Text.Muted" Color="#616161"/>
    <SolidColorBrush x:Key="Cyber.Text.Bright" Color="#000000"/>
    <SolidColorBrush x:Key="Cyber.Bg.Card" Color="#FAFAFA"/>

    <!-- ========== PlcLabel / PlcStatus Colors ========== -->
    <SolidColorBrush x:Key="Plc.Bg.Main" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Plc.Bg.Dark" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="Plc.Bg" Color="#FAFAFA"/>
    <SolidColorBrush x:Key="Plc.Border" Color="#BDBDBD"/>
    <SolidColorBrush x:Key="Plc.Text.Label" Color="#616161"/>
    <SolidColorBrush x:Key="Plc.Text.Value" Color="#0091EA"/>
    <SolidColorBrush x:Key="Plc.Text.Default" Color="#9E9E9E"/>
    <SolidColorBrush x:Key="Plc.Text.Gray" Color="#757575"/>

    <!-- ========== SensorViewer Colors ========== -->
    <SolidColorBrush x:Key="Sensor.Bg.Main" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Sensor.Bg.Header" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="Sensor.Border" Color="#BDBDBD"/>
    <SolidColorBrush x:Key="Sensor.Text.Title" Color="#212121"/>
    <SolidColorBrush x:Key="Sensor.Text.Group" Color="#0091EA"/>
    <SolidColorBrush x:Key="Sensor.Text.Label" Color="#424242"/>
    <SolidColorBrush x:Key="Sensor.Text.Value" Color="#1976D2"/>

    <!-- ========== LiveLogViewer Colors ========== -->
    <SolidColorBrush x:Key="Log.Bg.Main" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="Log.Bg.Header" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="Log.Border" Color="#BDBDBD"/>
    <SolidColorBrush x:Key="Log.Text.Normal" Color="#212121"/>
    <SolidColorBrush x:Key="Log.Text.Time" Color="#616161"/>

    <!-- ========== Overlay / Surface Alpha Colors ========== -->
    <SolidColorBrush x:Key="Overlay.Bg.Scrim" Color="#80000000"/>
    <SolidColorBrush x:Key="Overlay.Bg.Panel" Color="#14000000"/>
    <SolidColorBrush x:Key="Overlay.Bg.Medium" Color="#12000000"/>
    <SolidColorBrush x:Key="Overlay.Bg.Light" Color="#0A000000"/>
    <SolidColorBrush x:Key="Overlay.Highlight.Info" Color="#140091EA"/>

    <!-- ========== SecuredButton Colors ========== -->
    <SolidColorBrush x:Key="Button.Bg.Primary" Color="#2196F3"/>
    <SolidColorBrush x:Key="Button.Bg.Success" Color="#4CAF50"/>
    <SolidColorBrush x:Key="Button.Bg.Warning" Color="#FF9800"/>
    <SolidColorBrush x:Key="Button.Bg.Error" Color="#F44336"/>
    <SolidColorBrush x:Key="Button.Bg.Info" Color="#00BCD4"/>
    <SolidColorBrush x:Key="Button.Text" Color="#FFFFFF"/>

    <!-- ========== Status Colors (Universal) ========== -->
    <SolidColorBrush x:Key="Status.Success" Color="#4CAF50"/>
    <SolidColorBrush x:Key="Status.Warning" Color="#FF9800"/>
    <SolidColorBrush x:Key="Status.Error" Color="#F44336"/>
    <SolidColorBrush x:Key="Status.Info" Color="#2196F3"/>
    <SolidColorBrush x:Key="Status.Offline" Color="#9E9E9E"/>

    <!-- ========== PrintHead Accent Colors ========== -->
    <SolidColorBrush x:Key="PrintHead.Accent.Voltage" Color="#C49000"/>
    <SolidColorBrush x:Key="PrintHead.Accent.Encoder" Color="#2E7D32"/>
    <SolidColorBrush x:Key="PrintHead.Accent.PrintIndex" Color="#AD1457"/>

    <!-- ========== Semantic Alias Tokens (v1) ========== -->
    <!-- Surface -->
    <SolidColorBrush x:Key="Surface.Bg.Page" Color="{Binding Source={StaticResource Cyber.Bg.Dark}, Path=Color}"/>
    <SolidColorBrush x:Key="Surface.Bg.Panel" Color="{Binding Source={StaticResource Cyber.Bg.Panel}, Path=Color}"/>
    <SolidColorBrush x:Key="Surface.Bg.Card" Color="{Binding Source={StaticResource Cyber.Bg.Card}, Path=Color}"/>
    <SolidColorBrush x:Key="Surface.Bg.Control" Color="{Binding Source={StaticResource Plc.Bg.Main}, Path=Color}"/>

    <!-- Border -->
    <SolidColorBrush x:Key="Surface.Border.Default" Color="{Binding Source={StaticResource Cyber.Border}, Path=Color}"/>
    <SolidColorBrush x:Key="Surface.Border.Strong" Color="{Binding Source={StaticResource Cyber.Border.Strong}, Path=Color}"/>

    <!-- Text -->
    <SolidColorBrush x:Key="Text.Primary" Color="{Binding Source={StaticResource Cyber.Text.Main}, Path=Color}"/>
    <SolidColorBrush x:Key="Text.Secondary" Color="{Binding Source={StaticResource Cyber.Text.Muted}, Path=Color}"/>
    <SolidColorBrush x:Key="Text.Tertiary" Color="{Binding Source={StaticResource Plc.Text.Default}, Path=Color}"/>

    <!-- Accent / Action -->
    <SolidColorBrush x:Key="Accent.Primary" Color="{Binding Source={StaticResource Cyber.NeonBlue}, Path=Color}"/>
    <SolidColorBrush x:Key="Action.Primary" Color="{Binding Source={StaticResource Button.Bg.Primary}, Path=Color}"/>
    <SolidColorBrush x:Key="Action.Success" Color="{Binding Source={StaticResource Button.Bg.Success}, Path=Color}"/>
    <SolidColorBrush x:Key="Action.Warning" Color="{Binding Source={StaticResource Button.Bg.Warning}, Path=Color}"/>
    <SolidColorBrush x:Key="Action.Error" Color="{Binding Source={StaticResource Button.Bg.Error}, Path=Color}"/>
    <SolidColorBrush x:Key="Action.Info" Color="{Binding Source={StaticResource Button.Bg.Info}, Path=Color}"/>

    <!-- ================================================================ -->
    <!-- BACKWARD COMPATIBILITY ALIASES (v2 - Complete Mapping)          -->
    <!-- ================================================================ -->
    <!-- 
        Ensure existing controls continue to work
        New controls should use Semantic Tokens (Surface.*, Text.*, Action.*)
    -->

    <!-- Legacy Cyber.* mapped to new Surface.*/Text.*/Accent.* -->
    <StaticResource x:Key="Cyber.Bg.Dark.Legacy" ResourceKey="Surface.Bg.Page" />
    <StaticResource x:Key="Cyber.Bg.Panel.Legacy" ResourceKey="Surface.Bg.Panel" />
    <StaticResource x:Key="Cyber.Bg.Card.Legacy" ResourceKey="Surface.Bg.Card" />
    <StaticResource x:Key="Cyber.Border.Legacy" ResourceKey="Surface.Border.Default" />
    <StaticResource x:Key="Cyber.Border.Strong.Legacy" ResourceKey="Surface.Border.Strong" />
    <StaticResource x:Key="Cyber.NeonBlue.Legacy" ResourceKey="Accent.Primary" />
    <StaticResource x:Key="Cyber.Text.Main.Legacy" ResourceKey="Text.Primary" />
    <StaticResource x:Key="Cyber.Text.Muted.Legacy" ResourceKey="Text.Secondary" />

    <!-- Legacy Plc.* mapped to new Surface.*/Text.* -->
    <StaticResource x:Key="Plc.Bg.Main.Legacy" ResourceKey="Surface.Bg.Control" />
    <StaticResource x:Key="Plc.Border.Legacy" ResourceKey="Surface.Border.Weak" />
    <StaticResource x:Key="Plc.Text.Label.Legacy" ResourceKey="Text.Tertiary" />
    <StaticResource x:Key="Plc.Text.Value.Legacy" ResourceKey="Accent.Primary" />

    <!-- Legacy Button.* mapped to new Action.* -->
    <StaticResource x:Key="Button.Bg.Primary.Legacy" ResourceKey="Action.Primary.Bg" />
    <StaticResource x:Key="Button.Bg.Success.Legacy" ResourceKey="Action.Success.Bg" />
    <StaticResource x:Key="Button.Bg.Warning.Legacy" ResourceKey="Action.Warning.Bg" />
    <StaticResource x:Key="Button.Bg.Error.Legacy" ResourceKey="Action.Error.Bg" />
    <StaticResource x:Key="Button.Bg.Info.Legacy" ResourceKey="Action.Info.Bg" />
    <StaticResource x:Key="Button.Text.Legacy" ResourceKey="Action.Primary.Fg" />

</ResourceDictionary>
