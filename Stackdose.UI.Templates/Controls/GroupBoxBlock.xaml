<UserControl x:Class="Stackdose.UI.Templates.Controls.GroupBoxBlock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Name="Root"
              mc:Ignorable="d"
              d:DesignWidth="360"
              d:DesignHeight="240">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Stackdose.UI.Templates;component/Resources/CommonColors.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Style="{StaticResource Template.PanelCard}"
            Padding="{Binding GroupPadding, ElementName=Root}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,10">
                <TextBlock Text="{Binding Header, ElementName=Root}"
                           Style="{StaticResource Template.SectionTitleText}"
                           VerticalAlignment="Center"/>

                <Border DockPanel.Dock="Right"
                        Background="{DynamicResource Overlay.Bg.Panel}"
                        CornerRadius="5"
                        Padding="8,2"
                        Margin="10,0,0,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding BadgeText, ElementName=Root}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <TextBlock Text="{Binding BadgeText, ElementName=Root}"
                               Style="{StaticResource Template.CaptionText}"
                               FontWeight="SemiBold"/>
                </Border>
            </DockPanel>

            <ContentPresenter Grid.Row="1"
                              Content="{Binding GroupContent, ElementName=Root}"/>
        </Grid>
    </Border>
</UserControl>
