<UserControl x:Class="Stackdose.App.ModelB.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:Custom="http://schemas.stackdose.com/wpf"
             xmlns:Templates="http://schemas.stackdose.com/templates"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1600">
    
    <Grid Background="{DynamicResource Surface.Bg.Page}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="300"/>
        </Grid.RowDefinitions>

        <!-- Title Area -->
        <Border Grid.Row="0" 
                Background="{DynamicResource Surface.Bg.Panel}"
                BorderBrush="{DynamicResource Surface.Border.Default}"
                BorderThickness="0,0,0,1"
                Padding="30,20">
            <StackPanel>
                <TextBlock Text="Model-B 3D Printing Tablet Device"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{DynamicResource Text.Primary}"/>
                <TextBlock Text="Dual Machine Monitoring Overview"
                           FontSize="14"
                           Foreground="{DynamicResource Text.Secondary}"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Machine Cards Area -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto"
                      Padding="20">
            <UniformGrid Columns="2" 
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top">
                
                <!-- Machine 1 Card -->
                <Templates:MachineCard 
                    x:Name="Machine1Card"
                    Margin="10"
                    MachineId="Model-B-01"
                    Title="Model-B-01"
                    BatchLabel="Batch No."
                    BatchValue="--"
                    RecipeText="--"
                    StatusText="Idle"
                    LeftTopLabel="PrintHead 1"
                    LeftTopValue="Ready"
                    LeftBottomLabel="PrintHead 2"
                    LeftBottomValue="Ready"
                    RightTopLabel="Progress"
                    RightTopValue="0%"
                    RightBottomLabel="PLC Status"
                    RightBottomValue="Disconnected"
                    MachineSelected="OnMachineSelected"/>

                <!-- Machine 2 Card -->
                <Templates:MachineCard 
                    x:Name="Machine2Card"
                    Margin="10"
                    MachineId="Model-B-02"
                    Title="Model-B-02"
                    BatchLabel="Batch No."
                    BatchValue="--"
                    RecipeText="--"
                    StatusText="Idle"
                    LeftTopLabel="PrintHead 1"
                    LeftTopValue="Ready"
                    LeftBottomLabel="PrintHead 2"
                    LeftBottomValue="Ready"
                    RightTopLabel="Progress"
                    RightTopValue="0%"
                    RightBottomLabel="PLC Status"
                    RightBottomValue="Disconnected"
                    MachineSelected="OnMachineSelected"/>
                
            </UniformGrid>
        </ScrollViewer>

        <!-- Log Area -->
        <Border Grid.Row="2"
                Background="{DynamicResource Surface.Bg.Panel}"
                BorderBrush="{DynamicResource Surface.Border.Default}"
                BorderThickness="0,1,0,0"
                Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Log Title -->
                <TextBlock Grid.Row="0"
                           Text="Live Log"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Text.Primary}"
                           Margin="0,0,0,10"/>
                
                <!-- LiveLogViewer -->
                <Custom:LiveLogViewer 
                    Grid.Row="1"
                    x:Name="LogViewer"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
