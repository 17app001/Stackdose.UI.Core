                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="ж’ пҺҮ?" Style="{StaticResource SectionHeader}"/>
                                    <TextBlock Text="{Binding ProjectName}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding PageMode}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="й–®еү–?" Style="{StaticResource SectionHeader}"/>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding Machines.Count, StringFormat='{}{0} ?е•—иә«??}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Panels" Style="{StaticResource SectionHeader}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontWeight="SemiBold"
                                                   Visibility="{Binding HasMaintenanceMode, Converter={StaticResource BoolToVis}}"
                                                   Text="Maintenance " Foreground="{StaticResource AccentBrush}"/>
                                        <TextBlock FontWeight="SemiBold"
                                                   Visibility="{Binding HasSettings, Converter={StaticResource BoolToVis}}"
                                                   Text="Settings " Foreground="{StaticResource AccentBrush}"/>
                                        <TextBlock FontWeight="SemiBold"
                                                   Visibility="{Binding HasPlcDeviceEditor, Converter={StaticResource BoolToVis}}"
                                                   Text="PlcEditor" Foreground="{StaticResource AccentBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Generate button -->
                    <Button Grid.Row="4"
                            Content="?? ?пј№?ж’ пҺҮ?"
                            Style="{StaticResource SuccessButton}"
                            Command="{Binding GenerateCmd}"
                            Width="200" HorizontalAlignment="Left"
                            IsEnabled="{Binding IsGenerating, Converter={StaticResource InvertBool}}"/>

                    <!-- Log output -->
                    <TextBox Grid.Row="6"
                             Text="{Binding GenerationLog, Mode=OneWay}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="12"
                             Background="{StaticResource SurfaceBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             Padding="12"/>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Status bar -->
        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Height="26" Padding="16,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                           Text="{Binding Machines.Count, StringFormat='{}{0} ?е•—иә«??}"/>
                <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}" Text="  |  ж’ пҺҮ?еҡ—?/>
                <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}" Text="{Binding ProjectName}"/>
                <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}" Text="  |  з’…вҲӘ?еҡ—?/>
                <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}" Text="{Binding PageMode}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
