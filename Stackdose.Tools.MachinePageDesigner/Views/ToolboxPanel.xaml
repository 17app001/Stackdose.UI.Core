<UserControl x:Class="Stackdose.Tools.MachinePageDesigner.Views.ToolboxPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:Stackdose.Tools.MachinePageDesigner.Models"
             Background="{StaticResource SurfaceBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="&#x25A0; Toolbox" Style="{StaticResource SectionHeader}"
                   Margin="10,10,10,6" FontSize="13"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8,0">
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:ToolboxItemDescriptor}">
                        <Border Style="{StaticResource ToolboxItem}"
                                MouseMove="ToolboxItem_MouseMove"
                                Tag="{Binding}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,8,0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentBrush}"/>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Category}" FontSize="10"
                                               Foreground="{StaticResource TextMutedBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>