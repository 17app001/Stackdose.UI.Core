<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:core="http://schemas.stackdose.com/wpf">
    <DataTemplate x:Key="DeviceHeaderTemplate">
        <Border Padding="8"
                Margin="0,0,0,8"
                CornerRadius="6"
                Background="{DynamicResource Surface.Bg.Panel}"
                BorderBrush="{DynamicResource Surface.Border.Default}"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Machine"
                           Foreground="{DynamicResource Text.Secondary}" />
                <TextBlock Text="{Binding MachineName}"
                           FontWeight="SemiBold"
                           Margin="0,2,0,6" />
                <TextBlock Text="Machine ID"
                           Foreground="{DynamicResource Text.Secondary}" />
                <TextBlock Text="{Binding MachineId}"
                           Margin="0,2,0,0" />
            </StackPanel>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="DeviceCommandTemplate">
        <StackPanel>
            <Border Padding="10"
                    Margin="0,0,0,10"
                    CornerRadius="8"
                    Background="{DynamicResource Surface.Bg.Panel}"
                    BorderBrush="#FF4FD8FF"
                    BorderThickness="1.5">
                <StackPanel>
                    <TextBlock Text="Process State"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4" />
                    <Border Padding="10,8"
                            Margin="0,0,0,10"
                            CornerRadius="6"
                            Background="#2217C964"
                            BorderBrush="#6617C964"
                            BorderThickness="1">
                        <TextBlock Text="{Binding CurrentProcessStateText}"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#FFFFFFFF" />
                    </Border>
                </StackPanel>
            </Border>

            <UniformGrid Columns="2" Margin="0,0,0,8">
                <core:SecuredButton Content="Start"
                                    Theme="Success"
                                    RequiredLevel="Operator"
                                    OperationName="Start Process"
                                    Command="{Binding StartProcessCommand}"
                                    Margin="0,0,6,6" />
                <core:SecuredButton Content="Pause/Resume"
                                    Theme="Warning"
                                    RequiredLevel="Operator"
                                    OperationName="Pause Resume"
                                    Margin="6,0,0,6" />
                <core:SecuredButton Content="Stop"
                                    Theme="Error"
                                    RequiredLevel="Operator"
                                    OperationName="Stop Process"
                                    Margin="0,6,6,0" />
                <core:SecuredButton Content="Spit Execute"
                                    Theme="Warning"
                                    RequiredLevel="Operator"
                                    OperationName="Spit"
                                    Margin="6,6,0,0" />
            </UniformGrid>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="DeviceProcessTriggerTemplate">
        <Grid>
            <core:PlcEventTrigger Address="{Binding RunningAddress}"
                                  EventName="ProcessRunning"
                                  AutoClear="False" />
            <core:PlcEventTrigger Address="{Binding CompletedAddress}"
                                  EventName="ProcessCompleted"
                                  AutoClear="False" />
            <core:PlcEventTrigger Address="{Binding AlarmAddress}"
                                  EventName="ProcessAlarm"
                                  AutoClear="False" />
        </Grid>
    </DataTemplate>
</ResourceDictionary>
