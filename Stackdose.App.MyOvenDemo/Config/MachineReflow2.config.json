{
  "machine": {
    "id": "OVEN2",
    "name": "Reflow Oven B",
    "enable": true
  },
  "plc": {
    "ip": "192.168.1.101",
    "port": 3000,
    "pollIntervalMs": 200,
    "autoConnect": false,
    "monitorAddresses": [
      "D200,4",
      "M300,204"
    ]
  },
  "commands": {
    "Start": "M500",
    "Stop": "M501",
    "EmergencyStop": "M502",
    "Reset": "M503"
  },
  "processMonitor": {
    "isRunning": "M300",
    "isCompleted": "M302",
    "isAlarm": "M301"
  },
  "detailLabels": {
    "Oven Temp": "D200",
    "Cooling Temp": "D201",
    "Conveyor Speed": "D202",
    "Product Count": "D203"
  },
  "tags": {
    "status": {
      "isRunning": {
        "address": "M300",
        "type": "bool",
        "access": "read"
      },
      "isAlarm": {
        "address": "M301",
        "type": "bool",
        "access": "read"
      },
      "heartbeat": {
        "address": "D350",
        "type": "int16",
        "access": "read",
        "length": 1
      }
    },
    "process": {
      "batchNo": {
        "address": "D450",
        "type": "string",
        "access": "read",
        "length": 8
      },
      "recipeNo": {
        "address": "D460",
        "type": "string",
        "access": "read",
        "length": 8
      }
    }
  },
  "modules": [
    "processControl"
  ],
  "showPlcEditor": true
}