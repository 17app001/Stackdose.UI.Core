{
  "machine": {
    "id": "CVR1",
    "name": "Conveyor Line A",
    "enable": true
  },
  "plc": {
    "ip": "192.168.22.39",
    "port": 3000,
    "pollIntervalMs": 200,
    "autoConnect": false,
    "monitorAddresses": [
      "D100,4",
      "M200,4"
    ]
  },
  "commands": {
    "Start": "M300",
    "Stop": "M301",
    "EmergencyStop": "M302",
    "Reset": "M303"
  },
  "processMonitor": {
    "isRunning": "M200",
    "isCompleted": "M202",
    "isAlarm": "M201"
  },
  "detailLabels": {
    "Belt Speed": "D100",
    "Motor Current": "D101",
    "Temperature": "D102",
    "Product Count": "D103",
    "Elapsed Time": "D200"
  },
  "tags": {
    "status": {
      "isRunning": { "address": "M200", "type": "bool", "access": "read" },
      "isAlarm": { "address": "M201", "type": "bool", "access": "read" },
      "heartbeat": { "address": "D300", "type": "int16", "access": "read" }
    },
    "process": {
      "batchNo": { "address": "D400", "type": "string", "access": "read", "length": 8 },
      "recipeNo": { "address": "D410", "type": "string", "access": "read", "length": 8 }
    }
  },
  "modules": [
    "processControl"
  ]
}
