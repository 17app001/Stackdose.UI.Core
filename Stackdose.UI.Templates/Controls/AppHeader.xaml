<UserControl x:Class="Stackdose.UI.Templates.Controls.AppHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:Stackdose.UI.Templates.Converters"
             mc:Ignorable="d"
             d:DesignHeight="60" d:DesignWidth="1600">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Stackdose.UI.Templates;component/Resources/CommonColors.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:FirstCharConverter x:Key="FirstCharConverter"/>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

            <Style x:Key="HeaderMachineComboStyle" TargetType="ComboBox">
                <Setter Property="Foreground" Value="#162033"/>
                <Setter Property="Background" Value="#F5F7FA"/>
                <Setter Property="BorderBrush" Value="{StaticResource WarningBrush}"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="Padding" Value="8,2"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="IsEditable" Value="False"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="TextElement.Foreground" Value="#162033"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Setter Property="BorderBrush" Value="#FFD166"/>
                    </Trigger>
                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Setter Property="BorderBrush" Value="#FFD166"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="HeaderMachineComboItemStyle" TargetType="ComboBoxItem">
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" CornerRadius="3">
                                <ContentPresenter Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource HoverBackgroundBrush}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="#FFD166"/>
                                    <Setter Property="Foreground" Value="#1A2030"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{StaticResource CardBackgroundBrush}" 
            BorderBrush="{StaticResource BorderBrush}" 
            BorderThickness="0,0,0,2"
            Height="60">
        <Grid Margin="15,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Logo and System Title -->
            <StackPanel Grid.Column="0" 
                        Orientation="Horizontal" 
                        VerticalAlignment="Center">
                <Border Width="38" Height="38" 
                        Background="{StaticResource PrimaryBrush}" 
                        CornerRadius="19"
                        Margin="0,0,12,0">
                    <TextBlock Text="S" 
                               FontSize="22" 
                               FontWeight="Bold"
                               Foreground="{StaticResource CardBackgroundBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="STACKDOSE 3D TABLET PRINTER" 
                                   FontSize="15" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="  |  " 
                                   FontSize="15" 
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding DeviceName, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                   FontSize="18" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource WarningBrush}"/>
                    </StackPanel>
                    <TextBlock Text="Mercury Co. - Pharmaceutical 3D Printing System" 
                               FontSize="10" 
                               Foreground="{StaticResource TextTertiaryBrush}"
                               Margin="0,1,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Page Title (without MODEL-B) -->
            <StackPanel Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding PageTitle, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                           FontSize="22" 
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>

                <Border Margin="0,4,0,0"
                        Padding="8,2"
                        CornerRadius="10"
                        Background="#1D2232"
                        BorderBrush="#4F627A"
                        BorderThickness="1"
                        Visibility="{Binding ShowMachineBadge, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ComboBox x:Name="MachineSelector"
                              Width="220"
                              Height="24"
                              ItemsSource="{Binding MachineOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              SelectedValuePath="Key"
                              SelectedValue="{Binding SelectedMachineId, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                              SelectionChanged="MachineSelector_SelectionChanged"
                              Style="{StaticResource HeaderMachineComboStyle}"
                              ItemContainerStyle="{StaticResource HeaderMachineComboItemStyle}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Value}" Foreground="#162033"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Border>
            </StackPanel>

            <!-- User Info -->
            <StackPanel Grid.Column="2" 
                        Orientation="Horizontal" 
                        VerticalAlignment="Center">
                <Border Width="36" Height="36" 
                        Background="{StaticResource TextMutedBrush}" 
                        CornerRadius="18"
                        Margin="0,0,8,0">
                    <TextBlock Text="{Binding UserName, Converter={StaticResource FirstCharConverter}}" 
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                    <!-- DisplayName -->
                    <TextBlock Text="{Binding UserName}" 
                               FontSize="13" 
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <!-- UID and Role -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="UserIdText"
                                   Text="{Binding UserId}" 
                                   FontSize="10" 
                                   Foreground="{StaticResource InfoBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,6,0"/>
                        <TextBlock Text="|" 
                                   FontSize="10" 
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding UserRole}" 
                                   FontSize="10" 
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Logout Button -->
                    <Button x:Name="LogoutButton"
                            Content="Logout" 
                            Width="70" 
                            Style="{StaticResource Template.HeaderActionButton}"
                            Background="{StaticResource ErrorBrush}"
                            Margin="0,0,4,0"
                            Click="LogoutButton_Click"/>

                    <!-- Switch User Button -->
                    <Button x:Name="SwitchUserButton"
                            Width="70" 
                            Style="{StaticResource Template.HeaderActionButton}"
                            Background="{StaticResource InfoBrush}"
                            Margin="0,0,8,0"
                            Click="SwitchUserButton_Click">
                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="&#x21BB;" 
                                       FontSize="13"
                                       Margin="0,0,3,0"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe UI Symbol"/>
                            <TextBlock Text="Switch" 
                                       FontSize="11"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Minimize Button -->
                    <Button x:Name="MinimizeButton"
                            Content="-" 
                            Width="30" 
                            Style="{StaticResource Template.HeaderWindowButton}"
                            Background="{StaticResource WarningBrush}"
                            Margin="0,0,2,0"
                            Click="MinimizeButton_Click"/>

                    <!-- Fullscreen Button -->
                    <Button x:Name="FullscreenButton"
                            Width="30" 
                            Style="{StaticResource Template.HeaderWindowButton}"
                            Background="{StaticResource SuccessBrush}"
                            Margin="0,0,2,0"
                            Click="FullscreenButton_Click"
                            ToolTip="Exit Fullscreen">
                        <!-- Default: currently fullscreen, show "exit fullscreen" icon -->
                        <Path Data="F0 M2,5 H11 V14 H2 Z M4,7 V12 H9 V7 Z M7,2 H16 V11 H7 Z M9,4 V9 H14 V4 Z"
                              Fill="{StaticResource TextPrimaryBrush}"
                              Stretch="Uniform"
                              Width="16"
                              Height="16"/>
                    </Button>

                    <!-- Close Button -->
                    <Button x:Name="CloseButton"
                            Content="X" 
                            Width="30" 
                            Style="{StaticResource Template.HeaderWindowButton}"
                            Background="{StaticResource ErrorBrush}"
                            Click="CloseButton_Click"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
