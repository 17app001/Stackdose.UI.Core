<UserControl x:Class="Stackdose.App.SingleDetailLab.Pages.SingleDetailWorkspacePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:core="http://schemas.stackdose.com/wpf"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1400">

    <Grid Background="{DynamicResource Surface.Bg.Page}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource Surface.Bg.Panel}"
                BorderBrush="{DynamicResource Surface.Border.Default}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Detail + PLC Lab"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock x:Name="MachineSummaryText"
                           Margin="0,4,0,8"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <core:PlcStatus x:Name="TopPlcStatus"
                                Height="58"
                                IsGlobal="True"
                                ShowBorder="True"
                                AutoConnect="True"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource Surface.Bg.Panel}"
                    BorderBrush="{DynamicResource Surface.Border.Default}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10"
                    Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Widget Toolbox"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <Button Content="Add PlcLabel"
                            Height="32"
                            Margin="0,0,0,8"
                            Click="AddPlcLabel_Click"/>
                    <Button Content="Add PlcDeviceEditor"
                            Height="32"
                            Margin="0,0,0,8"
                            Click="AddPlcDeviceEditor_Click"/>
                    <Button Content="Add LiveLogViewer"
                            Height="32"
                            Margin="0,0,0,8"
                            Click="AddLiveLogViewer_Click"/>
                    <Button Content="Reset Default Layout"
                            Height="32"
                            Margin="0,0,0,16"
                            Click="ResetLayout_Click"/>
                    <TextBlock Text="Drag widgets by title bar"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="{DynamicResource Surface.Bg.Panel}"
                    BorderBrush="{DynamicResource Surface.Border.Default}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8">
                <Canvas x:Name="DesignerCanvas"
                        Background="#0F223046"
                        ClipToBounds="True" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
