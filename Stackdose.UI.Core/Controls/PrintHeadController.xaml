<UserControl x:Class="Stackdose.UI.Core.Controls.PrintHeadController"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" d:DesignWidth="550" MinHeight="200">

	<UserControl.Resources>
		<!-- Modern button style -->
		<Style x:Key="ModernButtonStyle" TargetType="Button">
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Height" Value="28"/>
			<Setter Property="FontSize" Value="10"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="5"
                                Opacity="0.95">
							<ContentPresenter HorizontalAlignment="Center" 
						                       VerticalAlignment="Center"
						                       Margin="8,3"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Opacity" Value="0.9"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter Property="Opacity" Value="0.8"/>
							</Trigger>
							<Trigger Property="IsEnabled" Value="False">
								<Setter Property="Opacity" Value="0.5"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- Compact text input style -->
		<Style x:Key="CompactTextBoxStyle" TargetType="TextBox">
			<Setter Property="Background" Value="{DynamicResource Plc.Bg.Main}"/>
			<Setter Property="Foreground" Value="{DynamicResource Cyber.Text.Main}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource Plc.Border}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="4,2"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="TextBox">
						<Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
							<ScrollViewer x:Name="PART_ContentHost" 
                                          Margin="{TemplateBinding Padding}"/>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- Dropdown style -->
		<Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
			<Setter Property="Foreground" Value="{DynamicResource Text.Primary}"/>
			<Setter Property="Background" Value="{DynamicResource Surface.Bg.Card}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource Plc.Border}"/>
			<Setter Property="Padding" Value="8,4"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="ComboBox">
						<Grid>
							<ToggleButton x:Name="ToggleButton"
                                          Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="1">
								<ToggleButton.Template>
									<ControlTemplate TargetType="ToggleButton">
										<Border x:Name="Border"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="3">
											<Grid>
												<Grid.ColumnDefinitions>
													<ColumnDefinition Width="*"/>
													<ColumnDefinition Width="20"/>
												</Grid.ColumnDefinitions>
												<Path Grid.Column="1"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="{DynamicResource Text.Primary}"/>
											</Grid>
										</Border>
									</ControlTemplate>
								</ToggleButton.Template>
							</ToggleButton>
							<ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="8,0,23,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left">
								<ContentPresenter.Resources>
									<Style TargetType="{x:Type TextBlock}">
										<Setter Property="Foreground" Value="{DynamicResource Text.Primary}"/>
									</Style>
								</ContentPresenter.Resources>
							</ContentPresenter>
							<Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
								<Grid x:Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
									<Border x:Name="DropDownBorder"
                                            Background="{DynamicResource Surface.Bg.Card}"
                                            BorderBrush="{DynamicResource Plc.Border}"
                                            BorderThickness="1"
                                            CornerRadius="3">
										<ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
											<ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
										</ScrollViewer>
									</Border>
								</Grid>
							</Popup>
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
			<Setter Property="ItemContainerStyle">
				<Setter.Value>
					<Style TargetType="ComboBoxItem">
						<Setter Property="Foreground" Value="White"/>
						<Setter Property="Background" Value="Transparent"/>
						<Setter Property="Padding" Value="8,4"/>
						<Setter Property="Template">
							<Setter.Value>
								<ControlTemplate TargetType="ComboBoxItem">
									<Border x:Name="Border"
                                            Background="{TemplateBinding Background}"
                                            BorderThickness="0"
                                            Padding="{TemplateBinding Padding}">
										<ContentPresenter/>
									</Border>
									<ControlTemplate.Triggers>
										<Trigger Property="IsHighlighted" Value="True">
											<Setter TargetName="Border" Property="Background" Value="{DynamicResource Overlay.Highlight.Info}"/>
										</Trigger>
										<Trigger Property="IsSelected" Value="True">
											<Setter TargetName="Border" Property="Background" Value="{DynamicResource Surface.Bg.Panel}"/>
											<Setter Property="FontWeight" Value="Bold"/>
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Setter.Value>
						</Setter>
					</Style>
				</Setter.Value>
			</Setter>
		</Style>
	</UserControl.Resources>

	<Border Background="{DynamicResource Plc.Bg.Dark}" 
            BorderBrush="{DynamicResource Plc.Border}" 
            BorderThickness="1" 
            CornerRadius="6"
            Padding="10">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="6"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="6"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="6"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<!-- Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="PrintHead Controller"
                           FontSize="12"
                           FontWeight="Bold"
                           FontFamily="Consolas"
                           Foreground="{DynamicResource Cyber.Text.Main}"
                           VerticalAlignment="Center"
                           Margin="2,0"/>
                <Border Grid.Column="1"
                        Background="{DynamicResource Surface.Bg.Control}"
                        BorderBrush="{DynamicResource Plc.Border}"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="6,3">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6"
                                 Fill="#2ECC71"
                                 Margin="0,0,4,0"
                                 VerticalAlignment="Center"/>
                        <TextBlock x:Name="ConnectedCountText"
                                   Text="0 已連線"
                                   FontSize="9"
                                   Foreground="{DynamicResource Text.Secondary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

			<!-- Top control row -->
            <Border Grid.Row="2"
                    Background="{DynamicResource Plc.Bg.Main}"
                    BorderBrush="{DynamicResource Plc.Border}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8,6">
				<StackPanel>
					<!-- 第一行：閃噴頻率 + 執行閃噴 + 編碼器重置 -->
					<StackPanel Orientation="Horizontal">
						<TextBlock Text="閃噴頻率"
						           FontSize="9"
						           FontWeight="Bold"
						           Foreground="{DynamicResource Cyber.Text.Main}"
						           VerticalAlignment="Center"
						           Margin="0,0,6,0"/>

						<Border Background="{DynamicResource Plc.Bg.Main}"
						        BorderBrush="{DynamicResource Plc.Border}"
						        BorderThickness="1"
						        CornerRadius="2"
						        Padding="5,2"
						        Margin="0,0,8,0">
							<StackPanel Orientation="Horizontal">
								<TextBox x:Name="FrequencyBox"
								         Text="0.1,1,1,1"
								         Width="92"
								         FontSize="10"
								         BorderThickness="0"
								         Background="Transparent"
								         VerticalContentAlignment="Center"/>
								<TextBlock Text="KHz"
								           FontSize="8"
								           Foreground="{DynamicResource Plc.Text.Default}"
								           VerticalAlignment="Center"
								           Margin="3,0,0,0"/>
							</StackPanel>
						</Border>

						<Button Content="執行閃噴"
						        Width="76"
						        FontWeight="SemiBold"
						        Background="#27AE60"
						        Foreground="White"
						        BorderBrush="#229954"
						        Margin="0,0,8,0"
						        Click="SpitButton_Click"
						        Style="{StaticResource ModernButtonStyle}"/>

						<Button Content="編碼器重置"
						        Width="92"
						        Background="#C228CA"
						        Foreground="White"
						        BorderBrush="#8E44AD"
						        Click="EncoderReset_Click"
						        Style="{StaticResource ModernButtonStyle}"/>
					</StackPanel>

					<!-- 第二行：讀取 / 載入 / 取消 — 平均撐滿同寬 -->
					<Grid Margin="0,5,0,0">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="6"/>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="6"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>

						<Button Grid.Column="0"
						        Content="讀取圖片"
						        Background="#00B0FF"
						        Foreground="White"
						        BorderBrush="#0081CB"
						        x:Name="BrowseImageButton"
						        Click="BrowseImageButton_Click"
						        Style="{StaticResource ModernButtonStyle}"/>

						<Button Grid.Column="2"
						        Content="載入任務"
						        Background="#FF9100"
						        Foreground="White"
						        BorderBrush="#C56200"
						        x:Name="LoadImageButton"
						        Click="LoadImageButton_Click"
						        Style="{StaticResource ModernButtonStyle}"/>

						<Button Grid.Column="4"
						        Content="取消任務"
						        Background="#FF1744"
						        Foreground="White"
						        BorderBrush="#C4001D"
						        x:Name="CancelTaskButton"
						        Click="CancelTaskButton_Click"
						        Style="{StaticResource ModernButtonStyle}"/>
					</Grid>
				</StackPanel>
			</Border>

			<!-- Main content -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="132"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left panel -->
                <Grid Grid.Column="0" Background="{DynamicResource Plc.Bg.Main}">
                    <StackPanel Margin="8,6">
						<!-- 列印方向 -->
						<TextBlock Text="列印方向"
                                   FontSize="9"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource Cyber.Text.Main}"
                                   Margin="0,0,0,6"/>

						<ComboBox x:Name="DirectionCombo"
                                  Height="28"
                                  FontSize="10"
                                  Margin="0,0,0,12"
                                  SelectedIndex="0"
                                  Style="{StaticResource ModernComboBoxStyle}">
							<ComboBoxItem Content="雙向列印"/>
							<ComboBoxItem Content="左到右"/>
							<ComboBoxItem Content="右到左"/>
							<ComboBoxItem Content="CarAtRight 雙向"/>
							<ComboBoxItem Content="CarAtRight 左到右"/>
							<ComboBoxItem Content="CarAtRight 右到左"/>
						</ComboBox>

						<!-- 列印參數 -->
						<TextBlock Text="列印參數"
                                   FontSize="9"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource Cyber.Text.Main}"
                                   Margin="0,0,0,6"/>

						<Grid>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="4"/>
								<RowDefinition Height="Auto"/>
							</Grid.RowDefinitions>
							<Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>

							<TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="起點X："
                                       FontSize="8"
                                       Foreground="{DynamicResource Plc.Text.Default}"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     x:Name="StartXBox"
                                     Text="50"
                                      Height="20"
                                     FontSize="8"
                                     Margin="0,0,0,2"
                                     Style="{StaticResource CompactTextBoxStyle}"/>

							<TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="校正值："
                                       FontSize="8"
                                       Foreground="{DynamicResource Plc.Text.Default}"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="1"
                                     x:Name="CaliMMBox"
                                     Text="30.5"
                                     Height="20"
                                     FontSize="8"
                                     Margin="0,2,0,0"
                                     Style="{StaticResource CompactTextBoxStyle}"/>
                        </Grid>
                    </StackPanel>
                </Grid>

				<!-- Image preview -->
				<Border Grid.Column="2"
                        Background="{DynamicResource Surface.Bg.Control}"
                        BorderBrush="{DynamicResource Plc.Border}"
                        BorderThickness="1"
                        CornerRadius="3">
					<Grid>
						<Image x:Name="PreviewImage"
                               Stretch="Uniform"
                               Margin="6"/>

						<TextBlock x:Name="ImageInfoText"
                                   Text="尚未載入圖片"
                                   FontSize="10"
                                   Foreground="{DynamicResource Text.Tertiary}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="Visible"/>
					</Grid>
				</Border>
			</Grid>

			<!-- Transfer Progress Bar -->
			<Grid Grid.Row="5" x:Name="ProgressPanel" Visibility="Collapsed" Margin="2,0">
				<ProgressBar x:Name="TransferProgressBar"
                             Height="4"
                             Value="0"
                             Minimum="0"
                             Maximum="100"
                             Foreground="{DynamicResource Accent.Primary}"
                             Background="{DynamicResource Surface.Bg.Control}"
                             BorderThickness="0"/>
			</Grid>

			<!-- Footer status -->
			<Border Grid.Row="7"
                    Background="{DynamicResource Plc.Bg.Dark}"
                    BorderBrush="{DynamicResource Plc.Border}"
                    BorderThickness="1"
                    CornerRadius="3"
                    Padding="6,4">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="8"/>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="8"/>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="8"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>

					<!-- 檔案路徑 -->
					<TextBlock Grid.Column="0"
                               Text="檔案："
                               FontSize="8"
                               Foreground="{DynamicResource Plc.Text.Default}"
                               VerticalAlignment="Center"/>

					<TextBlock Grid.Column="1"
                               x:Name="FilePathText"
                               Text="尚未選擇檔案"
                               FontSize="8"
                               Foreground="{DynamicResource Cyber.Text.Main}"
                               VerticalAlignment="Center"
                               Margin="3,0,0,0"
                               TextTrimming="CharacterEllipsis"/>

					<!-- 圖片寬度 -->
					<StackPanel Grid.Column="2" Orientation="Horizontal">
						<TextBlock Text="寬度："
                                   FontSize="8"
                                   Foreground="{DynamicResource Plc.Text.Default}"
                                   VerticalAlignment="Center"/>
						<TextBlock x:Name="ImageWidthText"
                                   Text="-"
                                   FontSize="8"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource Accent.Primary}"
                                   VerticalAlignment="Center"
                                   Margin="3,0,0,0"/>
					</StackPanel>

					<!-- 圖片高度 -->
					<StackPanel Grid.Column="4" Orientation="Horizontal">
						<TextBlock Text="高度："
                                   FontSize="8"
                                   Foreground="{DynamicResource Plc.Text.Default}"
                                   VerticalAlignment="Center"/>
						<TextBlock x:Name="ImageHeightText"
                                   Text="-"
                                   FontSize="8"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource Accent.Primary}"
                                   VerticalAlignment="Center"
                                   Margin="3,0,0,0"/>
					</StackPanel>

					<!-- 水平 DPI -->
					<StackPanel Grid.Column="6" Orientation="Horizontal">
						<TextBlock Text="水平DPI："
                                   FontSize="8"
                                   Foreground="{DynamicResource Plc.Text.Default}"
                                   VerticalAlignment="Center"/>
						<TextBlock x:Name="XDpiText"
                                   Text="-"
                                   FontSize="8"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource Accent.Primary}"
                                   VerticalAlignment="Center"
                                   Margin="3,0,0,0"/>
					</StackPanel>

					<!-- 垂直 DPI -->
					<StackPanel Grid.Column="8" Orientation="Horizontal">
						<TextBlock Text="垂直DPI："
                                   FontSize="8"
                                   Foreground="{DynamicResource Plc.Text.Default}"
                                   VerticalAlignment="Center"/>
						<TextBlock x:Name="YDpiText"
                                   Text="-"
                                   FontSize="8"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource Accent.Primary}"
                                   VerticalAlignment="Center"
                                   Margin="3,0,0,0"/>
					</StackPanel>
				</Grid>
			</Border>
		</Grid>
	</Border>
</UserControl>
