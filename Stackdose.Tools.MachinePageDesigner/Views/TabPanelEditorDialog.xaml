<Window x:Class="Stackdose.Tools.MachinePageDesigner.Views.TabPanelEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Stackdose.Tools.MachinePageDesigner.Views"
        xmlns:vm="clr-namespace:Stackdose.Tools.MachinePageDesigner.ViewModels"
        Title="TabPanel 子項目設計器"
        Width="1100" Height="720"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{StaticResource BgBrush}">

    <Window.InputBindings>
        <KeyBinding Command="{Binding UndoCmd}" Gesture="Ctrl+Z"/>
        <KeyBinding Command="{Binding RedoCmd}" Gesture="Ctrl+Y"/>
        <KeyBinding Command="{Binding CopyCmd}" Gesture="Ctrl+C"/>
        <KeyBinding Command="{Binding PasteCmd}" Gesture="Ctrl+V"/>
        <KeyBinding Command="{Binding DeleteSelectedCmd}" Gesture="Delete"/>
        <KeyBinding Command="{Binding SelectAllCmd}" Gesture="Ctrl+A"/>
    </Window.InputBindings>

    <DockPanel>
        <!-- ── Top: tab header strip ──────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="Tab："
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           FontSize="12"/>
                <ContentControl x:Name="TabHeadersControl"
                                DockPanel.Dock="Left"
                                VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- ── Bottom: Save / Cancel ──────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,6">
            <DockPanel>
                <!-- 狀態列訊息 -->
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Margin="8,0,0,0"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button x:Name="BtnSave"
                            Content="✔ 儲存並關閉"
                            Width="110" Height="30"
                            Margin="0,0,8,0"
                            Background="#3A5690"
                            Foreground="White"
                            BorderThickness="0"
                            Click="OnSave"/>
                    <Button x:Name="BtnCancel"
                            Content="✘ 取消"
                            Width="90" Height="30"
                            Background="#4A3030"
                            Foreground="White"
                            BorderThickness="0"
                            Click="OnCancel"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Left: Toolbox ──────────────────────────────────────────── -->
        <Border DockPanel.Dock="Left"
                Width="170"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <local:ToolboxPanel x:Name="ToolboxPanelCtrl"/>
        </Border>

        <!-- ── Right: Property Panel ───────────────────────────────────── -->
        <Border DockPanel.Dock="Right"
                Width="260"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1,0,0,0">
            <local:PropertyPanel x:Name="PropertyPanelCtrl"
                                 DataContext="{Binding Canvas.SelectedItem}"/>
        </Border>

        <!-- ── Center: FreeCanvas ─────────────────────────────────────── -->
        <local:FreeCanvas x:Name="EditorCanvas"/>

    </DockPanel>
</Window>
