<UserControl x:Class="Stackdose.App.ModelE.SinglePage2.Pages.SingleDetailWorkspacePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:core="http://schemas.stackdose.com/wpf"
             xmlns:templateControls="clr-namespace:Stackdose.UI.Templates.Controls;assembly=Stackdose.UI.Templates"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1800">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Stackdose.UI.Templates;component/Resources/CommonColors.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{DynamicResource Surface.Bg.Page}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource Surface.Bg.Panel}"
                BorderBrush="{DynamicResource Surface.Border.Default}"
                BorderThickness="1"
                CornerRadius="8"
                MinHeight="200"
                Padding="12,16"
                Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Title"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock x:Name="MachineSummaryText"
                                   Text="Subtitle"
                                   Margin="0,4,0,8"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>

                    <core:PlcStatus x:Name="TopPlcStatus"
                                    Grid.Column="1"
                                    Width="280"
                                    Height="58"
                                    IsGlobal="True"
                                    ShowBorder="True"
                                    AutoConnect="False" />
                </Grid>

                <UniformGrid Grid.Row="1"
                             Columns="5"
                             Margin="0,8,0,0">
                    <core:InfoLabel Height="100" Label="PLC" Value="--" FrameBackground="DarkBlue" ValueAlignment="Center" />
                    <core:InfoLabel Height="100" Label="Head" Value="--" FrameBackground="DarkBlue" ValueAlignment="Center" />
                    <core:InfoLabel Height="100" Label="Commands" Value="0" FrameBackground="DarkBlue" ValueAlignment="Center" />
                    <core:InfoLabel Height="100" Label="Monitors" Value="0" FrameBackground="DarkBlue" ValueAlignment="Center" />
                    <core:InfoLabel Height="100" Label="Alarms" Value="0" FrameBackground="DarkBlue" ValueAlignment="Center" />
                </UniformGrid>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="520" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <templateControls:GroupBoxBlock Grid.Row="0"
                                               Header="GroupBox 1"
                                               BadgeText="Drop Here"
                                               GroupPadding="10" />

                <templateControls:GroupBoxBlock Grid.Row="2"
                                               Header="GroupBox 2"
                                               BadgeText="Drop Here"
                                               GroupPadding="10" />

                <templateControls:GroupBoxBlock Grid.Row="4"
                                               Header="GroupBox 3"
                                               BadgeText="Drop Here"
                                               GroupPadding="10" />
            </Grid>

            <Border Grid.Column="2"
                    Background="{DynamicResource Surface.Bg.Panel}"
                    BorderBrush="{DynamicResource Surface.Border.Default}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <TabControl Style="{StaticResource Template.TabControl}"
                            Margin="0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch">
                    <TabItem Header="Bootstrap" Style="{StaticResource Template.TabItem}">
                        <Grid Background="{DynamicResource Surface.Bg.Page}">
                            <TextBlock Text="listBootstrap"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="10"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top" />
                        </Grid>
                    </TabItem>

                    <TabItem Header="Monitor" Style="{StaticResource Template.TabItem}">
                        <Grid Background="{DynamicResource Surface.Bg.Page}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <core:PlcDeviceEditor Grid.Column="0" Margin="0" Height="220" VerticalAlignment="Top" />
                            <StackPanel Grid.Column="2">
                                <core:InfoLabel Label="Monitors" Value="0" Caption="Realtime" />
                                <core:InfoLabel Margin="0,8,0,0" Label="Commands" Value="0" Caption="Pending" />
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Sensors" Style="{StaticResource Template.TabItem}">
                        <Grid Background="{DynamicResource Surface.Bg.Page}">
                            <core:SensorViewer ConfigFile="" />
                        </Grid>
                    </TabItem>

                    <TabItem Header="Alarms" Style="{StaticResource Template.TabItem}">
                        <Grid Background="{DynamicResource Surface.Bg.Page}">
                            <core:AlarmViewer ConfigFile="" />
                        </Grid>
                    </TabItem>

                    <TabItem Header="Messages" Style="{StaticResource Template.TabItem}">
                        <Grid Background="{DynamicResource Surface.Bg.Page}">
                            <core:LiveLogViewer />
                        </Grid>
                    </TabItem>

                    <TabItem Header="Recipe" Style="{StaticResource Template.TabItem}">
                        <Grid Background="{DynamicResource Surface.Bg.Page}">
                            <core:InfoLabel Width="320"
                                            Height="100"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Label="Recipe"
                                            Value="--"
                                            Caption="Ready" />
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</UserControl>
