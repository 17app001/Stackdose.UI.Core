<UserControl x:Class="Stackdose.UI.Core.Controls.SystemClock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              mc:Ignorable="d"
              d:DesignWidth="240"
              d:DesignHeight="72">

    <Border Background="{DynamicResource Surface.Bg.Card}"
            BorderBrush="{DynamicResource Surface.Border.Default}"
            BorderThickness="1"
            CornerRadius="4"
            Padding="12,8">
        <StackPanel>
            <TextBlock x:Name="TimeText"
                       Text="00:00:00"
                       FontSize="{Binding TimeFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontWeight="Bold"
                       HorizontalAlignment="Right"
                       FontFamily="Consolas"
                       Foreground="{DynamicResource Text.Primary}"/>
            <TextBlock x:Name="DateText"
                       Text="2000-01-01"
                       FontSize="{Binding DateFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       HorizontalAlignment="Right"
                       Foreground="{DynamicResource Text.Secondary}"
                       Margin="0,4,0,0"/>
        </StackPanel>
    </Border>
</UserControl>
