<base:PlcControlBase x:Class="Stackdose.UI.Core.Controls.PlcLabel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:Stackdose.UI.Core.Converters"
             xmlns:base="clr-namespace:Stackdose.UI.Core.Controls.Base"
             mc:Ignorable="d" 
             d:DesignHeight="60" d:DesignWidth="200"
             Foreground="{DynamicResource Plc.Text.Value}">

    <FrameworkElement.ToolTip>
        <ToolTip Background="#1A1E2A"
                 BorderBrush="{DynamicResource Plc.Border}"
                 BorderThickness="1"
                 Padding="8,6"
                 Placement="Mouse"
                 HasDropShadow="True">
            <StackPanel>
                <TextBlock Text="PLC Address"
                           Foreground="#B9C7E6"
                           FontSize="10"
                           FontFamily="Consolas" />
                <TextBlock Text="{Binding PlacementTarget.Address, RelativeSource={RelativeSource AncestorType=ToolTip}}"
                           Foreground="#5DE2FF"
                           FontSize="12"
                           FontWeight="SemiBold"
                           FontFamily="Consolas" />
            </StackPanel>
        </ToolTip>
    </FrameworkElement.ToolTip>

    <FrameworkElement.Resources>
        <converters:PlcLabelColorThemeToBrushConverter x:Key="ColorThemeConverter"/>
    </FrameworkElement.Resources>

    <Border x:Name="FrameBorder"
             ClipToBounds="True"
             Background="{Binding FrameBackground, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource ColorThemeConverter}}">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="{DynamicResource Plc.Border}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="Padding" Value="10,6"/>
                
                <Style.Triggers>
                    <DataTrigger Binding="{Binding FrameBackground, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Default">
                        <Setter Property="Background" Value="{DynamicResource Plc.Bg.Main}"/>
                    </DataTrigger>
                    
                    <DataTrigger Binding="{Binding ShowFrame, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="0"/>
                    </DataTrigger>
                    
                    <DataTrigger Binding="{Binding FrameShape, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Circle">
                        <Setter Property="CornerRadius" Value="500"/>
                        <Setter Property="Padding" Value="14"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        
        <!-- 使用 Viewbox 確保圓形時內容自適應 -->
        <Grid x:Name="ContentGrid" VerticalAlignment="Center">
            <Grid.Style>
                <Style TargetType="Grid">
                    <!-- 圓形時強制寬高相等 -->
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding FrameShape, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Circle">
                            <Setter Property="Width" Value="{Binding ActualHeight, RelativeSource={RelativeSource Self}}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue='Label'}" 
                       Foreground="{Binding LabelForeground, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource ColorThemeConverter}}"
                       FontSize="{Binding LabelFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontFamily="Microsoft JhengHei"
                       HorizontalAlignment="{Binding LabelAlignment, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       TextTrimming="CharacterEllipsis" 
                       VerticalAlignment="Center"
                       Margin="0,0,0,2">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <!-- 圓形時自動置中 -->
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FrameShape, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Circle">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- 數值顯示 (第二行) -->
            <TextBlock Grid.Row="1" 
                       Foreground="{Binding ValueForeground, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource ColorThemeConverter}}"
                       FontSize="{Binding ValueFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                       FontWeight="Bold" 
                       FontFamily="Consolas"
                       HorizontalAlignment="{Binding ValueAlignment, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                       VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue='123.4'}"/>
                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>

                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FrameShape, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Circle">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </DataTrigger>
                            
                            <DataTrigger Binding="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="-">
                                <Setter Property="Text" Value="{Binding DefaultValue, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                <Setter Property="Opacity" Value="0.5"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="">
                                <Setter Property="Text" Value="{Binding DefaultValue, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                <Setter Property="Opacity" Value="0.5"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="{x:Null}">
                                <Setter Property="Text" Value="{Binding DefaultValue, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                <Setter Property="Opacity" Value="0.5"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <TextBlock Grid.Row="2"
                       Text="{Binding Address, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue='D0'}" 
                       Foreground="{DynamicResource Plc.Text.Default}" 
                       FontSize="9" 
                       FontFamily="Consolas"
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Left"
                       Margin="0,2,0,0"
                       Opacity="0.7">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <!-- 圓形時自動置中並縮小 -->
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FrameShape, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Circle">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontSize" Value="8"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
                <TextBlock.Visibility>
                    <Binding Path="ShowAddress" RelativeSource="{RelativeSource AncestorType=UserControl}">
                        <Binding.Converter>
                            <BooleanToVisibilityConverter/>
                        </Binding.Converter>
                    </Binding>
                </TextBlock.Visibility>
            </TextBlock>
        </Grid>
    </Border>
</base:PlcControlBase>
