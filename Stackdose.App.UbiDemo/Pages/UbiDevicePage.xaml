<UserControl x:Class="Stackdose.App.UbiDemo.Pages.UbiDevicePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="http://schemas.stackdose.com/wpf"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1400"
             d:DesignHeight="900">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Stackdose.App.UbiDemo;component/Resources/DevicePageTemplates.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{DynamicResource Surface.Bg.Page}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ContentControl Content="{Binding}"
                        ContentTemplate="{StaticResource DeviceProcessTriggerTemplate}" />

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="360" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="460" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="Command Operation" Margin="0,0,0,10">
                    <StackPanel Margin="8">
                        <ContentControl Content="{Binding}"
                                        ContentTemplate="{StaticResource DeviceCommandTemplate}" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="1" Header="Command Actions">
                    <StackPanel Margin="8" VerticalAlignment="Top">
                        <core:SecuredButton Content="Initialize"
                                            Theme="Primary"
                                            RequiredLevel="Operator"
                                            OperationName="Initialize"
                                            Margin="0,0,0,8"
                                            HorizontalAlignment="Stretch" />
                        <core:SecuredButton Content="Device Clean"
                                            Theme="Warning"
                                            RequiredLevel="Operator"
                                            OperationName="Device Clean"
                                            Margin="0,0,0,8"
                                            HorizontalAlignment="Stretch" />
                        <core:SecuredButton Content="Clear Alarm"
                                            Theme="Error"
                                            RequiredLevel="Operator"
                                            OperationName="Clear Alarm"
                                            HorizontalAlignment="Stretch" />
                    </StackPanel>
                </GroupBox>
            </Grid>

            <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="PrintHead Quick Operation" Margin="0,0,0,10">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <core:PrintHeadStatus HeadName="PrintHead 1"
                                                  ConfigFilePath="{Binding PrintHead1ConfigFile}"
                                                  AutoConnect="False"
                                                  Margin="0,0,8,0" />

                            <core:PrintHeadStatus Grid.Column="1"
                                                  HeadName="PrintHead 2"
                                                  ConfigFilePath="{Binding PrintHead2ConfigFile}"
                                                  AutoConnect="False"
                                                  Margin="8,0,0,0" />
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Spit" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding SpitParameter}"
                                     Margin="0,0,8,0" />
                            <core:SecuredButton Grid.Column="2" Content="Execute" Theme="Warning" RequiredLevel="Operator" OperationName="Spit" Margin="0,0,8,0" />
                            <core:SecuredButton Grid.Column="3" Content="Grating Reset" Theme="Primary" RequiredLevel="Operator" OperationName="Grating Reset" />
                        </Grid>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="1" Header="Print Information">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <UniformGrid Columns="2" Margin="8">
                            <UniformGrid.Resources>
                                <Style TargetType="{x:Type core:PlcLabel}">
                                    <Setter Property="LabelFontSize" Value="11" />
                                    <Setter Property="ValueFontSize" Value="14" />
                                    <Setter Property="ShowAddress" Value="False" />
                                    <Setter Property="Margin" Value="2" />
                                </Style>
                            </UniformGrid.Resources>
                            <core:PlcLabel Label="Total Tray" Address="{Binding TotalTrayAddress}" ShowFrame="True" DefaultValue="0" />
                            <core:PlcLabel Label="Current Tray" Address="{Binding CurrentTrayAddress}" ShowFrame="True" DefaultValue="0" />
                            <core:PlcLabel Label="Total Layer" Address="{Binding TotalLayerAddress}" ShowFrame="True" DefaultValue="0" />
                            <core:PlcLabel Label="Current Layer" Address="{Binding CurrentLayerAddress}" ShowFrame="True" DefaultValue="0" />
                            <core:PlcLabel Label="Switch Graphic Layer" Address="{Binding SwitchGraphicLayerAddress}" ShowFrame="True" DefaultValue="0" />
                            <core:PlcLabel Label="Switch Area Layer" Address="{Binding SwitchAreaLayerAddress}" ShowFrame="True" DefaultValue="0" />
                            <core:PlcLabel Label="Message ID" Address="{Binding MessageIdAddress}" ShowFrame="True" DefaultValue="0" />
                            <core:PlcLabel Label="Battery" Address="{Binding BatteryAddress}" Divisor="10" StringFormat="F1" ShowFrame="True" DefaultValue="0.0" />
                            <core:PlcLabel Label="Elapsed Time" Address="{Binding ElapsedTimeAddress}" ShowFrame="True" DefaultValue="00:00:00" />
                            <core:PlcLabel Label="PrintHead Count" Address="{Binding PrintHeadCountAddress}" ShowFrame="True" DefaultValue="2" />
                            <core:PlcLabel Label="Batch" Address="{Binding BatchAddress}" ShowFrame="True" DefaultValue="--" />
                            <core:PlcLabel Label="Recipe" Address="{Binding RecipeAddress}" ShowFrame="True" DefaultValue="--" />
                            <core:PlcLabel Label="Nozzle" Address="{Binding NozzleAddress}" ShowFrame="True" DefaultValue="--" />
                            <core:PlcLabel Label="Alarm" Address="{Binding AlarmAddress}" DataType="Bit" ShowFrame="True" DefaultValue="OFF" />
                        </UniformGrid>
                    </ScrollViewer>
                </GroupBox>
            </Grid>

            <Grid Grid.Row="0" Grid.Column="2" Grid.RowSpan="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <GroupBox Header="Alarm Viewer" Margin="0,0,0,10">
                    <core:AlarmViewer Title="ALM"
                                      ConfigFile="{Binding AlarmConfigFile}"
                                      ItemFontSize="12"
                                      ShowDeviceAddress="False" />
                </GroupBox>

                <GroupBox Grid.Row="1" Header="Sensor Viewer">
                    <core:SensorViewer Title="SNR"
                                       ConfigFile="{Binding SensorConfigFile}"
                                       ItemFontSize="12"
                                       ShowDeviceAddress="False"
                                       EnableGrouping="True"
                                       AutoStart="True"
                                       RefreshInterval="500" />
                </GroupBox>
            </Grid>

            <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,10,0">
                <GroupBox Header="System Log">
                    <core:LiveLogViewer Margin="8" />
                </GroupBox>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
