<UserControl x:Class="Stackdose.UI.Core.Controls.LiveLogViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="220" d:DesignWidth="420">

    <Border Background="{DynamicResource Log.Bg.Main}"
            BorderBrush="{DynamicResource Log.Border}"
            BorderThickness="1"
            CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="{DynamicResource Log.Bg.Header}"
                    BorderBrush="{DynamicResource Log.Border}"
                    BorderThickness="0,0,0,1"
                    Padding="10,8"
                    CornerRadius="6,6,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="SYSTEM LOG / AUDIT TRAIL"
                               Foreground="{DynamicResource Plc.Text.Label}"
                               FontSize="11"
                               FontWeight="Bold"
                               FontFamily="Consolas"
                               VerticalAlignment="Center"/>

                    <Border Grid.Column="1"
                            Background="{DynamicResource Overlay.Bg.Medium}"
                            CornerRadius="10"
                            Padding="8,2"
                            VerticalAlignment="Center">
                        <TextBlock Text="LIVE"
                                   Foreground="{DynamicResource Status.Success}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"/>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <ListView x:Name="LogList"
                          Background="Transparent"
                          BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.CanContentScroll="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          SnapsToDevicePixels="True">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="ItemBorder"
                                                Background="{TemplateBinding Background}"
                                                Padding="0">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Overlay.Highlight.Info}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="92"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding TimeStr}"
                                           Foreground="{DynamicResource Log.Text.Time}"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           VerticalAlignment="Top"
                                           Margin="0,1,8,0"/>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding Message}"
                                           Foreground="{Binding Color}"
                                           FontFamily="Microsoft JhengHei"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           LineHeight="18"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Border IsHitTestVisible="False"
                        Background="{DynamicResource Overlay.Bg.Light}"
                        CornerRadius="4"
                        Padding="12,6"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=LogList, Path=Items.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="目前尚無日誌"
                               Foreground="{DynamicResource Plc.Text.Gray}"
                               FontFamily="Microsoft JhengHei"
                               FontSize="12"
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
