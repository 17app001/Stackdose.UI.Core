<Window x:Class="Stackdose.Tools.MachinePageDesigner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Stackdose.Tools.MachinePageDesigner.Views"
        xmlns:vm="clr-namespace:Stackdose.Tools.MachinePageDesigner.ViewModels"
        Title="{Binding WindowTitle}"
        Width="1400" Height="900"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl"       Command="{Binding NewCmd}"/>
        <KeyBinding Key="O" Modifiers="Ctrl"       Command="{Binding OpenCmd}"/>
        <KeyBinding Key="S" Modifiers="Ctrl"       Command="{Binding SaveCmd}"/>
        <KeyBinding Key="S" Modifiers="Ctrl+Shift" Command="{Binding SaveAsCmd}"/>
        <KeyBinding Key="Z" Modifiers="Ctrl"       Command="{Binding UndoCmd}"/>
        <KeyBinding Key="Y" Modifiers="Ctrl"       Command="{Binding RedoCmd}"/>
        <KeyBinding Key="Delete"                    Command="{Binding DeleteSelectedCmd}"/>
        <KeyBinding Key="C" Modifiers="Ctrl"       Command="{Binding CopyCmd}"/>
        <KeyBinding Key="V" Modifiers="Ctrl"       Command="{Binding PasteCmd}"/>
        <KeyBinding Key="A" Modifiers="Ctrl"       Command="{Binding SelectAllCmd}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,4">
            <WrapPanel>
                <Button Content="&#x2795; New"     Command="{Binding NewCmd}"     Style="{StaticResource ToolbarButton}" Margin="0,0,4,0"/>
                <Button Content="&#x2197; Open"    Command="{Binding OpenCmd}"    Style="{StaticResource ToolbarButton}" Margin="0,0,4,0"/>
                <Button Content="&#x25BC; Save"    Command="{Binding SaveCmd}"    Style="{StaticResource ToolbarButton}" Margin="0,0,4,0"/>
                <Button Content="&#x25BD; Save As" Command="{Binding SaveAsCmd}"  Style="{StaticResource ToolbarButton}" Margin="0,0,16,0"/>

                <Separator Style="{x:Null}" Width="1" Background="{StaticResource BorderBrush}" Margin="0,2,16,2"/>

                <Button Content="&#x21B6; Undo"    Command="{Binding UndoCmd}"    Style="{StaticResource ToolbarButton}" Margin="0,0,4,0"/>
                <Button Content="&#x21B7; Redo"    Command="{Binding RedoCmd}"    Style="{StaticResource ToolbarButton}" Margin="0,0,16,0"/>

                <Separator Style="{x:Null}" Width="1" Background="{StaticResource BorderBrush}" Margin="0,2,16,2"/>

                <Button Content="&#x2716; Delete"  Command="{Binding DeleteSelectedCmd}" Style="{StaticResource ToolbarButton}" Margin="0,0,4,0"/>
                <Button Content="&#x2398; Copy"    Command="{Binding CopyCmd}"          Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" ToolTip="複製選取元件（Ctrl+C）"/>
                <Button Content="&#x2399; Paste"   Command="{Binding PasteCmd}"         Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" ToolTip="貼上（Ctrl+V）"/>
                <Button Content="&#x2630; All"     Command="{Binding SelectAllCmd}"     Style="{StaticResource ToolbarButton}" Margin="0,0,16,0" ToolTip="全選（Ctrl+A）"/>

                <Separator Style="{x:Null}" Width="1" Background="{StaticResource BorderBrush}" Margin="0,2,16,2"/>

                <!-- Z-Order -->
                <Button Content="&#x25B3;&#x25B3;" Command="{Binding BringToFrontCmd}" Style="{StaticResource ToolbarButton}" Margin="0,0,2,0" ToolTip="移至最前（Bring to Front）"/>
                <Button Content="&#x25B3;"  Command="{Binding MoveUpCmd}"       Style="{StaticResource ToolbarButton}" Margin="0,0,2,0" ToolTip="上移一層（Move Up）"/>
                <Button Content="&#x25BD;"  Command="{Binding MoveDownCmd}"     Style="{StaticResource ToolbarButton}" Margin="0,0,2,0" ToolTip="下移一層（Move Down）"/>
                <Button Content="&#x25BD;&#x25BD;" Command="{Binding SendToBackCmd}"  Style="{StaticResource ToolbarButton}" Margin="0,0,16,0" ToolTip="移至最後（Send to Back）"/>

                <Separator Style="{x:Null}" Width="1" Background="{StaticResource BorderBrush}" Margin="0,2,16,2"/>

                <!-- Lock -->
                <Button Content="&#x1F512; Lock" Command="{Binding LockToggleCmd}" Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" ToolTip="鎖定/解鎖選取元件"/>

                <Separator Style="{x:Null}" Width="1" Background="{StaticResource BorderBrush}" Margin="4,2,4,2"/>

                <!-- Align -->
                <Button Content="&#x2594;&#x258C;" Command="{Binding AlignLeftCmd}"    Style="{StaticResource ToolbarButton}" Margin="0,0,2,0" ToolTip="靠左對齊 (Align Left)"/>
                <Button Content="&#x2506;"         Command="{Binding AlignCenterHCmd}" Style="{StaticResource ToolbarButton}" Margin="0,0,2,0" ToolTip="水平置中 (Center Horizontally)"/>
                <Button Content="&#x2590;&#x2594;" Command="{Binding AlignRightCmd}"   Style="{StaticResource ToolbarButton}" Margin="0,0,2,0" ToolTip="靠右對齊 (Align Right)"/>
                <Button Content="&#x2594;&#x2015;" Command="{Binding AlignTopCmd}"     Style="{StaticResource ToolbarButton}" Margin="0,0,2,0" ToolTip="靠上對齊 (Align Top)"/>
                <Button Content="&#x2550;"         Command="{Binding AlignCenterVCmd}" Style="{StaticResource ToolbarButton}" Margin="0,0,2,0" ToolTip="垂直置中 (Center Vertically)"/>
                <Button Content="&#x2015;&#x2581;" Command="{Binding AlignBottomCmd}"  Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" ToolTip="靠下對齊 (Align Bottom)"/>

                <Separator Style="{x:Null}" Width="1" Background="{StaticResource BorderBrush}" Margin="4,2,4,2"/>

                <!-- Distribute -->
                <Button Content="&#x2194; =" Command="{Binding DistributeHorizCmd}" Style="{StaticResource ToolbarButton}" Margin="0,0,2,0" ToolTip="水平平均間距 (Distribute Horizontally，需 3 個以上)"/>
                <Button Content="&#x2195; =" Command="{Binding DistributeVertCmd}"  Style="{StaticResource ToolbarButton}" Margin="0,0,16,0" ToolTip="垂直平均間距 (Distribute Vertically，需 3 個以上)"/>

                <Separator Style="{x:Null}" Width="1" Background="{StaticResource BorderBrush}" Margin="0,2,16,2"/>

                <!-- Snap to Grid -->
                <ToggleButton Content="&#x22EF; Snap"
                              IsChecked="{Binding SnapToGrid}"
                              Style="{StaticResource CanvasModeToggle}"
                              Margin="0,0,4,0"
                              ToolTip="Snap to Grid（吸附格線，10px）"/>

                <!-- PLC Tags -->
                <Button Content="&#x1F4CC; Tags"
                        Command="{Binding OpenTagEditorCmd}"
                        Style="{StaticResource ToolbarButton}"
                        Margin="0,0,16,0"
                        ToolTip="編輯 PLC Tags（地址 → 名稱對照表）"/>

                <Separator Style="{x:Null}" Width="1" Background="{StaticResource BorderBrush}" Margin="0,2,16,2"/>

                <TextBlock Text="Canvas:" Style="{StaticResource FieldLabel}" Margin="0,0,4,0"/>
                <TextBox Text="{Binding CanvasWidth, UpdateSourceTrigger=LostFocus, StringFormat=F0}"
                         Width="56" Margin="0,0,2,0" ToolTip="畫布寬度（px，400–4000）"/>
                <TextBlock Text="×" Style="{StaticResource FieldLabel}" Margin="0,0,2,0"/>
                <TextBox Text="{Binding CanvasHeight, UpdateSourceTrigger=LostFocus, StringFormat=F0}"
                         Width="56" Margin="0,0,16,0" ToolTip="畫布高度（px，300–3000）"/>

                <Separator Style="{x:Null}" Width="1" Background="{StaticResource BorderBrush}" Margin="0,2,16,2"/>

                <TextBlock Text="Layout:" Style="{StaticResource FieldLabel}" Margin="0,0,4,0"/>
                <ComboBox ItemsSource="{Binding LayoutModes}" SelectedItem="{Binding LayoutMode}" Width="120" Margin="0,0,12,0"/>

                <TextBlock Text="Title:" Style="{StaticResource FieldLabel}" Margin="0,0,4,0"/>
                <TextBox Text="{Binding DocTitle, UpdateSourceTrigger=PropertyChanged}" Width="160" Margin="0,0,12,0"/>

                <TextBlock Text="Machine ID:" Style="{StaticResource FieldLabel}" Margin="0,0,4,0"/>
                <TextBox Text="{Binding MachineId, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
            </WrapPanel>
        </Border>

        <!-- Page Tabs -->
        <Border Grid.Row="1"
                Background="#1A1A2E"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,0,4,0">
            <DockPanel>
                <!-- Add Page -->
                <Button DockPanel.Dock="Right"
                        Content="+"
                        Command="{Binding AddPageCmd}"
                        Style="{StaticResource ToolbarButton}"
                        Width="26" Height="26"
                        FontSize="15" FontWeight="Bold"
                        ToolTip="新增頁面"
                        Margin="4,2,0,2"
                        VerticalAlignment="Center"/>

                <!-- Tab list -->
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Pages}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:PageTabViewModel}">
                                <Border x:Name="tabBorder"
                                        Margin="1,3,1,0"
                                        Padding="0"
                                        CornerRadius="4,4,0,0"
                                        Background="#252540"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1,1,1,0"
                                        Cursor="Hand">
                                    <DockPanel Margin="6,3,4,3">
                                        <!-- Delete button -->
                                        <Button DockPanel.Dock="Right"
                                                Content="×"
                                                FontSize="11"
                                                Width="16" Height="16"
                                                Padding="0"
                                                Margin="4,0,0,0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="#888"
                                                VerticalAlignment="Center"
                                                Command="{Binding DataContext.DeletePageCmd,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="刪除此頁面"/>

                                        <!-- Page name (view mode) -->
                                        <TextBlock x:Name="pageNameText"
                                                   Text="{Binding Name}"
                                                   FontSize="12"
                                                   Foreground="#AAAACC"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding IsEditing,
                                                       Converter={StaticResource InverseBoolToVisibility}}"/>

                                        <!-- Page name (edit mode) -->
                                        <TextBox x:Name="pageNameEdit"
                                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="12"
                                                 Background="Transparent"
                                                 BorderThickness="0,0,0,1"
                                                 BorderBrush="#6C8EEF"
                                                 Foreground="White"
                                                 MinWidth="60"
                                                 VerticalAlignment="Center"
                                                 Visibility="{Binding IsEditing,
                                                     Converter={StaticResource BoolToVisibilityConverter}}"
                                                 local:FocusHelper.IsFocused="{Binding IsEditing}"
                                                 LostFocus="OnPageNameEditLostFocus"
                                                 KeyDown="OnPageNameEditKeyDown"/>
                                    </DockPanel>

                                    <!-- Click to select -->
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.SelectPageCmd,
                                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CommandParameter="{Binding}"/>
                                        <MouseBinding MouseAction="LeftDoubleClick"
                                                      Command="{Binding DataContext.RenamePageCmd,
                                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter TargetName="tabBorder" Property="Background" Value="#2D2D50"/>
                                        <Setter TargetName="tabBorder" Property="BorderBrush" Value="#6C8EEF"/>
                                        <Setter TargetName="pageNameText" Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Main 3-column layout -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="150" MaxWidth="300"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="280" MinWidth="200" MaxWidth="400"/>
            </Grid.ColumnDefinitions>

            <local:ToolboxPanel Grid.Column="0" DataContext="{Binding Toolbox}"/>
            <GridSplitter Grid.Column="1" Width="3" Background="{StaticResource BorderBrush}" HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

            <local:FreeCanvas Grid.Column="2"
                              DataContext="{Binding Canvas}"
                              Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"/>

            <GridSplitter Grid.Column="3" Width="3" Background="{StaticResource BorderBrush}" HorizontalAlignment="Center" VerticalAlignment="Stretch"/>
            <local:PropertyPanel Grid.Column="4" DataContext="{Binding Canvas.SelectedItem}"
                                 Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                 Tags="{Binding DataContext.Tags, RelativeSource={RelativeSource AncestorType=Window}}"/>
        </Grid>

        <!-- StatusBar -->
        <Border Grid.Row="3"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="10,4">
            <TextBlock Text="{Binding StatusText}" Style="{StaticResource FieldLabel}" FontSize="11"/>
        </Border>
    </Grid>
</Window>
