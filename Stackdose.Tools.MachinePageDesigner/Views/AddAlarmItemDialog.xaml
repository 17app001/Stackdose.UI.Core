<Window x:Class="Stackdose.Tools.MachinePageDesigner.Views.AddAlarmItemDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新增報警定義"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="Lbl">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,8,0,2"/>
        </Style>
    </Window.Resources>

    <Border Padding="20">
        <StackPanel>
            <!-- Group -->
            <TextBlock Text="群組 (Group)" Style="{StaticResource Lbl}"/>
            <TextBox x:Name="TxtGroup" Text="General"/>

            <!-- Device -->
            <TextBlock Style="{StaticResource Lbl}">
                <Run Text="PLC 位址 (Device)"/>
                <Run Text="  例：M100" Foreground="Gray" FontSize="11"/>
            </TextBlock>
            <TextBox x:Name="TxtDevice" Text="M100"/>

            <!-- Bit -->
            <TextBlock Style="{StaticResource Lbl}">
                <Run Text="Bit 索引"/>
                <Run Text="  整數，0 起算" Foreground="Gray" FontSize="11"/>
            </TextBlock>
            <TextBox x:Name="TxtBit" Text="0"/>

            <!-- Description -->
            <TextBlock Text="描述 (OperationDescription)" Style="{StaticResource Lbl}"/>
            <TextBox x:Name="TxtDescription" Text="" MinHeight="32"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="確定" IsDefault="True" Width="80" Height="30"
                        Margin="0,0,8,0" Click="OnOk"/>
                <Button Content="取消" IsCancel="True" Width="80" Height="30"
                        Click="OnCancel"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
