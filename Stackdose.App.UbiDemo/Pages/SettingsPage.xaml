<UserControl x:Class="Stackdose.App.UbiDemo.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="http://schemas.stackdose.com/wpf"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="860"
             d:DesignWidth="1300">
    <Grid Background="{DynamicResource Surface.Bg.Page}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*" />
            <ColumnDefinition Width="1.8*" />
        </Grid.ColumnDefinitions>

        <!-- ========================================== -->
        <!-- LEFT: Global Settings                      -->
        <!-- ========================================== -->
        <Grid Grid.Column="0" Margin="0,0,6,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Global Toolbar -->
            <Border Grid.Row="0" Padding="12" CornerRadius="8" Margin="0,0,0,10"
                    Background="{DynamicResource Surface.Bg.Panel}"
                    BorderBrush="{DynamicResource Surface.Border.Default}" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <core:SecuredButton Content="Load Config" Theme="Info" RequiredLevel="SuperAdmin" OperationName="Load Maintenance Config" Margin="0,0,8,0" />
                    <core:SecuredButton Content="Save Config" Theme="Primary" RequiredLevel="SuperAdmin" OperationName="Save Maintenance Config" Margin="0,0,8,0" />
                    <core:SecuredButton Content="Open Config Folder" Theme="Warning" RequiredLevel="SuperAdmin" OperationName="Open Config Folder" />
                </StackPanel>
            </Border>

            <!-- PLC Address Settings -->
            <GroupBox Grid.Row="1" Header="PLC Address Settings" Margin="0,0,0,10">
                <Grid Margin="8" MinHeight="220">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="PLC IP" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0" />
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding PlcIpAddress}" Margin="0,0,0,8" />

                    <TextBlock Text="PLC Port" VerticalAlignment="Center" Grid.Row="1" Grid.Column="0" />
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding PlcPort}" Margin="0,0,0,8" />

                    <TextBlock Text="Scan Interval" VerticalAlignment="Center" Grid.Row="2" Grid.Column="0" />
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ScanIntervalMs}" Margin="0,0,0,8" />

                    <TextBlock Text="Monitor Map" VerticalAlignment="Center" Grid.Row="3" Grid.Column="0" />
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding MonitorMap}" Margin="0,0,0,8" />

                    <TextBlock Text="Config Root" VerticalAlignment="Center" Grid.Row="4" Grid.Column="0" />
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding ConfigRootPath}" Margin="0,0,0,8" />

                    <TextBlock Text="Monitored Count" VerticalAlignment="Center" Grid.Row="5" Grid.Column="0" />
                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding RegisteredMonitorCount}" IsReadOnly="True" Margin="0,0,0,8" />

                    <TextBlock Text="Monitored Device" VerticalAlignment="Top" Grid.Row="6" Grid.Column="0" />
                    <Border Grid.Row="6" Grid.Column="1"
                            BorderBrush="{DynamicResource Surface.Border.Default}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Background="{DynamicResource Surface.Bg.Panel}">
                        <ListBox ItemsSource="{Binding RegisteredMonitorDeviceItems}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontFamily="Consolas"
                                 FontSize="11"
                                 Padding="4"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 VerticalAlignment="Stretch" />
                    </Border>
                </Grid>
            </GroupBox>

            <!-- PLC Device Editor (Global) -->
            <GroupBox Grid.Row="2" Header="PLC Device Editor (Word / DWord)">
                <core:PlcDeviceEditor Margin="8,0,8,0"
                                      Height="238"
                                      MinHeight="0"
                                      Label="Maintenance Device Editor"
                                      Address="D200"
                                      Value="0"
                                      Reason="Maintenance mode manual operation"
                                      RequiredLevel="SuperAdmin"
                                      EnableAuditTrail="True" />
            </GroupBox>
        </Grid>

        <!-- ========================================== -->
        <!-- RIGHT: Per-Machine Settings                -->
        <!-- ========================================== -->
        <Grid Grid.Column="1" Margin="6,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- == Machine Selector == -->
            <Border Grid.Row="0" Margin="0,0,0,10"
                    CornerRadius="10"
                    Background="#1C1C2E"
                    BorderThickness="1"
                    BorderBrush="#00E5FF">
                <Border.Effect>
                    <DropShadowEffect Color="#00E5FF" BlurRadius="12" ShadowDepth="0" Opacity="0.25"/>
                </Border.Effect>

                <Grid>
                    <!-- Accent top bar -->
                    <Border CornerRadius="10,10,0,0" Height="4" VerticalAlignment="Top">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00E5FF" Offset="0"/>
                                <GradientStop Color="#0088D4" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Content -->
                    <Grid Margin="14,12,14,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon -->
                        <Border Grid.Column="0"
                                Width="36" Height="36"
                                CornerRadius="8"
                                Background="#1A3A50">
                            <TextBlock Text="&#x2699;" FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#00E5FF"/>
                        </Border>

                        <!-- Label -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="DEVICE SETTINGS"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="#5A8AB0"
                                       Margin="0,0,0,2"/>
                            <TextBlock Text="Target Machine"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#FFFFFF"/>
                        </StackPanel>

                        <!-- ComboBox -->
                        <Border Grid.Column="3"
                                Margin="16,0,0,0"
                                VerticalAlignment="Center"
                                Background="#0D1A26"
                                BorderBrush="#00E5FF"
                                BorderThickness="1"
                                CornerRadius="6">
                            <ComboBox ItemsSource="{Binding MachineOptions}"
                                      SelectedValue="{Binding SelectedMachineId}"
                                      SelectedValuePath="MachineId"
                                      DisplayMemberPath="DisplayName"
                                      Height="34"
                                      Padding="10,0"
                                      FontSize="13" FontWeight="SemiBold"
                                      Foreground="#00E5FF"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      VerticalContentAlignment="Center"/>
                        </Border>

                        <!-- Machine count badge -->
                        <Border Grid.Column="4"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Background="#1A3A50"
                                BorderBrush="#00E5FF"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="8,4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding MachineOptions.Count}"
                                           FontSize="12" FontWeight="Bold"
                                           Foreground="#00E5FF"/>
                                <TextBlock Text=" Devices"
                                           FontSize="11"
                                           Foreground="#5A8AB0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Machine Resources (Per-Machine) -->
            <GroupBox Grid.Row="1" Header="Machine Resources" Margin="0,0,0,10">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Machine Config" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0" />
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding MachineConfigPath}" Margin="0,0,0,8" IsReadOnly="True" />

                    <TextBlock Text="Alarm Config" VerticalAlignment="Center" Grid.Row="1" Grid.Column="0" />
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding AlarmConfigPath}" Margin="0,0,0,8" IsReadOnly="True" />

                    <TextBlock Text="Sensor Config" VerticalAlignment="Center" Grid.Row="2" Grid.Column="0" />
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SensorConfigPath}" Margin="0,0,0,8" IsReadOnly="True" />

                    <TextBlock Text="Head Profile" VerticalAlignment="Center" Grid.Row="3" Grid.Column="0" />
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding HeadProfilePath}" Margin="0,0,0,8" IsReadOnly="True" />

                    <TextBlock Text="Wave Path" VerticalAlignment="Center" Grid.Row="4" Grid.Column="0" />
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding WavePath}" Margin="0,0,0,8" IsReadOnly="True" />

                    <TextBlock Text="PLC IP" VerticalAlignment="Center" Grid.Row="5" Grid.Column="0" />
                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding MachineIpAddress, Mode=OneWay}" IsReadOnly="True" />
                </Grid>
            </GroupBox>

            <!-- PrintHead Controller (Per-Machine) -->
            <GroupBox Grid.Row="2" Header="PrintHead Control">
                <core:PrintHeadController Margin="8,0,8,0" MinHeight="200"
                                          MachineId="{Binding SelectedMachineId}" />
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
