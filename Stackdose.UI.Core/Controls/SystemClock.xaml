<UserControl x:Class="Stackdose.UI.Core.Controls.SystemClock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              mc:Ignorable="d"
              d:DesignWidth="240"
              d:DesignHeight="72">

    <UserControl.Resources>
        <!-- 獨立的卡片樣式，不依賴 UI.Templates -->
        <Style x:Key="SystemClock.Card" TargetType="Border">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="BorderBrush" Value="#33334C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource SystemClock.Card}">
        <StackPanel>
            <TextBlock x:Name="TimeText"
                       Text="00:00:00"
                       FontSize="{Binding TimeFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontWeight="Bold"
                       HorizontalAlignment="Right"
                       FontFamily="Consolas"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock x:Name="DateText"
                       Text="2000-01-01"
                       FontSize="{Binding DateFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       HorizontalAlignment="Right"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>
    </Border>
</UserControl>
