<UserControl x:Class="Stackdose.App.DesignPlayer.Pages.MonitorPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="http://schemas.stackdose.com/wpf"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1400" d:DesignHeight="800">

    <Grid Background="{DynamicResource Surface.Bg.Page}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- PLC 連線列 -->
            <RowDefinition Height="Auto"/>   <!-- 頁籤列（多頁時顯示） -->
            <RowDefinition Height="*"/>      <!-- 設計器畫布 -->
        </Grid.RowDefinitions>

        <!-- ── PLC 連線狀態列 ── -->
        <Border Grid.Row="0"
                Background="{DynamicResource Surface.Bg.Panel}"
                BorderBrush="{DynamicResource Surface.Border.Default}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <DockPanel>
                <!-- PlcStatus：在 code-behind 依 config 建立後插入此處 -->
                <Border x:Name="PlcStatusHost"
                        DockPanel.Dock="Left"
                        VerticalAlignment="Center"
                        Margin="0,0,16,0"/>

                <TextBlock x:Name="lblDesignFile"
                           DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Surface.Text.Tertiary}"
                           FontSize="11"
                           HorizontalAlignment="Right"/>

                <TextBlock x:Name="lblCanvasInfo"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Surface.Text.Secondary}"
                           FontSize="12"/>
            </DockPanel>
        </Border>

        <!-- ── 頁籤列（多頁文件才顯示） ── -->
        <Border Grid.Row="1"
                x:Name="PageTabsBar"
                Background="{DynamicResource Surface.Bg.Panel}"
                BorderBrush="{DynamicResource Surface.Border.Default}"
                BorderThickness="0,0,0,1"
                Padding="8,4"
                Visibility="Collapsed">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          HorizontalAlignment="Left">
                <StackPanel x:Name="PageTabs" Orientation="Horizontal" VerticalAlignment="Center"/>
            </ScrollViewer>
        </Border>

        <!-- ── 設計器畫布（可縮放 + 捲動） ── -->
        <ScrollViewer Grid.Row="2"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource Surface.Bg.Page}"
                      Padding="24">
            <Grid HorizontalAlignment="Left" VerticalAlignment="Top">
                <Grid.LayoutTransform>
                    <ScaleTransform x:Name="CanvasScale" ScaleX="1" ScaleY="1"/>
                </Grid.LayoutTransform>

                <Canvas x:Name="MonitorCanvas"
                        ClipToBounds="True"
                        SnapsToDevicePixels="True"/>

                <!-- 純視覺外框 -->
                <Border x:Name="CanvasBorder"
                        BorderBrush="{DynamicResource Surface.Border.Default}"
                        BorderThickness="1"
                        IsHitTestVisible="False"/>
            </Grid>
        </ScrollViewer>

        <!-- 空畫面提示（還沒載入設計稿時顯示） -->
        <StackPanel x:Name="EmptyHint"
                    Grid.Row="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Opacity="0.4">
            <TextBlock Text="📄" FontSize="48" HorizontalAlignment="Center"/>
            <TextBlock Text="尚未載入設計稿"
                       Foreground="{DynamicResource Surface.Text.Secondary}"
                       FontSize="16" Margin="0,8,0,4"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="EmptyHintSub"
                       Text="請確認 Config/monitor.machinedesign.json 存在"
                       Foreground="{DynamicResource Surface.Text.Tertiary}"
                       FontSize="12"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
