<Window x:Class="Stackdose.UI.Core.Examples.ThemeSystemDemo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Theme System Demo - Batch B" 
        Height="600" Width="800"
        Background="{DynamicResource Surface.Bg.Page}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="Theme System Demo - Batch B Verification"
                   FontSize="24" 
                   FontWeight="Bold"
                   Foreground="{DynamicResource Text.Primary}"
                   Margin="0,0,0,20"/>

        <!-- Control Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="Switch to Dark Theme" 
                    Click="SwitchToDarkTheme_Click"
                    Background="{DynamicResource Action.Primary.Bg}"
                    Foreground="{DynamicResource Action.Primary.Fg}"
                    Padding="15,8"
                    Margin="0,0,10,0"/>
            
            <Button Content="Switch to Light Theme" 
                    Click="SwitchToLightTheme_Click"
                    Background="{DynamicResource Action.Info.Bg}"
                    Foreground="{DynamicResource Action.Info.Fg}"
                    Padding="15,8"
                    Margin="0,0,10,0"/>
            
            <Button Content="Verify Backward Compatibility" 
                    Click="VerifyBackwardCompatibility_Click"
                    Background="{DynamicResource Action.Success.Bg}"
                    Foreground="{DynamicResource Action.Success.Fg}"
                    Padding="15,8"/>
        </StackPanel>

        <!-- Demo Content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- New Semantic Tokens Demo -->
                <Border Background="{DynamicResource Surface.Bg.Panel}" 
                        BorderBrush="{DynamicResource Surface.Border.Default}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="15"
                        Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="? NEW: Semantic Tokens" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource Text.Primary}"
                                   Margin="0,0,0,10"/>
                        
                        <TextBlock Foreground="{DynamicResource Text.Primary}" Margin="0,5">
                            <Run Text="Surface.Bg.Panel" FontWeight="Bold"/>
                            <Run Text=" - Panel background"/>
                        </TextBlock>
                        
                        <TextBlock Foreground="{DynamicResource Text.Secondary}" Margin="0,5">
                            <Run Text="Text.Secondary" FontWeight="Bold"/>
                            <Run Text=" - Secondary text color"/>
                        </TextBlock>
                        
                        <TextBlock Foreground="{DynamicResource Text.Tertiary}" Margin="0,5">
                            <Run Text="Text.Tertiary" FontWeight="Bold"/>
                            <Run Text=" - Tertiary text color"/>
                        </TextBlock>
                        
                        <Border Background="{DynamicResource Action.Success.Bg}"
                                Padding="8"
                                CornerRadius="4"
                                Margin="0,10,0,0">
                            <TextBlock Text="Action.Success.Bg - Success button background"
                                       Foreground="{DynamicResource Action.Success.Fg}"
                                       FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Old Keys Demo (Backward Compatibility) -->
                <Border Background="{DynamicResource Cyber.Bg.Panel}" 
                        BorderBrush="{DynamicResource Cyber.Border}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="15"
                        Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="? OLD: Backward Compatible Keys" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource Cyber.Text.Main}"
                                   Margin="0,0,0,10"/>
                        
                        <TextBlock Foreground="{DynamicResource Cyber.Text.Main}" Margin="0,5">
                            <Run Text="Cyber.Bg.Panel" FontWeight="Bold"/>
                            <Run Text=" - Still works!"/>
                        </TextBlock>
                        
                        <TextBlock Foreground="{DynamicResource Plc.Text.Value}" Margin="0,5">
                            <Run Text="Plc.Text.Value" FontWeight="Bold"/>
                            <Run Text=" - Still works!"/>
                        </TextBlock>
                        
                        <Border Background="{DynamicResource Button.Bg.Success}"
                                Padding="8"
                                CornerRadius="4"
                                Margin="0,10,0,0">
                            <TextBlock Text="Button.Bg.Success - Still works!"
                                       Foreground="{DynamicResource Button.Text}"
                                       FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Status Colors Demo -->
                <Border Background="{DynamicResource Surface.Bg.Card}" 
                        BorderBrush="{DynamicResource Surface.Border.Strong}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="15">
                    <StackPanel>
                        <TextBlock Text="Status Colors" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource Text.Primary}"
                                   Margin="0,0,0,10"/>
                        
                        <StackPanel Orientation="Horizontal">
                            <Border Width="100" Height="40" Background="{DynamicResource Status.Success}" Margin="5">
                                <TextBlock Text="Success" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"
                                           Foreground="White"
                                           FontWeight="Bold"/>
                            </Border>
                            
                            <Border Width="100" Height="40" Background="{DynamicResource Status.Warning}" Margin="5">
                                <TextBlock Text="Warning" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"
                                           Foreground="White"
                                           FontWeight="Bold"/>
                            </Border>
                            
                            <Border Width="100" Height="40" Background="{DynamicResource Status.Error}" Margin="5">
                                <TextBlock Text="Error" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"
                                           Foreground="White"
                                           FontWeight="Bold"/>
                            </Border>
                            
                            <Border Width="100" Height="40" Background="{DynamicResource Status.Info}" Margin="5">
                                <TextBlock Text="Info" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"
                                           Foreground="White"
                                           FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
