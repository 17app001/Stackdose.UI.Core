<UserControl x:Class="Stackdose.Tools.MachinePageDesigner.Views.ToolboxPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:Stackdose.Tools.MachinePageDesigner.Models"
             xmlns:local="clr-namespace:Stackdose.Tools.MachinePageDesigner.Views"
             Background="{StaticResource SurfaceBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tab Header -->
        <UniformGrid Grid.Row="0" Rows="1" Margin="6,8,6,0">
            <RadioButton x:Name="tabControls" Content="▪ 控制項" IsChecked="True"
                         Checked="OnTabChanged" Style="{StaticResource ToolboxTabRadio}"/>
            <RadioButton x:Name="tabTemplates" Content="📋 模板庫"
                         Checked="OnTabChanged" Style="{StaticResource ToolboxTabRadio}"/>
        </UniformGrid>

        <!-- Tab Content -->
        <Grid Grid.Row="1">
            <!-- Controls Tab -->
            <ScrollViewer x:Name="controlsPanel" VerticalScrollBarVisibility="Auto" Padding="8,0">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ToolboxItemDescriptor}">
                            <Border Style="{StaticResource ToolboxItem}"
                                    MouseMove="ToolboxItem_MouseMove"
                                    Tag="{Binding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,8,0"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource AccentBrush}"/>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Category}" FontSize="10"
                                                   Foreground="{StaticResource TextMutedBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Templates Tab -->
            <local:TemplateGalleryPanel x:Name="templatePanel" Visibility="Collapsed"/>
        </Grid>
    </Grid>
</UserControl>