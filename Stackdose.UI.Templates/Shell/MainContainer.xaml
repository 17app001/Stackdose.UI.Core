<UserControl x:Class="Stackdose.UI.Templates.Shell.MainContainer"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:controls="clr-namespace:Stackdose.UI.Templates.Controls"
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              x:Name="Root"
              mc:Ignorable="d"
               d:DesignHeight="900" d:DesignWidth="1600">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Stackdose.UI.Templates;component/Resources/CommonColors.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{DynamicResource Surface.Bg.Page}">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="35"/>
            <!-- Bottom Bar -->
        </Grid.RowDefinitions>
        <Border MouseLeftButtonDown="Header_DragMove">
            <!-- Header -->
            <controls:AppHeader x:Name="AppHeaderControl"
                            Grid.Row="0"
                            PageTitle="{Binding ElementName=Root, Path=PageTitle}"
                            DeviceName="{Binding ElementName=Root, Path=HeaderDeviceName}"
                            ShowMachineBadge="{Binding ElementName=Root, Path=IsShellMode}"
                            MachineDisplayName="{Binding ElementName=Root, Path=CurrentMachineDisplayName}"
                            MachineOptions="{Binding ElementName=Root, Path=MachineOptions}"
                            SelectedMachineId="{Binding ElementName=Root, Path=SelectedMachineId, Mode=TwoWay}"
                            MachineSelectionChanged="OnMachineSelectionChanged"
                            LogoutClicked="OnLogout"
                            MinimizeClicked="OnMinimize"
                            CloseClicked="OnClose"/>
        </Border>
        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <!-- Left Navigation - Wider -->
                <ColumnDefinition Width="*"/>
                <!-- Dynamic Content Area -->
            </Grid.ColumnDefinitions>

            <!-- Left Navigation -->
            <controls:LeftNavigation x:Name="LeftNavigationControl"
                                     Grid.Column="0"
                                     IsMultiMachineMode="{Binding ElementName=Root, Path=IsShellMode}"
                                     NavigationRequested="OnNavigate"/>

            <!-- Dynamic Content Area -->
                <Border Grid.Column="1"
                    Background="{DynamicResource Surface.Bg.Panel}"
                    BorderBrush="{DynamicResource Surface.Border.Default}"
                    BorderThickness="1,0,0,0">
                <ContentControl x:Name="ContentArea"
                               Margin="{StaticResource Template.PagePadding}"
                               Content="{Binding ElementName=Root, Path=ShellContent}"/>
            </Border>
        </Grid>

        <!-- Bottom Bar -->
        <controls:AppBottomBar Grid.Row="2"/>
    </Grid>
</UserControl>
