{
  "machine": {
    "id": "M1",
    "name": "PLC Monitor",
    "enable": true
  },
  "alarmConfigFile": "Config/Machine1.alarms.json",
  "sensorConfigFile": "Config/Machine1.sensors.json",
  "plc": {
    "ip": "192.168.22.39",
    "port": 3000,
    "pollIntervalMs": 500,
    "autoConnect": true,
    "monitorAddresses": ["D103", "D104", "D105", "D106"]
  },
  "tags": {
    "status": {
      "isRunning": { "address": "M201", "type": "bool", "access": "read" },
      "isAlarm":   { "address": "M202", "type": "bool", "access": "read" }
    },
    "process": {
      "壓差":     { "address": "D103", "type": "int16", "access": "read" },
      "流量":     { "address": "D104", "type": "int16", "access": "read" },
      "供量壓力": { "address": "D105", "type": "int16", "access": "read" },
      "回量壓力": { "address": "D106", "type": "int16", "access": "read" }
    }
  }
}
