<UserControl x:Class="Stackdose.App.SingleDetailLab.Pages.SingleDetailWorkspacePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:core="http://schemas.stackdose.com/wpf"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1400">

    <Grid Background="{DynamicResource Surface.Bg.Page}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource Surface.Bg.Panel}"
                BorderBrush="{DynamicResource Surface.Border.Default}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Detail + PLC Lab"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock x:Name="MachineSummaryText"
                           Margin="0,4,0,8"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <core:PlcStatus x:Name="TopPlcStatus"
                                Height="58"
                                IsGlobal="True"
                                ShowBorder="True"
                                AutoConnect="True"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="{DynamicResource Surface.Bg.Panel}"
                BorderBrush="{DynamicResource Surface.Border.Default}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <Grid x:Name="DesignerHost">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Design this area directly in Visual Studio (XAML Designer). Drag PlcLabel/PlcDeviceEditor/UI.Core controls here."
                           Margin="0,0,0,12"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="90" />
                        <RowDefinition Height="90" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <core:PlcLabel x:Name="DefaultBatchLabel"
                                   Grid.Row="0"
                                   Grid.Column="0"
                                   Label="Batch"
                                   ShowFrame="True"
                                   Margin="0,0,12,12"/>

                    <core:PlcLabel x:Name="DefaultRecipeLabel"
                                   Grid.Row="0"
                                   Grid.Column="1"
                                   Label="Recipe"
                                   ShowFrame="True"
                                   Margin="0,0,12,12"/>

                    <core:PlcDeviceEditor x:Name="DefaultEditor"
                                          Grid.Row="1"
                                          Grid.Column="0"
                                          Grid.ColumnSpan="1"
                                          Label="Command Editor"
                                          Reason="Single page lab test"
                                          Margin="0,0,12,12"/>
                </Grid>

                <TextBlock Grid.Row="2"
                           Text="Tip: remove/replace sample controls in XAML and layout freely in designer."
                           Margin="0,12,0,0"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
