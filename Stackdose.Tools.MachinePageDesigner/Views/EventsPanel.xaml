<UserControl x:Class="Stackdose.Tools.MachinePageDesigner.Views.EventsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Stackdose.Tools.MachinePageDesigner.ViewModels"
             Background="{StaticResource SurfaceBrush}">

    <UserControl.Resources>
        <!-- 動作詳細欄位：依 ActionType 顯示不同欄位組合 -->
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="120"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto" MinHeight="200"/>
        </Grid.RowDefinitions>

        <!-- ── 上半部：事件列表 ── -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 事件列表工具列 -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="行為事件" Style="{StaticResource SectionHeader}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button x:Name="btnAddEvent" Content="＋ 新增" Click="OnAddEvent"
                        Style="{StaticResource ToolbarButton}" Padding="6,2" FontSize="11"/>
                <Button x:Name="btnRemoveEvent" Content="－ 刪除" Click="OnRemoveEvent"
                        Style="{StaticResource ToolbarButton}" Padding="6,2" FontSize="11"
                        Margin="4,0,0,0"/>
            </StackPanel>

            <!-- 事件清單 -->
            <ListBox Grid.Row="1" x:Name="eventsListBox"
                     SelectionChanged="OnEventSelected"
                     Background="{StaticResource PanelBrush}"
                     BorderBrush="{StaticResource BorderBrush}"
                     BorderThickness="1"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:BehaviorEventViewModel}">
                        <TextBlock Text="{Binding Summary}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Padding="4,2" TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding Summary}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch"
                      Background="{StaticResource BorderBrush}"/>

        <!-- ── 下半部：事件詳細設定 ── -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,4,0,0">
            <StackPanel x:Name="eventDetail">

                <!-- 空狀態 -->
                <TextBlock x:Name="noSelectionHint"
                           Text="請點選上方事件以編輯"
                           Foreground="{StaticResource TextMutedBrush}"
                           Margin="0,16" HorizontalAlignment="Center"/>

                <!-- 事件詳細（有選取時顯示） -->
                <StackPanel x:Name="detailForm" Visibility="Collapsed">

                    <!-- 觸發來源 -->
                    <TextBlock Text="觸發來源 (on)" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                    <ComboBox x:Name="cboOn"
                              ItemsSource="{x:Static vm:BehaviorEventViewModel.OnTypes}"
                              SelectionChanged="OnEventOnChanged"
                              Margin="0,0,0,8"/>

                    <!-- 條件（when） -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <CheckBox x:Name="chkHasCondition"
                                  Content="觸發條件 (when)"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Checked="OnHasConditionChanged"
                                  Unchecked="OnHasConditionChanged"/>
                    </StackPanel>

                    <Grid x:Name="whenForm" Visibility="Collapsed" Margin="8,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="cboWhenOp"
                                  Grid.Column="0"
                                  ItemsSource="{x:Static vm:BehaviorEventViewModel.WhenOps}"
                                  SelectionChanged="OnWhenOpChanged"/>
                        <TextBox x:Name="txtWhenValue"
                                 Grid.Column="2"
                                 LostFocus="OnWhenValueChanged"
                                 PreviewKeyDown="OnNumericKeyDown"/>
                    </Grid>

                    <!-- 動作列表 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="動作 (do)" Style="{StaticResource SectionHeader}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Button x:Name="btnAddAction" Content="＋" Click="OnAddAction"
                                Style="{StaticResource ToolbarButton}" Padding="6,2" FontSize="11"/>
                        <Button x:Name="btnRemoveAction" Content="－" Click="OnRemoveAction"
                                Style="{StaticResource ToolbarButton}" Padding="6,2" FontSize="11"
                                Margin="4,0,0,0"/>
                    </StackPanel>

                    <ListBox x:Name="actionsListBox"
                             MinHeight="60" MaxHeight="100"
                             SelectionChanged="OnActionSelected"
                             Background="{StaticResource PanelBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"
                             Margin="0,0,0,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:BehaviorActionViewModel}">
                                <TextBlock Text="{Binding Summary}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Padding="4,2" TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Summary}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 動作詳細設定 -->
                    <StackPanel x:Name="actionDetail" Visibility="Collapsed">
                        <Separator Margin="0,0,0,8"/>

                        <TextBlock Text="動作類型 (action)" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                        <ComboBox x:Name="cboActionType"
                                  ItemsSource="{x:Static vm:BehaviorActionViewModel.ActionTypes}"
                                  SelectionChanged="OnActionTypeChanged"
                                  Margin="0,0,0,8"/>

                        <!-- Target（SetProp / WritePlc） -->
                        <StackPanel x:Name="targetField" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource FieldLabel}" Margin="0,0,0,2">
                                <Run Text="目標 (target)"/>
                                <Run Text=' — "self" 或控制項 id' Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                            </TextBlock>
                            <TextBox x:Name="txtTarget" LostFocus="OnActionFieldChanged"
                                     PreviewKeyDown="OnEnterCommit" Margin="0,0,0,8"/>
                        </StackPanel>

                        <!-- Prop（SetProp） -->
                        <StackPanel x:Name="propField" Visibility="Collapsed">
                            <TextBlock Text="屬性 (prop)" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                            <TextBox x:Name="txtProp" LostFocus="OnActionFieldChanged"
                                     PreviewKeyDown="OnEnterCommit" Margin="0,0,0,8"/>
                        </StackPanel>

                        <!-- Value（SetProp / WritePlc / SetStatus） -->
                        <StackPanel x:Name="valueField" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource FieldLabel}" Margin="0,0,0,2">
                                <Run Text="值 (value)"/>
                                <Run Text=" — 支援 {value}" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                            </TextBlock>
                            <TextBox x:Name="txtValue" LostFocus="OnActionFieldChanged"
                                     PreviewKeyDown="OnEnterCommit" Margin="0,0,0,8"/>
                        </StackPanel>

                        <!-- Message（LogAudit / ShowDialog） -->
                        <StackPanel x:Name="messageField" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource FieldLabel}" Margin="0,0,0,2">
                                <Run Text="訊息 (message)"/>
                                <Run Text=" — 支援 {value}" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                            </TextBlock>
                            <TextBox x:Name="txtMessage" LostFocus="OnActionFieldChanged"
                                     PreviewKeyDown="OnEnterCommit" Margin="0,0,0,8"/>
                        </StackPanel>

                        <!-- Title（ShowDialog） -->
                        <StackPanel x:Name="titleField" Visibility="Collapsed">
                            <TextBlock Text="標題 (title)" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                            <TextBox x:Name="txtTitle" LostFocus="OnActionFieldChanged"
                                     PreviewKeyDown="OnEnterCommit" Margin="0,0,0,8"/>
                        </StackPanel>

                        <!-- Page（Navigate） -->
                        <StackPanel x:Name="pageField" Visibility="Collapsed">
                            <TextBlock Text="頁面 (page)" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                            <TextBox x:Name="txtPage" LostFocus="OnActionFieldChanged"
                                     PreviewKeyDown="OnEnterCommit" Margin="0,0,0,8"/>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
