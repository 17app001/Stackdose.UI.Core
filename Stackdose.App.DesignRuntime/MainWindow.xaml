<Window x:Class="Stackdose.App.DesignRuntime.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:plc="clr-namespace:Stackdose.UI.Core.Controls;assembly=Stackdose.UI.Core"
        Title="DesignRuntime — MachineDesign 執行環境"
        Width="1400" Height="860"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E"
        AllowDrop="True"
        Drop="OnWindowDrop"
        DragOver="OnWindowDragOver">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Row 0：PLC 連線設定 ── -->
        <Border x:Name="plcConfigBorder"
                Grid.Row="0"
                Background="#1E2040"
                BorderBrush="#3A3A6A"
                BorderThickness="0,0,0,1"
                Padding="10,6">
            <WrapPanel VerticalAlignment="Center">

                <TextBlock Text="PLC IP：" Foreground="#9090B0" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="12"/>
                <TextBox x:Name="txtIp" Text="192.168.1.100" Width="130" Margin="0,0,6,0"
                         Background="#2A2A48" Foreground="White" BorderBrush="#4A4A6A"
                         Padding="4,3" VerticalAlignment="Center"/>

                <TextBlock Text="Port：" Foreground="#9090B0" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="12"/>
                <TextBox x:Name="txtPort" Text="3000" Width="60" Margin="0,0,6,0"
                         Background="#2A2A48" Foreground="White" BorderBrush="#4A4A6A"
                         Padding="4,3" VerticalAlignment="Center"/>

                <TextBlock Text="Scan (ms)：" Foreground="#9090B0" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="12"/>
                <TextBox x:Name="txtScan" Text="200" Width="50" Margin="0,0,10,0"
                         Background="#2A2A48" Foreground="White" BorderBrush="#4A4A6A"
                         Padding="4,3" VerticalAlignment="Center"/>

                <Button x:Name="btnConnect" Content="&#x1F50C; 連線"
                        Click="OnConnectClick"
                        Padding="12,5" Margin="0,0,12,0"
                        Background="#4CAF50" Foreground="White"
                        BorderThickness="0" Cursor="Hand" FontWeight="SemiBold">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#4CAF50"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}"
                                                CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Background" Value="#2D6E30"/>
                                                <Setter Property="Foreground" Value="#88AA88"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#43A047"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="btnDisconnect" Content="&#x26D4; 斷線"
                        Click="OnDisconnectClick"
                        Padding="12,5" Margin="0,0,16,0"
                        BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"
                        IsEnabled="False">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#EF5350"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}"
                                                CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Background" Value="#7B2B2A"/>
                                                <Setter Property="Foreground" Value="#AA7070"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E53935"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Separator Width="1" Background="#3A3A6A" Margin="0,2,16,2" Style="{x:Null}"/>

                <!-- PlcStatus 控制項：放在此處，Loaded 後自動連線 -->
                <Border x:Name="plcStatusHost" VerticalAlignment="Center" Margin="0,0,16,0"/>

                <Separator Width="1" Background="#3A3A6A" Margin="0,2,16,2" Style="{x:Null}"/>

                <CheckBox x:Name="chkSimMode"
                          Content="🤖 模擬器模式"
                          Foreground="#FFB74D"
                          VerticalAlignment="Center"
                          FontSize="12"
                          Margin="0,0,0,0"
                          Checked="OnSimModeChanged"
                          Unchecked="OnSimModeChanged"
                          ToolTip="啟用後，下次連線將使用內建模擬器（不需真實 PLC）"/>

            </WrapPanel>
        </Border>

        <!-- ── Row 1：檔案 + 縮放工具列 ── -->
        <Border x:Name="toolbarBorder"
                Grid.Row="1"
                Background="#252540"
                BorderBrush="#3A3A5A"
                BorderThickness="0,0,0,1"
                Padding="10,6">
            <WrapPanel VerticalAlignment="Center">

                <Button x:Name="btnOpen" Content="&#x1F4C2; 開啟 JSON"
                        Click="OnOpenClick"
                        Padding="12,5" Margin="0,0,8,0"
                        Background="#4A6EBF" Foreground="White"
                        BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>

                <TextBlock x:Name="lblFilePath"
                           Text="尚未載入   拖曳 .machinedesign.json 至視窗"
                           Foreground="#9090B0" VerticalAlignment="Center"
                           Margin="0,0,24,0" FontSize="12"/>

                <Separator Width="1" Background="#3A3A5A" Margin="0,2,16,2" Style="{x:Null}"/>

                <TextBlock Text="縮放：" Foreground="#9090B0" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
                <Slider x:Name="sliderZoom"
                        Minimum="0.25" Maximum="2.0" Value="1.0"
                        Width="160" VerticalAlignment="Center"
                        ValueChanged="OnZoomChanged"
                        SmallChange="0.05" LargeChange="0.25"
                        Margin="0,0,8,0"/>
                <TextBlock x:Name="lblZoom" Text="100%"
                           Foreground="#C0C0D8" VerticalAlignment="Center"
                           Width="40" FontSize="12"/>

                <Separator Width="1" Background="#3A3A5A" Margin="0,2,16,2" Style="{x:Null}"/>

                <TextBlock x:Name="lblCanvasInfo" Text="畫布：—"
                           Foreground="#9090B0" VerticalAlignment="Center" FontSize="12"/>

                <Separator Width="1" Background="#3A3A5A" Margin="16,2,16,2" Style="{x:Null}"/>

                <Button x:Name="btnRandomSim"
                        Content="🎲 亂數 D100~D102"
                        Click="OnRandomSimClick"
                        Padding="12,5"
                        Background="#5C6BC0" Foreground="White"
                        BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"
                        ToolTip="每 100~300ms 隨機寫入 0~32767 至 D100、D101、D102（需先連線）"/>

                <Separator Width="1" Background="#3A3A5A" Margin="16,2,8,2" Style="{x:Null}"/>

                <ToggleButton x:Name="btnThemeToggle"
                              Content="☀ Light"
                              Click="OnThemeToggleClick"
                              Padding="10,5"
                              Background="#3A3A5A" Foreground="#C0C0D8"
                              BorderThickness="1" BorderBrush="#5A5A7A"
                              Cursor="Hand" FontSize="11"
                              ToolTip="切換 Dark / Light 主題"/>

            </WrapPanel>
        </Border>

        <!-- ── Row 2：執行畫布（FreeCanvas 裸畫布 / Shell 外殼切換） ── -->
        <Grid Grid.Row="2">

            <!-- FreeCanvas 模式：原始 ScrollViewer + Canvas（預設可見） -->
            <ScrollViewer x:Name="scrollViewerCanvas"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="#12121E"
                          Padding="40">
                <Grid x:Name="canvasHost" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Grid.LayoutTransform>
                        <ScaleTransform x:Name="canvasScale"/>
                    </Grid.LayoutTransform>

                    <!-- 主畫布：ClipToBounds 確保元件不超出邊界 -->
                    <Canvas x:Name="runtimeCanvas"
                            Background="#1E1E32"
                            ClipToBounds="True"
                            SnapsToDevicePixels="True"/>

                    <!-- 邊框（純視覺）-->
                    <Border x:Name="canvasBorder"
                            BorderBrush="#3A3A6A"
                            BorderThickness="1"
                            IsHitTestVisible="False"/>
                </Grid>
            </ScrollViewer>

            <!-- Shell 預覽模式（SinglePage / Standard）：預設隱藏 -->
            <ContentControl x:Name="shellPreviewHost" Visibility="Collapsed"/>

        </Grid>

        <!-- ── Row 3：狀態列 ── -->
        <Border Grid.Row="3"
                Background="#252540"
                BorderBrush="#3A3A5A"
                BorderThickness="0,1,0,0"
                Padding="10,4">
            <DockPanel>
                <!-- Dashboard 模式：僅顯示此連線燈，其餘元件隱藏 -->
                <Border x:Name="dashboardPlcHost"
                        DockPanel.Dock="Left"
                        Visibility="Collapsed"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"/>
                <TextBlock x:Name="lblShellMode"
                           Text="Shell: FreeCanvas"
                           DockPanel.Dock="Right"
                           Foreground="#7070A0" FontSize="11"
                           Margin="0,0,16,0"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="lblItemCount" Text="" Foreground="#7070A0" FontSize="11" DockPanel.Dock="Right" Margin="0,0,16,0"/>
                <!-- ValueChanged 事件監視 -->
                <ToggleButton x:Name="btnWatchEvents"
                              Content="📡 偵測值變化"
                              DockPanel.Dock="Right"
                              Padding="8,2" Margin="0,0,8,0"
                              Background="#2A3A5A" Foreground="#7090C0"
                              BorderThickness="1" BorderBrush="#3A5A8A"
                              FontSize="11" Cursor="Hand"
                              Checked="OnWatchEventsToggled"
                              Unchecked="OnWatchEventsToggled"/>
                <TextBlock x:Name="lblEventLog"
                           Text=""
                           DockPanel.Dock="Right"
                           Foreground="#5DE2FF" FontSize="11"
                           FontFamily="Consolas"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"
                           Visibility="Collapsed"/>
                <TextBlock x:Name="lblStatus"
                           Text="就緒 — 請先設定 PLC 連線，再開啟 .machinedesign.json"
                           Foreground="#7070A0" FontSize="11"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
