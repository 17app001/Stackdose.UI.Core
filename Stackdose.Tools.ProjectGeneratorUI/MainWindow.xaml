                                        <TextBlock Text="ж’ҢиЎҢ?йҡһжӯ№?йҠқеүңоһІ?о«ә??иҰ“iewer" FontSize="10" Margin="0,4,0,0"
                                                   Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                        <TextBlock Text="???еҲ»о Ҫ" FontSize="9" Margin="0,4,0,0" Foreground="#4FC3F7"/>
                                    </StackPanel>
                                </RadioButton>

                                <RadioButton Style="{StaticResource LayoutModeCard}" Margin="0,0,6,0"
                                             IsChecked="{Binding LayoutMode, Mode=TwoWay,
