<UserControl x:Class="Stackdose.UI.Core.Controls.PlcText"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="50" d:DesignWidth="280"
             x:Name="Root">

    <Border Background="{DynamicResource Plc.Bg.Main}"
            BorderBrush="{DynamicResource Plc.Border}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="10,8">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Label -->
            <TextBlock Grid.Column="0"
                       Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue='Parameter'}"
                       Foreground="{DynamicResource Plc.Text.Label}"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <!-- ── Word 模式：TextBox + 套用按鈕 ── -->
            <Grid Grid.Column="1">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Mode, ElementName=Root}" Value="Bit">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        BorderBrush="{DynamicResource Plc.Border}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Background="{DynamicResource Plc.Bg.Dark}"
                        VerticalAlignment="Center"
                        Margin="0,0,6,0">
                    <TextBox x:Name="ValueTextBox"
                             Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, FallbackValue='0'}"
                             FontSize="14"
                             FontWeight="Bold"
                             FontFamily="Consolas"
                             Foreground="{DynamicResource Plc.Text.Value}"
                             Background="Transparent"
                             CaretBrush="{DynamicResource Plc.Text.Value}"
                             BorderThickness="0"
                             Padding="6,4"
                             TextAlignment="Right"
                             MinWidth="60"
                             ToolTip="{Binding Address, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                </Border>

                <Button Grid.Column="1"
                        x:Name="ApplyButton"
                        Content="套用"
                        Click="ApplyButton_Click"
                        Foreground="{DynamicResource Button.Text}"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Padding="10,0"
                        Height="28"
                        VerticalAlignment="Center"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="寫入 PLC">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{DynamicResource Button.Bg.Primary}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- ── Bit 模式：ON / OFF 切換按鈕 ── -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Mode, ElementName=Root}" Value="Bit">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <!-- ON 按鈕 -->
                <Button x:Name="BitOnButton"
                        Content="ON"
                        Click="BitOn_Click"
                        FontSize="12"
                        FontWeight="Bold"
                        Width="52" Height="28"
                        Margin="0,0,6,0"
                        Cursor="Hand"
                        BorderThickness="0"
                        ToolTip="寫入 1（ON）">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    CornerRadius="4"
                                    Background="{DynamicResource Button.Bg.Success}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="1">
                                                <Setter Property="BorderBrush" Value="{DynamicResource Button.Bg.Success}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="0">
                                                <Setter Property="Opacity" Value="0.4"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Foreground>
                        <SolidColorBrush Color="White"/>
                    </Button.Foreground>
                </Button>

                <!-- OFF 按鈕 -->
                <Button x:Name="BitOffButton"
                        Content="OFF"
                        Click="BitOff_Click"
                        FontSize="12"
                        FontWeight="Bold"
                        Width="52" Height="28"
                        Cursor="Hand"
                        BorderThickness="0"
                        ToolTip="寫入 0（OFF）">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    CornerRadius="4"
                                    Background="{DynamicResource Button.Bg.Error}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="0">
                                                <Setter Property="BorderBrush" Value="{DynamicResource Button.Bg.Error}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="1">
                                                <Setter Property="Opacity" Value="0.4"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Foreground>
                        <SolidColorBrush Color="White"/>
                    </Button.Foreground>
                </Button>
            </StackPanel>

        </Grid>
    </Border>
</UserControl>
