<UserControl x:Class="Stackdose.Tools.MachinePageDesigner.Views.FreeCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Stackdose.Tools.MachinePageDesigner.Views"
             xmlns:vm="clr-namespace:Stackdose.Tools.MachinePageDesigner.ViewModels"
             Background="{DynamicResource Surface.Bg.Page}"
             AllowDrop="True"
             Focusable="True"
             Drop="OnDrop"
             DragOver="OnDragOver"
             PreviewKeyDown="OnPreviewKeyDown"
             PreviewMouseWheel="OnPreviewMouseWheel">

    <ScrollViewer x:Name="scrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Padding="24">

        <!-- 畫布邊框 -->
        <Border Width="{Binding CanvasWidth}"
                Height="{Binding CanvasHeight}"
                BorderBrush="{DynamicResource Surface.Border.Default}"
                BorderThickness="1"
                Background="{DynamicResource Surface.Bg.Panel}"
                SnapsToDevicePixels="True">

            <Border.LayoutTransform>
                <ScaleTransform ScaleX="{Binding ZoomLevel}" ScaleY="{Binding ZoomLevel}"/>
            </Border.LayoutTransform>

            <Grid>

            <!-- 格線 overlay（半透明暗色，Light/Dark 背景皆可見） -->
            <Rectangle IsHitTestVisible="False">
                <Rectangle.Fill>
                    <DrawingBrush TileMode="Tile"
                                  Viewport="0,0,20,20"
                                  ViewportUnits="Absolute"
                                  Stretch="None">
                        <DrawingBrush.Drawing>
                            <DrawingGroup>
                                <GeometryDrawing>
                                    <GeometryDrawing.Pen>
                                        <Pen Brush="#20000000" Thickness="0.5"/>
                                    </GeometryDrawing.Pen>
                                    <GeometryDrawing.Geometry>
                                        <PathGeometry>
                                            <PathFigure StartPoint="20,0" IsClosed="False">
                                                <LineSegment Point="20,20"/>
                                            </PathFigure>
                                            <PathFigure StartPoint="0,20" IsClosed="False">
                                                <LineSegment Point="20,20"/>
                                            </PathFigure>
                                        </PathGeometry>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingGroup>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- 設計畫布（Canvas.Left/Top 定位用） -->
            <Canvas x:Name="designCanvas"
                    Width="{Binding CanvasWidth}"
                    Height="{Binding CanvasHeight}"
                    Background="Transparent"
                    MouseLeftButtonDown="OnCanvasMouseDown"
                    MouseMove="OnCanvasMouseMove"
                    MouseLeftButtonUp="OnCanvasMouseUp"
                    ClipToBounds="True">

                <!-- 元件層 -->
                <ItemsControl ItemsSource="{Binding CanvasItems}"
                              Canvas.Left="0" Canvas.Top="0"
                              IsHitTestVisible="True">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas IsItemsHost="True" ClipToBounds="False"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}"/>
                            <Setter Property="Canvas.Top"  Value="{Binding Y}"/>
                            <Setter Property="Width"       Value="{Binding Width}"/>
                            <Setter Property="Height"      Value="{Binding Height}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:DesignerItemViewModel}">
                            <local:FreeCanvasItem
                                Tag="{Binding Tag, RelativeSource={RelativeSource AncestorType=local:FreeCanvas}}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 框選矩形 -->
                <Rectangle x:Name="selectionRect"
                           Stroke="#FF6C8EEF"
                           StrokeThickness="1"
                           Fill="#226C8EEF"
                           Visibility="Collapsed"
                           IsHitTestVisible="False"/>

            </Canvas>
            </Grid>
        </Border>

    </ScrollViewer>
</UserControl>
