<Application x:Class="Stackdose.Tools.MachinePageDesigner.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Stackdose.Tools.MachinePageDesigner.Views"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- UI.Core 語意 Token（Surface.*、Text.*、Accent.* 等） -->
                <ResourceDictionary Source="pack://application:,,,/Stackdose.UI.Core;component/Themes/Theme.xaml"/>
                <ResourceDictionary Source="Themes/DesignerTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <local:ThemeToBoolConverter x:Key="ThemeToBoolConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
