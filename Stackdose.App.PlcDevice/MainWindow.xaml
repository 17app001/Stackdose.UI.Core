        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Templates="http://schemas.stackdose.com/templates"
        Title="PLC Device Starter"
        Height="900"
        Width="1600"
        WindowState="Maximized"
        WindowStyle="None"
