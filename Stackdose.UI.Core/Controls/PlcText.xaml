<base:PlcControlBase x:Class="Stackdose.UI.Core.Controls.PlcText"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:base="clr-namespace:Stackdose.UI.Core.Controls.Base"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="280">

    <Border Background="{DynamicResource Plc.Bg.Main}"
            BorderBrush="{DynamicResource Plc.Border}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="10,8">
        
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Label -->
            <TextBlock Grid.Column="0"
                       Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue='Parameter'}"
                       Foreground="{DynamicResource Plc.Text.Label}"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <!-- Value TextBox wrapped in Border for rounded corners -->
            <Border Grid.Column="1"
                    BorderBrush="{DynamicResource Plc.Border}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Background="#FF1A2332"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0">
                <TextBox x:Name="ValueTextBox"
                         Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, FallbackValue='0'}"
                         FontSize="14"
                         FontWeight="Bold"
                         FontFamily="Consolas"
                         Foreground="#FF00E5FF"
                         Background="Transparent"
                         CaretBrush="#FF00E5FF"
                         BorderThickness="0"
                         Padding="6,4"
                         TextAlignment="Right"
                         MinWidth="60"
                         ToolTip="{Binding Address, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            </Border>

            <!-- Apply Button - Use OK text instead of checkmark symbol -->
            <Button Grid.Column="2"
                    x:Name="ApplyButton"
                    Content="OK"
                    Click="ApplyButton_Click"
                    Background="#FF00C853"
                    Foreground="White"
                    FontSize="12"
                    FontWeight="Bold"
                    Width="40"
                    Height="28"
                    VerticalAlignment="Center"
                    BorderThickness="0"
                    Cursor="Hand"
                    ToolTip="Apply changes">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF00E676"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF00A846"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</base:PlcControlBase>
