<UserControl x:Class="Stackdose.Tools.MachinePageDesigner.Views.PropertyPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Stackdose.Tools.MachinePageDesigner.Views"
             xmlns:vm="clr-namespace:Stackdose.Tools.MachinePageDesigner.ViewModels"
             Background="{StaticResource SurfaceBrush}">

    <UserControl.Resources>
        <!-- ════════════════════════════════════════════════════════
             PlcLabel 屬性面板
             ════════════════════════════════════════════════════════ -->
        <DataTemplate x:Key="PlcLabelTemplate" DataType="{x:Type vm:DesignerItemViewModel}">
            <StackPanel Margin="0,4">
                <!-- Label -->
                <TextBlock Text="標籤名稱" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <!-- Address -->
                <TextBlock Text="PLC 位址" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <!-- DefaultValue -->
                <TextBlock Text="預設值" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <TextBox Text="{Binding DefaultValue, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <!-- LabelFontSize -->
                <TextBlock Style="{StaticResource FieldLabel}" Margin="0,0,0,2">
                    <Run Text="標籤字體大小："/><Run Text="{Binding LabelFontSize, StringFormat=F0, Mode=OneWay}"/>
                </TextBlock>
                <Slider Value="{Binding LabelFontSize}" Minimum="8" Maximum="36" TickFrequency="1"
                        IsSnapToTickEnabled="True" Margin="0,0,0,8"/>

                <!-- LabelForeground -->
                <TextBlock Text="標籤色彩" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <ComboBox ItemsSource="{x:Static vm:DesignerItemViewModel.ColorThemes}"
                          SelectedItem="{Binding LabelForeground}" Margin="0,0,0,8"/>

                <!-- ValueFontSize -->
                <TextBlock Style="{StaticResource FieldLabel}" Margin="0,0,0,2">
                    <Run Text="數值字體大小："/><Run Text="{Binding ValueFontSize, StringFormat=F0, Mode=OneWay}"/>
                </TextBlock>
                <Slider Value="{Binding ValueFontSize}" Minimum="8" Maximum="72" TickFrequency="1"
                        IsSnapToTickEnabled="True" Margin="0,0,0,8"/>

                <!-- FrameShape -->
                <TextBlock Text="外框形狀" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <RadioButton Content="□ Rectangle" Margin="0,0,12,0"
                                 IsChecked="{Binding FrameShape, Converter={local:StringEqualityConverter}, ConverterParameter=Rectangle}"/>
                    <RadioButton Content="○ Circle"
                                 IsChecked="{Binding FrameShape, Converter={local:StringEqualityConverter}, ConverterParameter=Circle}"/>
                </StackPanel>

                <!-- ValueColorTheme -->
                <TextBlock Text="數值色彩" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <ComboBox ItemsSource="{x:Static vm:DesignerItemViewModel.ColorThemes}"
                          SelectedItem="{Binding ValueColorTheme}" Margin="0,0,0,8"/>

                <!-- FrameBackground -->
                <TextBlock Text="底框背景色" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <ComboBox ItemsSource="{x:Static vm:DesignerItemViewModel.ColorThemes}"
                          SelectedItem="{Binding FrameBackground}" Margin="0,0,0,8"/>

                <!-- LabelAlignment -->
                <TextBlock Text="標籤對齊" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <RadioButton Content="左" Margin="0,0,12,0"
                                 IsChecked="{Binding LabelAlignment, Converter={local:StringEqualityConverter}, ConverterParameter=Left}"/>
                    <RadioButton Content="中" Margin="0,0,12,0"
                                 IsChecked="{Binding LabelAlignment, Converter={local:StringEqualityConverter}, ConverterParameter=Center}"/>
                    <RadioButton Content="右"
                                 IsChecked="{Binding LabelAlignment, Converter={local:StringEqualityConverter}, ConverterParameter=Right}"/>
                </StackPanel>

                <!-- ValueAlignment -->
                <TextBlock Text="數值對齊" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <RadioButton Content="左" Margin="0,0,12,0"
                                 IsChecked="{Binding ValueAlignment, Converter={local:StringEqualityConverter}, ConverterParameter=Left}"/>
                    <RadioButton Content="中" Margin="0,0,12,0"
                                 IsChecked="{Binding ValueAlignment, Converter={local:StringEqualityConverter}, ConverterParameter=Center}"/>
                    <RadioButton Content="右"
                                 IsChecked="{Binding ValueAlignment, Converter={local:StringEqualityConverter}, ConverterParameter=Right}"/>
                </StackPanel>

                <!-- Divisor -->
                <TextBlock Text="除數 (Divisor)" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <TextBox Text="{Binding Divisor, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <!-- StringFormat -->
                <TextBlock Text="數值格式" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <ComboBox ItemsSource="{x:Static vm:DesignerItemViewModel.StringFormats}"
                          SelectedItem="{Binding StringFormat}" Margin="0,0,0,8"/>
            </StackPanel>
        </DataTemplate>

        <!-- ════════════════════════════════════════════════════════
             PlcText 屬性面板
             ════════════════════════════════════════════════════════ -->
        <DataTemplate x:Key="PlcTextTemplate" DataType="{x:Type vm:DesignerItemViewModel}">
            <StackPanel Margin="0,4">
                <TextBlock Text="標籤名稱" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Text="PLC 位址" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <!-- Mode -->
                <TextBlock Text="模式" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <RadioButton Content="Word（數值）" Margin="0,0,12,0"
                                 IsChecked="{Binding PlcTextMode, Converter={local:StringEqualityConverter}, ConverterParameter=Word}"/>
                    <RadioButton Content="Bit（ON/OFF）"
                                 IsChecked="{Binding PlcTextMode, Converter={local:StringEqualityConverter}, ConverterParameter=Bit}"/>
                </StackPanel>
                <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,8"
                           Text="Word：寫入整數值並按套用。Bit：直接點 ON / OFF 按鈕切換。"/>
            </StackPanel>
        </DataTemplate>

        <!-- ════════════════════════════════════════════════════════
             PlcStatusIndicator 屬性面板
             ════════════════════════════════════════════════════════ -->
        <DataTemplate x:Key="PlcStatusIndicatorTemplate" DataType="{x:Type vm:DesignerItemViewModel}">
            <StackPanel Margin="0,4">
                <TextBlock Text="顯示名稱" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Text="PLC 位址 (M/D)" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <TextBox Text="{Binding DisplayAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
            </StackPanel>
        </DataTemplate>

        <!-- ════════════════════════════════════════════════════════
             SecuredButton 屬性面板
             ════════════════════════════════════════════════════════ -->
        <DataTemplate x:Key="SecuredButtonTemplate" DataType="{x:Type vm:DesignerItemViewModel}">
            <StackPanel Margin="0,4">
                <TextBlock Text="按鈕名稱" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Text="命令位址" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <TextBox Text="{Binding CommandAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Text="寫入值" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <TextBox Text="{Binding WriteValue, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="10" TextWrapping="Wrap"
                           Text="點擊按鈕時寫入 PLC 的值（預設 1）。toggle 模式下此值為「開啟值」。" Margin="0,0,0,8"/>

                <TextBlock Text="命令類型" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <ComboBox ItemsSource="{x:Static vm:DesignerItemViewModel.CommandTypes}"
                          SelectedItem="{Binding CommandType}" Margin="0,0,0,4"/>
                <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="10" TextWrapping="Wrap"
                           Text="write＝寫入固定值；pulse＝寫入後延遲歸零；toggle＝讀取當前值取反；sequence＝多步驟序列。" Margin="0,0,0,8"/>

                <TextBlock Style="{StaticResource FieldLabel}" Margin="0,0,0,2">
                    <Run Text="Pulse 持續時間 (ms)："/><Run Text="{Binding PulseMs, StringFormat=F0, Mode=OneWay}"/>
                </TextBlock>
                <Slider Value="{Binding PulseMs}" Minimum="50" Maximum="3000" TickFrequency="50"
                        IsSnapToTickEnabled="True" Margin="0,0,0,4"/>
                <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="10" TextWrapping="Wrap"
                           Text="僅 pulse 模式有效。寫入值後等待此毫秒數再寫 0。" Margin="0,0,0,8"/>

                <!-- Sequence Definition Editor (visible when commandType=sequence) -->
                <StackPanel Margin="0,0,0,8">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CommandType}" Value="sequence">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Separator Margin="0,4,0,8"/>
                    <TextBlock Text="序列定義 (JSON)" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                    <TextBox Text="{Binding SequenceDefinition, UpdateSourceTrigger=LostFocus}"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             MinHeight="120" MaxHeight="300" FontFamily="Consolas" FontSize="11"
                             Margin="0,0,0,4"/>
                    <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="10" TextWrapping="Wrap"
                               Text="JSON 格式定義多步驟 PLC 指令序列。步驟類型：write（寫入）、read（讀取存變數）、wait（延遲）、conditional（條件分支）、readWait（輪詢等待）。&#x0A;範例：{&quot;steps&quot;:[{&quot;type&quot;:&quot;write&quot;,&quot;address&quot;:&quot;D100&quot;,&quot;value&quot;:1},{&quot;type&quot;:&quot;wait&quot;,&quot;ms&quot;:500},{&quot;type&quot;:&quot;write&quot;,&quot;address&quot;:&quot;D100&quot;,&quot;value&quot;:0}],&quot;onError&quot;:&quot;rollback&quot;}"/>
                </StackPanel>

                <TextBlock Text="所需權限" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <ComboBox ItemsSource="{x:Static vm:DesignerItemViewModel.AccessLevels}"
                          SelectedItem="{Binding RequiredLevel}" Margin="0,0,0,8"/>

                <TextBlock Text="按鈕主題" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <ComboBox ItemsSource="{x:Static vm:DesignerItemViewModel.ButtonThemes}"
                          SelectedItem="{Binding Theme}" Margin="0,0,0,8"/>
            </StackPanel>
        </DataTemplate>

        <!-- ════════════════════════════════════════════════════════
             Spacer / GroupBox 屬性面板
             ════════════════════════════════════════════════════════ -->
        <DataTemplate x:Key="SpacerTemplate" DataType="{x:Type vm:DesignerItemViewModel}">
            <StackPanel Margin="0,4">
                <TextBlock Text="群組標題 (Title)" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <TextBox Text="{Binding GroupTitle, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Text="標題列主題色" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <ComboBox ItemsSource="{x:Static vm:DesignerItemViewModel.GroupHeaderThemeOptions}"
                          SelectedItem="{Binding GroupHeaderTheme}" Margin="0,0,0,8"/>

                <TextBlock Text="拖曳此 GroupBox 時，中心點在框內的元件會一起移動"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="10" TextWrapping="Wrap" Margin="0,0,0,4"/>
            </StackPanel>
        </DataTemplate>

        <!-- ════════════════════════════════════════════════════════
             LiveLog 屬性面板
             ════════════════════════════════════════════════════════ -->
        <DataTemplate x:Key="LiveLogTemplate" DataType="{x:Type vm:DesignerItemViewModel}">
            <StackPanel Margin="0,4">
                <TextBlock Text="即時日誌檢視器" Style="{StaticResource SectionHeader}" Margin="0,0,0,4"/>
                <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="10" TextWrapping="Wrap"
                           Text="LiveLog 自動訂閱系統日誌，無需額外設定。&#x0A;調整元件尺寸即可控制顯示區域大小。"/>
            </StackPanel>
        </DataTemplate>

        <!-- ════════════════════════════════════════════════════════
             AlarmViewer 屬性面板
             ════════════════════════════════════════════════════════ -->
        <DataTemplate x:Key="AlarmViewerTemplate" DataType="{x:Type vm:DesignerItemViewModel}">
            <StackPanel Margin="0,4">
                <TextBlock Text="設定檔路徑" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding ConfigFile, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                    <Button Grid.Column="1" Content="產生範本" Padding="8,2" FontSize="11"
                            Click="OnGenerateAlarmTemplate"/>
                </Grid>
                <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="10" TextWrapping="Wrap"
                           Text="點「產生範本」建立 alarms.json 並填入路徑；Runtime 從此檔讀取報警定義。"/>
            </StackPanel>
        </DataTemplate>

        <!-- ════════════════════════════════════════════════════════
             SensorViewer 屬性面板
             ════════════════════════════════════════════════════════ -->
        <DataTemplate x:Key="SensorViewerTemplate" DataType="{x:Type vm:DesignerItemViewModel}">
            <StackPanel Margin="0,4">
                <TextBlock Text="設定檔路徑" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding ConfigFile, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                    <Button Grid.Column="1" Content="產生範本" Padding="8,2" FontSize="11"
                            Click="OnGenerateSensorTemplate"/>
                </Grid>
                <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="10" TextWrapping="Wrap"
                           Text="點「產生範本」建立 sensors.json 並填入路徑；Runtime 從此檔讀取感測器定義。"/>
            </StackPanel>
        </DataTemplate>

        <!-- ════════════════════════════════════════════════════════
             StaticLabel 屬性面板
             ════════════════════════════════════════════════════════ -->
        <DataTemplate x:Key="StaticLabelTemplate" DataType="{x:Type vm:DesignerItemViewModel}">
            <StackPanel Margin="0,4">
                <!-- StaticText -->
                <TextBlock Text="顯示文字" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <TextBox Text="{Binding StaticText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <!-- StaticFontSize -->
                <TextBlock Style="{StaticResource FieldLabel}" Margin="0,0,0,2">
                    <Run Text="字體大小："/><Run Text="{Binding StaticFontSize, StringFormat=F0, Mode=OneWay}"/>
                </TextBlock>
                <Slider Value="{Binding StaticFontSize}" Minimum="8" Maximum="72" TickFrequency="1"
                        IsSnapToTickEnabled="True" Margin="0,0,0,8"/>

                <!-- StaticFontWeight -->
                <TextBlock Text="字體粗細" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <ComboBox ItemsSource="{x:Static vm:DesignerItemViewModel.FontWeightOptions}"
                          SelectedItem="{Binding StaticFontWeight}" Margin="0,0,0,8"/>

                <!-- StaticTextAlign -->
                <TextBlock Text="對齊方式" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <ComboBox ItemsSource="{x:Static vm:DesignerItemViewModel.TextAlignOptions}"
                          SelectedItem="{Binding StaticTextAlign}" Margin="0,0,0,8"/>

                <!-- StaticForeground -->
                <TextBlock Text="文字顏色" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                <ComboBox ItemsSource="{x:Static vm:DesignerItemViewModel.ForegroundOptions}"
                          SelectedItem="{Binding StaticForeground}" Margin="0,0,0,4"/>
                <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="10"
                           Text="也可直接輸入顏色代碼（如 #FF6C8EEF）"/>
            </StackPanel>
        </DataTemplate>

        <!-- ════════════════════════════════════════════════════════
             空白（未選取任何項目）
             ════════════════════════════════════════════════════════ -->
        <DataTemplate x:Key="EmptyTemplate">
            <TextBlock Text="請點選畫布中的控制項以編輯屬性"
                       Foreground="{StaticResource TextMutedBrush}"
                       TextWrapping="Wrap" Margin="0,20"
                       HorizontalAlignment="Center"/>
        </DataTemplate>

        <!-- Template Selector -->
        <local:PropertyPanelTemplateSelector x:Key="PropSelector"
            PlcLabelTemplate="{StaticResource PlcLabelTemplate}"
            PlcTextTemplate="{StaticResource PlcTextTemplate}"
            PlcStatusIndicatorTemplate="{StaticResource PlcStatusIndicatorTemplate}"
            SecuredButtonTemplate="{StaticResource SecuredButtonTemplate}"
            SpacerTemplate="{StaticResource SpacerTemplate}"
            LiveLogTemplate="{StaticResource LiveLogTemplate}"
            AlarmViewerTemplate="{StaticResource AlarmViewerTemplate}"
            SensorViewerTemplate="{StaticResource SensorViewerTemplate}"
            StaticLabelTemplate="{StaticResource StaticLabelTemplate}"
            EmptyTemplate="{StaticResource EmptyTemplate}"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="10,8"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock Text="&#x25C6; Properties" Style="{StaticResource SectionHeader}" FontSize="13"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10,6">
            <StackPanel>
                <!-- 鎖定 -->
                <CheckBox Content="鎖定（防止移動/縮放）"
                          IsChecked="{Binding IsLocked}"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          Margin="0,4,0,10"/>

                <!-- 位置與大小 -->
                <StackPanel x:Name="canvasPosSection">

                    <TextBlock Text="位置 / 大小" Style="{StaticResource SectionHeader}" Margin="0,4,0,6"/>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="X" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding X, UpdateSourceTrigger=LostFocus, StringFormat=F0}"
                                     PreviewKeyDown="OnNumericKeyDown"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="Y" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding Y, UpdateSourceTrigger=LostFocus, StringFormat=F0}"
                                     PreviewKeyDown="OnNumericKeyDown"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="寬度 W" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding Width, UpdateSourceTrigger=LostFocus, StringFormat=F0}"
                                     PreviewKeyDown="OnNumericKeyDown"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Text="高度 H" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding Height, UpdateSourceTrigger=LostFocus, StringFormat=F0}"
                                     PreviewKeyDown="OnNumericKeyDown"/>
                        </StackPanel>
                    </Grid>

                    <Separator Margin="0,4,0,8"/>
                </StackPanel>

                <!-- 型態專屬屬性 -->
                <ContentControl Content="{Binding}"
                                ContentTemplateSelector="{StaticResource PropSelector}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
