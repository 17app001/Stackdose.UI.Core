                                </StackPanel>
                            </Grid>

                            <!-- ?е–®?зҳҘоқ„? Sliderеҡ—пҢ–plitRight ?пҗӨ?еҡ—?-->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="?е–®?зҳҘоқ„?"
                                           ToolTip="SplitRight з’…вҲӘ??пҗӨ?еҡ—о®ҚоҸҝ??Viewer з”Ҳп„”оӯ ж’ пҡ–и‘үз”Ҳп„”?ж’–з ҚжјІзҳҘ?>
                                    <TextBlock.Style>
