<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Stackdose.UI.Core;component/Themes/Theme.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Legacy-compatible brush keys mapped from UI.Core semantic/domain tokens -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{Binding Source={StaticResource Accent.Primary}, Path=Color}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{Binding Source={StaticResource Action.Primary}, Path=Color}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{Binding Source={StaticResource Surface.Bg.Page}, Path=Color}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{Binding Source={StaticResource Surface.Bg.Card}, Path=Color}"/>
    <SolidColorBrush x:Key="DarkBackgroundBrush" Color="{Binding Source={StaticResource Surface.Bg.Panel}, Path=Color}"/>
    <SolidColorBrush x:Key="HoverBackgroundBrush" Color="{Binding Source={StaticResource Overlay.Bg.Light}, Path=Color}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{Binding Source={StaticResource Text.Primary}, Path=Color}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{Binding Source={StaticResource Text.Secondary}, Path=Color}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{Binding Source={StaticResource Text.Tertiary}, Path=Color}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{Binding Source={StaticResource Text.Secondary}, Path=Color}"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="{Binding Source={StaticResource Action.Success}, Path=Color}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{Binding Source={StaticResource Action.Warning}, Path=Color}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{Binding Source={StaticResource Action.Error}, Path=Color}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{Binding Source={StaticResource Action.Info}, Path=Color}"/>

    <SolidColorBrush x:Key="BorderBrush" Color="{Binding Source={StaticResource Surface.Border.Default}, Path=Color}"/>
    <SolidColorBrush x:Key="BorderSecondaryBrush" Color="{Binding Source={StaticResource Surface.Border.Strong}, Path=Color}"/>

    <SolidColorBrush x:Key="DisabledBackgroundBrush" Color="{Binding Source={StaticResource Overlay.Bg.Panel}, Path=Color}"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="{Binding Source={StaticResource Text.Tertiary}, Path=Color}"/>
    <SolidColorBrush x:Key="DangerAccentBrush" Color="{Binding Source={StaticResource Status.Error}, Path=Color}"/>

</ResourceDictionary>
