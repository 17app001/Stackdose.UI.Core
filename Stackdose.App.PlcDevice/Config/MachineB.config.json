{
  "schemaVersion": "1.0",
  "machine": {
    "id": "MODELB-M02",
    "name": "Model B Machine 02",
    "line": "Line-A",
    "enable": true
  },
  "plc": {
    "vendor": "Mitsubishi",
    "protocol": "MC",
    "ip": "192.168.10.21",
    "port": 5000,
    "pollIntervalMs": 300,
    "timeoutMs": 1000,
    "retry": 2
  },
  "tags": {
    "status": {
      "isConnected": { "address": "M220", "type": "bool", "access": "read" },
      "isRunning": { "address": "M221", "type": "bool", "access": "read" },
      "isAlarm": { "address": "M222", "type": "bool", "access": "read" },
      "heartbeat": { "address": "D320", "type": "int16", "access": "read" },
      "mode": { "address": "D321", "type": "int16", "access": "read" }
    },
    "command": {
      "start": { "address": "M120", "type": "bool", "access": "writePulse", "pulseMs": 200 },
      "stop": { "address": "M121", "type": "bool", "access": "writePulse", "pulseMs": 200 },
      "reset": { "address": "M122", "type": "bool", "access": "writePulse", "pulseMs": 200 }
    },
    "process": {
      "batchNo": { "address": "D500", "type": "string", "access": "read", "length": 8 },
      "recipeNo": { "address": "D510", "type": "string", "access": "read", "length": 8 },
      "nozzleTemp": { "address": "D520", "type": "int16", "access": "read", "scale": 0.1, "unit": "C" }
    }
  },
  "security": {
    "start": "Operator",
    "stop": "Operator",
    "reset": "Supervisor"
  }
}
