<UserControl x:Class="Stackdose.UI.Templates.Pages.MachineOverviewPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:core="http://schemas.stackdose.com/wpf"
             xmlns:controls="clr-namespace:Stackdose.UI.Templates.Controls"
             mc:Ignorable="d"
             d:DesignWidth="1400"
             d:DesignHeight="900">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Stackdose.UI.Templates;component/Resources/CommonColors.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{DynamicResource Surface.Bg.Page}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource Template.PanelCard}"
                Margin="{StaticResource Template.CardMargin}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Machine Overview"
                               Style="{StaticResource Template.PageTitleText}"/>
                    <TextBlock Text="Use this page as the default multi-machine dashboard template."
                               Style="{StaticResource Template.CaptionText}"
                               Margin="0,6,0,10"/>
                    <core:PlcStatus Width="280"
                                    x:Name="PlcConnectionStatus"
                                    Height="58"
                                    HorizontalAlignment="Left"
                                    AutoConnect="{Binding PlcAutoConnect, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    IsGlobal="True"
                                    ShowBorder="True"
                                    IpAddress="{Binding PlcIpAddress, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Port="{Binding PlcPort, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    ScanInterval="{Binding PlcScanInterval, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    MonitorAddress="{Binding PlcMonitorAddresses, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                </StackPanel>

                <controls:SystemClock Grid.Column="1"
                                      Width="260"
                                      Height="106"
                                      TimeFontSize="30"
                                      DateFontSize="12"
                                      VerticalAlignment="Top"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Margin="20,0,20,20"
                      Visibility="{Binding ShowMachineCards, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding MachineCards, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel ItemWidth="420" ItemHeight="300"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:MachineCard Margin="8"
                                              MachineId="{Binding MachineId}"
                                              SelectCommand="{Binding SelectMachineCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              SelectCommandParameter="{Binding MachineId}"
                                              Title="{Binding Title}"
                                              BatchValue="{Binding BatchValue}"
                                              RecipeText="{Binding RecipeText}"
                                              StatusText="{Binding StatusText}"
                                              StatusBrush="{Binding StatusBrush}"
                                              LeftTopLabel="{Binding LeftTopLabel}"
                                              LeftTopValue="{Binding LeftTopValue}"
                                              LeftBottomLabel="{Binding LeftBottomLabel}"
                                              LeftBottomValue="{Binding LeftBottomValue}"
                                              RightTopLabel="{Binding RightTopLabel}"
                                              RightTopValue="{Binding RightTopValue}"
                                              RightBottomLabel="{Binding RightBottomLabel}"
                                              RightBottomValue="{Binding RightBottomValue}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
