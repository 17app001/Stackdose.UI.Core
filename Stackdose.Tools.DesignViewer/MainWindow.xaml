<Window x:Class="Stackdose.Tools.DesignViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DesignViewer — MachineDesign JSON 預覽器"
        Width="1280" Height="820"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E"
        AllowDrop="True"
        Drop="OnWindowDrop"
        DragOver="OnWindowDragOver">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ── -->
        <Border Grid.Row="0"
                Background="#252540"
                BorderBrush="#3A3A5A"
                BorderThickness="0,0,0,1"
                Padding="10,6">
            <WrapPanel VerticalAlignment="Center">

                <Button x:Name="btnOpen"
                        Content="&#x1F4C2; 開啟 JSON"
                        Click="OnOpenClick"
                        Padding="12,5" Margin="0,0,8,0"
                        Background="#4A6EBF" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        FontWeight="SemiBold"/>

                <TextBlock x:Name="lblFilePath"
                           Text="尚未載入檔案   拖曳 .machinedesign.json 到視窗即可預覽"
                           Foreground="#9090B0" VerticalAlignment="Center"
                           Margin="0,0,24,0" FontSize="12"/>

                <Separator Width="1" Background="#3A3A5A" Margin="0,2,16,2" Style="{x:Null}"/>

                <TextBlock Text="縮放：" Foreground="#9090B0" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
                <Slider x:Name="sliderZoom"
                        Minimum="0.25" Maximum="2.0" Value="1.0"
                        Width="160" VerticalAlignment="Center"
                        ValueChanged="OnZoomChanged"
                        SmallChange="0.05" LargeChange="0.25"
                        TickFrequency="0.25" IsSnapToTickEnabled="False"
                        Margin="0,0,8,0"/>
                <TextBlock x:Name="lblZoom"
                           Text="100%" Foreground="#C0C0D8"
                           VerticalAlignment="Center" Width="40" FontSize="12"/>

                <Separator Width="1" Background="#3A3A5A" Margin="0,2,16,2" Style="{x:Null}"/>

                <TextBlock x:Name="lblCanvasSize"
                           Text="畫布：—"
                           Foreground="#9090B0" VerticalAlignment="Center" FontSize="12"/>

            </WrapPanel>
        </Border>

        <!-- ── 頁籤列（多頁文件才顯示） ── -->
        <Border Grid.Row="1"
                x:Name="pageTabsBar"
                Background="#1E2040"
                BorderBrush="#3A3A6A"
                BorderThickness="0,0,0,1"
                Padding="8,4"
                Visibility="Collapsed">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          HorizontalAlignment="Left">
                <StackPanel x:Name="pageTabs" Orientation="Horizontal" VerticalAlignment="Center"/>
            </ScrollViewer>
        </Border>

        <!-- ── Canvas Area ── -->
        <ScrollViewer Grid.Row="2"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="#12121E"
                      Padding="40">

            <!-- ScaleTransform 套用縮放 -->
            <Grid x:Name="canvasHost" HorizontalAlignment="Left" VerticalAlignment="Top">
                <Grid.LayoutTransform>
                    <ScaleTransform x:Name="canvasScale" ScaleX="1" ScaleY="1"/>
                </Grid.LayoutTransform>

                <!-- 實際畫布 -->
                <Canvas x:Name="designCanvas"
                        Background="#1E1E32"
                        ClipToBounds="True"
                        SnapsToDevicePixels="True">

                    <!-- 格線（視覺輔助） -->
                    <Canvas.Effect>
                        <BlurEffect Radius="0"/>
                    </Canvas.Effect>
                </Canvas>

                <!-- 畫布邊框 -->
                <Border x:Name="canvasBorder"
                        BorderBrush="#3A3A6A"
                        BorderThickness="1"
                        IsHitTestVisible="False"/>
            </Grid>
        </ScrollViewer>

        <!-- ── Status Bar ── -->
        <Border Grid.Row="3"
                Background="#252540"
                BorderBrush="#3A3A5A"
                BorderThickness="0,1,0,0"
                Padding="10,4">
            <TextBlock x:Name="lblStatus"
                       Text="就緒 — 請開啟或拖入 .machinedesign.json 檔案"
                       Foreground="#7070A0" FontSize="11"/>
        </Border>
    </Grid>
</Window>
