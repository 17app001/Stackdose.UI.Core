                                        ToolTip="ж’ҢиЎҢ? 250pxеҡ—п—әоҸҝз”Ҳп„“???1.4">ж’–жҹ“iewer</Button>
                            </WrapPanel>

                            <!-- ж’ҢиЎҢ?ж’–?Slider -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}"
