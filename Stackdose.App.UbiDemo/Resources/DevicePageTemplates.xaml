<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:core="http://schemas.stackdose.com/wpf">

    <!-- ============================================================ -->
    <!-- Device Command: Process State (large + prominent) + buttons  -->
    <!-- ============================================================ -->
    <DataTemplate x:Key="DeviceCommandTemplate">
        <StackPanel>

            <!-- Process State - large prominent panel -->
            <Border Margin="0,0,0,10"
                    CornerRadius="10"
                    BorderThickness="1.5"
                    BorderBrush="#00E5FF"
                    Background="#0D1A26">
                <Border.Effect>
                    <DropShadowEffect Color="#00E5FF" BlurRadius="16" ShadowDepth="0" Opacity="0.3"/>
                </Border.Effect>

                <Grid>
                    <!-- Accent top stripe -->
                    <Border CornerRadius="10,10,0,0" Height="3" VerticalAlignment="Top">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00E5FF" Offset="0"/>
                                <GradientStop Color="#0088D4" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <StackPanel Margin="14,14,14,12">
                        <!-- Title row -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Ellipse Width="10" Height="10"
                                     Fill="#00E5FF"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#00E5FF" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="PROCESS STATE"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="#5A8AB0"/>
                        </StackPanel>

                        <!-- State value - big and bold -->
                        <Border Padding="14,12"
                                CornerRadius="8"
                                Background="#162033"
                                BorderBrush="#2A4A60"
                                BorderThickness="1">
                            <TextBlock Text="{Binding CurrentProcessStateText}"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="#00E5FF"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Operation Duration row -->
                        <Border Margin="0,8,0,0"
                                Padding="10,8"
                                CornerRadius="6"
                                Background="#162033"
                                BorderBrush="#2A4A60"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#x23F1;"
                                               FontSize="14"
                                               Foreground="#5A8AB0"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <TextBlock Text="Operation Duration"
                                               FontSize="11"
                                               Foreground="#5A8AB0"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <core:PlcLabel Grid.Column="1"
                                               Label=""
                                               Address="{Binding ElapsedTimeAddress}"
                                               ShowFrame="False"
                                               ShowAddress="False"
                                               LabelFontSize="1"
                                               ValueFontSize="16"
                                               DefaultValue="00:00:00"
                                               ValueAlignment="Right"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Command buttons -->
            <UniformGrid Columns="2" Margin="0,4,0,8">
                <core:SecuredButton Content="Start"
                                    Theme="Success"
                                    RequiredLevel="Operator"
                                    OperationName="Start Process"
                                    Command="{Binding StartProcessCommand}"
                                    Margin="0,0,4,4" />
                <core:SecuredButton Content="Pause/Resume"
                                    Theme="Warning"
                                    RequiredLevel="Operator"
                                    OperationName="Pause Resume"
                                    Margin="4,0,0,4" />
                <core:SecuredButton Content="Stop"
                                    Theme="Error"
                                    RequiredLevel="Operator"
                                    OperationName="Stop Process"
                                    Margin="0,4,4,0" />
                <core:SecuredButton Content="Spit Execute"
                                    Theme="Warning"
                                    RequiredLevel="Operator"
                                    OperationName="Spit"
                                    Margin="4,4,0,0" />
            </UniformGrid>
        </StackPanel>
    </DataTemplate>

    <!-- ============================================================ -->
    <!-- Device Process Trigger (unchanged)                           -->
    <!-- ============================================================ -->
    <DataTemplate x:Key="DeviceProcessTriggerTemplate">
        <Grid>
            <core:PlcEventTrigger Address="{Binding RunningAddress}"
                                  EventName="ProcessRunning"
                                  AutoClear="False" />
            <core:PlcEventTrigger Address="{Binding CompletedAddress}"
                                  EventName="ProcessCompleted"
                                  AutoClear="False" />
            <core:PlcEventTrigger Address="{Binding AlarmAddress}"
                                  EventName="ProcessAlarm"
                                  AutoClear="False" />
        </Grid>
    </DataTemplate>
</ResourceDictionary>
