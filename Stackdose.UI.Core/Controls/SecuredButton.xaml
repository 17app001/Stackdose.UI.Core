<UserControl x:Class="Stackdose.UI.Core.Controls.SecuredButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Stackdose.UI.Core.Controls"
             mc:Ignorable="d"
             x:Name="root"
             d:DesignHeight="40" d:DesignWidth="150">
    
    <Button x:Name="InnerButton"
            Content="{Binding Content, ElementName=root}"
            IsEnabled="{Binding IsAuthorized, ElementName=root}"
            Click="InnerButton_Click"
            ToolTip="{Binding TooltipText, ElementName=root}"
            MinWidth="100"
            MinHeight="36"
            Padding="15,8"
            FontSize="14"
            FontWeight="Medium"
            FocusVisualStyle="{x:Null}"
            Cursor="Hand">
        
        <Button.Style>
            <Style TargetType="Button">
                <Setter Property="Background" Value="{Binding BackgroundBrush, ElementName=root}"/>
                <Setter Property="Foreground" Value="{DynamicResource Text.Inverse}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Surface.Border.Default}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    CornerRadius="5"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <Border.Effect>
                                    <DropShadowEffect Color="#40000000" 
                                                      BlurRadius="8" 
                                                      ShadowDepth="1" 
                                                      Opacity="0.2"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"
                                                  TextElement.Foreground="{TemplateBinding Foreground}">
                                    <ContentPresenter.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                        </Style>
                                    </ContentPresenter.Resources>
                                </ContentPresenter>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                
                <Style.Triggers>
                    <Trigger Property="IsKeyboardFocused" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource Accent.Primary}"/>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{Binding HoverBrush, ElementName=root}"/>
                        <Setter Property="Opacity" Value="0.9"/>
                    </Trigger>

                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Opacity" Value="0.8"/>
                    </Trigger>
                    
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Background" Value="{DynamicResource Surface.Bg.Panel}"/>
                        <Setter Property="Foreground" Value="{DynamicResource Text.Tertiary}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource Surface.Border.Default}"/>
                        <Setter Property="Cursor" Value="Arrow"/>
                        <Setter Property="Opacity" Value="1.0"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Button.Style>
    </Button>
</UserControl>
