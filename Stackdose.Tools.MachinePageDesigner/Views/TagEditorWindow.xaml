<Window x:Class="Stackdose.Tools.MachinePageDesigner.Views.TagEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PLC Tags 編輯器"
        Width="560" Height="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="400" MinHeight="320">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="PLC Tags 定義表" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock TextWrapping="Wrap" FontSize="11" Opacity="0.65"
                       Text="工程師在此定義 PLC 地址與人類可讀名稱的對照。設計師在屬性面板填寫地址時，可從下拉選取，減少打錯的機率。"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="1"
                  x:Name="TagGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0"
                  Margin="0,0,0,8"
                  BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="PLC 地址 *" Binding="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                                    Width="140" MinWidth="80"/>
                <DataGridTextColumn Header="名稱（中文 / 英文）" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*" MinWidth="120"/>
                <DataGridTextColumn Header="單位（選填）" Binding="{Binding Unit, UpdateSourceTrigger=PropertyChanged}"
                                    Width="90" MinWidth="60"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Row action buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="＋ 新增列" Width="90" Padding="0,5" Margin="0,0,8,0"
                    Click="OnAddRow"/>
            <Button Content="✕ 刪除選取" Width="90" Padding="0,5"
                    Click="OnDeleteRow"/>
        </StackPanel>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="確定" Width="80" Padding="0,6" IsDefault="True"
                    Margin="0,0,8,0" Click="OnOk"/>
            <Button Content="關閉" Width="80" Padding="0,6" IsCancel="True"
                    Click="OnClose"/>
        </StackPanel>
    </Grid>
</Window>
