<UserControl x:Class="Stackdose.UI.Core.Controls.PrintHeadStatus"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="root"
             d:DesignWidth="220"
             HorizontalAlignment="Stretch">

    <Border Background="{DynamicResource Plc.Bg.Dark}"
            BorderBrush="{DynamicResource Plc.Border}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="8"
            HorizontalAlignment="Stretch">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: Status Light + Name + IP + Temperature + Power Button -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status Light -->
                <Grid Grid.Column="0" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusLight"
                             Width="10"
                             Height="10"
                             Fill="{DynamicResource Status.Error}">
                        <Ellipse.Effect>
                            <DropShadowEffect x:Name="StatusGlow"
                                              Color="#FF5F5F"
                                              BlurRadius="6"
                                              ShadowDepth="0"
                                              Opacity="0.8"/>
                        </Ellipse.Effect>
                    </Ellipse>
                </Grid>

                <!-- Name + IP -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="{Binding HeadName, ElementName=root, FallbackValue='PrintHead 1'}"
                               FontSize="12"
                               FontWeight="Bold"
                               FontFamily="Microsoft JhengHei"
                               Foreground="{DynamicResource Plc.Text.Label}"/>
                    <TextBlock x:Name="BoardAddressText"
                               Text="N/A"
                               FontSize="9"
                               FontFamily="Consolas"
                               Foreground="{DynamicResource Plc.Text.Default}"
                               Margin="0,1,0,0"/>
                    <TextBlock x:Name="StateText"
                               Text="IDLE"
                               FontSize="9"
                               FontWeight="Bold"
                               FontFamily="Consolas"
                               Foreground="{DynamicResource Status.Offline}"
                               Margin="0,2,0,0"
                               HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Temperature -->
                <TextBlock x:Name="TemperatureText"
                           Grid.Column="4"
                           Text="N/A"
                           FontSize="12"
                           Foreground="{DynamicResource Plc.Text.Value}"
                           FontWeight="Bold"
                           FontFamily="Consolas"
                           VerticalAlignment="Center"/>

                <!-- Power ON/OFF Button -->
                <ToggleButton x:Name="PowerButton"
                               Grid.Column="6"
                              Width="28"
                              Height="28"
                              VerticalAlignment="Center"
                              Cursor="Hand"
                              Checked="PowerButton_Checked"
                              Unchecked="PowerButton_Unchecked">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Grid>
                                            <Ellipse x:Name="CircleBackground"
                                                     Width="28"
                                                     Height="28"
                                                     Fill="{DynamicResource Cyber.Bg.Panel}"
                                                     Stroke="{DynamicResource Cyber.Border}"
                                                     StrokeThickness="1.5"/>
                                            <Canvas Width="14" Height="14"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                                <Line X1="7" Y1="0" X2="7" Y2="7"
                                                      x:Name="PowerLine"
                                                      Stroke="{DynamicResource Plc.Text.Gray}"
                                                      StrokeThickness="2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"/>
                                                <Path x:Name="PowerArc"
                                                      Data="M 3,5 A 5,5 0 1,0 11,5"
                                                      Stroke="{DynamicResource Plc.Text.Gray}"
                                                      StrokeThickness="2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      Fill="Transparent"/>
                                            </Canvas>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="CircleBackground" Property="Fill" Value="{DynamicResource Status.Success}"/>
                                                <Setter TargetName="CircleBackground" Property="Stroke" Value="{DynamicResource Status.Success}"/>
                                                <Setter TargetName="PowerLine" Property="Stroke" Value="White"/>
                                                <Setter TargetName="PowerArc" Property="Stroke" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CircleBackground" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="CircleBackground" Property="Opacity" Value="0.5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>
            </Grid>

            <!-- Status Data (Always Visible, Compact) -->
            <Border x:Name="StatusDataPanel"
                    Grid.Row="2"
                    Background="{DynamicResource Plc.Bg.Main}"
                    BorderBrush="{DynamicResource Plc.Border}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="6,3">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Voltages: 4 channels in a single row, plain text, no badge borders -->
                    <ItemsControl x:Name="VoltagesPanel" Grid.Row="0" HorizontalAlignment="Stretch">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" Rows="1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontSize="9"
                                           Foreground="{DynamicResource PrintHead.Accent.Voltage}"
                                           FontFamily="Consolas"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Encoder + PrintIndex side by side -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="Enc: "
                                       FontSize="9"
                                       Foreground="{DynamicResource Plc.Text.Default}"
                                       FontFamily="Consolas"/>
                            <TextBlock x:Name="EncoderText"
                                       Text="N/A"
                                       FontSize="9"
                                       Foreground="{DynamicResource PrintHead.Accent.Encoder}"
                                       FontFamily="Consolas"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="Idx: "
                                       FontSize="9"
                                       Foreground="{DynamicResource Plc.Text.Default}"
                                       FontFamily="Consolas"/>
                            <TextBlock x:Name="PrintIndexText"
                                       Text="N/A"
                                       FontSize="9"
                                       Foreground="{DynamicResource PrintHead.Accent.PrintIndex}"
                                       FontFamily="Consolas"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
