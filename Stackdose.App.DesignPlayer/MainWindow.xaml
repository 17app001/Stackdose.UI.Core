<Window x:Class="Stackdose.App.DesignPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Shell="clr-namespace:Stackdose.UI.Templates.Shell;assembly=Stackdose.UI.Templates"
        xmlns:controls="clr-namespace:Stackdose.App.DesignPlayer.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Stackdose Monitor"
        Height="900" Width="1600"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="CanResize">

    <Grid>
        <!-- 標準 Shell（預設） -->
        <Shell:MainContainer x:Name="MainShell"
                             IsShellMode="False"
                             HeaderDeviceName="MONITOR"
                             PageTitle="Monitor"/>

        <!-- Dashboard 模式（初始隱藏，偵測到 Dashboard layout 後切換） -->
        <Grid x:Name="DashboardLayout" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <controls:DashboardTopBar x:Name="DashTopBar" Grid.Row="0"/>
            <ContentControl x:Name="DashboardContent" Grid.Row="1"/>
        </Grid>
    </Grid>
</Window>
