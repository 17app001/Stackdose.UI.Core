<Window x:Class="Stackdose.App.ModelB.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Custom="http://schemas.stackdose.com/wpf"
        xmlns:Templates="http://schemas.stackdose.com/templates"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Model-B 3D Printing Tablet Device" 
        Height="900" 
        Width="1600"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="CanResize">
    
    <!-- 使用 CyberFrame 作為外層框架 -->
    <Custom:CyberFrame
        x:Name="MainFrame"
        Title="MODEL-B"
        PlcIpAddress="192.168.22.39"
        PlcPort="3000"
        PlcAutoConnect="True"
        PlcScanInterval="150">
        
        <Custom:CyberFrame.MainContent>
            <!-- 使用 MainContainer 作為主容器 -->
            <Templates:MainContainer 
                NavigationRequested="OnNavigate"
                LogoutRequested="OnLogout"
                CloseRequested="OnClose"
                MinimizeRequested="OnMinimize"/>
        </Custom:CyberFrame.MainContent>
        
    </Custom:CyberFrame>
</Window>
