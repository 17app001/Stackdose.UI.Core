<UserControl x:Class="Stackdose.UI.Templates.Controls.SystemClock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="240"
             d:DesignHeight="72">

    <Border Style="{StaticResource Template.PanelCard}">
        <StackPanel>
            <TextBlock x:Name="TimeText"
                       Text="00:00:00"
                       FontSize="{Binding TimeFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontWeight="Bold"
                       HorizontalAlignment="Right"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock x:Name="DateText"
                       Text="2000-01-01"
                       FontSize="{Binding DateFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       HorizontalAlignment="Right"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>
    </Border>
</UserControl>
