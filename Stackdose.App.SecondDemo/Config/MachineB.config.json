{
  "machine": {
    "id": "M2",
    "name": "Second Machine 02",
    "enable": true
  },
  "alarmConfigFile": "Config/MachineB.alarms.json",
  "sensorConfigFile": "Config/MachineB.sensors.json",
  "plc": {
    "ip": "192.168.22.39",
    "port": 3000,
    "pollIntervalMs": 150,
    "autoConnect": true
  },
  "tags": {
    "status": {
      "isConnected": { "address": "M220", "type": "bool", "access": "read" },
      "isRunning": { "address": "M221", "type": "bool", "access": "read" },
      "isAlarm": { "address": "M222", "type": "bool", "access": "read" }
    },
    "process": {
      "batchNo": { "address": "D500", "type": "string", "access": "read", "length": 8 },
      "recipeNo": { "address": "D510", "type": "string", "access": "read", "length": 8 },
      "nozzleTemp": { "address": "D520", "type": "int16", "access": "read" }
    }
  }
}
