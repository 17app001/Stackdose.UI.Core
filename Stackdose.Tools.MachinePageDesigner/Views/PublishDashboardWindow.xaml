<Window x:Class="Stackdose.Tools.MachinePageDesigner.Views.PublishDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="封裝 Dashboard App"
        Width="620" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI"
        FontSize="13">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="📦 封裝 Dashboard App"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,4"/>
            <TextBlock TextWrapping="Wrap" FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Text="產生可獨立部署的 Dashboard 執行檔，包含 DesignPlayer、設計稿與 app-config.json。需在安裝了 .NET 8 SDK 的開發機上執行。"/>
        </StackPanel>

        <!-- Form -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Exe Name -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="執行檔名稱"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       VerticalAlignment="Center" Margin="0,0,8,8"/>
            <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                     x:Name="ExeNameBox" Margin="0,0,0,8" FontFamily="Consolas"
                     ToolTip="輸出 .exe 的檔案名稱（不含副檔名），預設為 MachineId"/>

            <!-- Output Dir -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="輸出資料夾"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       VerticalAlignment="Center" Margin="0,0,8,8"/>
            <TextBox Grid.Row="1" Grid.Column="1"
                     x:Name="OutputDirBox" Margin="0,0,4,8" FontFamily="Consolas"
                     ToolTip="封裝結果的輸出目錄"/>
            <Button Grid.Row="1" Grid.Column="2" Content="..."
                    Click="OnBrowseOutput"
                    Padding="8,4" Margin="0,0,0,8"
                    Style="{StaticResource ToolbarButton}"/>

            <!-- App Config Path -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="app-config.json 路徑"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       VerticalAlignment="Center" Margin="0,0,8,8"/>
            <TextBox Grid.Row="2" Grid.Column="1"
                     x:Name="AppConfigPathBox" Margin="0,0,4,8" FontFamily="Consolas"
                     ToolTip="要一起封裝的 app-config.json 路徑（必填）"/>
            <Button Grid.Row="2" Grid.Column="2" Content="..."
                    Click="OnBrowseAppConfig"
                    Padding="8,4" Margin="0,0,0,8"
                    Style="{StaticResource ToolbarButton}"/>

            <!-- DesignPlayer proj -->
            <TextBlock Grid.Row="3" Grid.Column="0" Text="DesignPlayer.csproj"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11"/>
            <TextBox Grid.Row="3" Grid.Column="1"
                     x:Name="ProjPathBox" Margin="0,0,4,0" FontFamily="Consolas" FontSize="11"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     ToolTip="自動偵測，通常不需手動填寫"/>
            <Button Grid.Row="3" Grid.Column="2" Content="..."
                    Click="OnBrowseProj"
                    Padding="8,4"
                    Style="{StaticResource ToolbarButton}"/>
        </Grid>

        <!-- Log output -->
        <Border Grid.Row="2"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                Margin="0,0,0,12">
            <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="LogBox"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         Background="#0D0D1A"
                         Foreground="#9090B0"
                         FontFamily="Consolas"
                         FontSize="11"
                         BorderThickness="0"
                         Padding="8"
                         AcceptsReturn="True"/>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <DockPanel Grid.Row="3">
            <Button x:Name="OpenFolderBtn"
                    Content="📂 開啟資料夾"
                    DockPanel.Dock="Left"
                    Padding="12,7"
                    Visibility="Collapsed"
                    Click="OnOpenFolder"
                    Background="#5C6BC0" Foreground="White"
                    BorderThickness="0" Cursor="Hand"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="PublishBtn"
                        Content="📦 封裝"
                        Width="120" Padding="0,7" Margin="0,0,10,0"
                        IsDefault="True" Click="OnPublish"
                        FontWeight="SemiBold"
                        Background="{StaticResource AccentBrush}"
                        Foreground="White"/>
                <Button x:Name="CloseBtn"
                        Content="關閉"
                        Width="80" Padding="0,7"
                        IsCancel="True" Click="OnClose"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
