<Window x:Class="Stackdose.Tools.MachinePageDesigner.Views.AddSensorItemDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新增感測器定義"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="Lbl">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,8,0,2"/>
        </Style>
    </Window.Resources>

    <Border Padding="20">
        <StackPanel>
            <!-- Group -->
            <TextBlock Text="群組 (Group)" Style="{StaticResource Lbl}"/>
            <TextBox x:Name="TxtGroup" Text="General"/>

            <!-- Device -->
            <TextBlock Style="{StaticResource Lbl}">
                <Run Text="PLC 位址 (Device)"/>
                <Run Text="  例：D90、M100" Foreground="Gray" FontSize="11"/>
            </TextBlock>
            <TextBox x:Name="TxtDevice" Text="D90"/>

            <!-- Mode + Bit + Value 同一行 -->
            <TextBlock Style="{StaticResource Lbl}">
                <Run Text="模式 / Bit / 期望值"/>
                <Run Text="  AND/OR: 填 Bit+Value；COMPARE: 只填 Value（如 &gt;75）" Foreground="Gray" FontSize="11"/>
            </TextBlock>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" x:Name="CmbMode" SelectedIndex="0"
                          FontSize="13" Padding="4,4">
                    <ComboBoxItem Content="AND"/>
                    <ComboBoxItem Content="OR"/>
                    <ComboBoxItem Content="COMPARE"/>
                </ComboBox>
                <TextBox Grid.Column="2" x:Name="TxtBit"  Text="" ToolTip="Bit 索引"/>
                <TextBox Grid.Column="4" x:Name="TxtValue" Text="1" ToolTip="期望值"/>
            </Grid>

            <!-- Description -->
            <TextBlock Text="描述 (OperationDescription)" Style="{StaticResource Lbl}"/>
            <TextBox x:Name="TxtDescription" Text="" MinHeight="32"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="確定" IsDefault="True" Width="80" Height="30"
                        Margin="0,0,8,0" Click="OnOk"/>
                <Button Content="取消" IsCancel="True" Width="80" Height="30"
                        Click="OnCancel"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
