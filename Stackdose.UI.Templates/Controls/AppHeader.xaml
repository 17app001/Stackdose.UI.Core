<UserControl x:Class="Stackdose.UI.Templates.Controls.AppHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:Stackdose.UI.Templates.Converters"
             mc:Ignorable="d"
             d:DesignHeight="60" d:DesignWidth="1600">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Stackdose.UI.Templates;component/Resources/CommonColors.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:FirstCharConverter x:Key="FirstCharConverter"/>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{StaticResource CardBackgroundBrush}" 
            BorderBrush="{StaticResource BorderBrush}" 
            BorderThickness="0,0,0,2"
            Height="60">
        <Grid Margin="15,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Logo and System Title -->
            <StackPanel Grid.Column="0" 
                        Orientation="Horizontal" 
                        VerticalAlignment="Center">
                <Border Width="38" Height="38" 
                        Background="{StaticResource PrimaryBrush}" 
                        CornerRadius="19"
                        Margin="0,0,12,0">
                    <TextBlock Text="S" 
                               FontSize="22" 
                               FontWeight="Bold"
                               Foreground="{StaticResource CardBackgroundBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="STACKDOSE 3D TABLET PRINTER" 
                                   FontSize="15" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="  |  " 
                                   FontSize="15" 
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="MODEL-B" 
                                   FontSize="18" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource WarningBrush}"/>
                    </StackPanel>
                    <TextBlock Text="Mercury Co. - Pharmaceutical 3D Printing System" 
                               FontSize="10" 
                               Foreground="{StaticResource TextTertiaryBrush}"
                               Margin="0,1,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Page Title (without MODEL-B) -->
            <StackPanel Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding PageTitle, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                           FontSize="22" 
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>

                <Border Margin="0,4,0,0"
                        Padding="8,2"
                        CornerRadius="10"
                        Background="{StaticResource HoverBackgroundBrush}"
                        Visibility="{Binding ShowMachineBadge, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding MachineDisplayName, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"
                               HorizontalAlignment="Center"/>
                </Border>
            </StackPanel>

            <!-- User Info -->
            <StackPanel Grid.Column="2" 
                        Orientation="Horizontal" 
                        VerticalAlignment="Center">
                <Border Width="36" Height="36" 
                        Background="{StaticResource TextMutedBrush}" 
                        CornerRadius="18"
                        Margin="0,0,8,0">
                    <TextBlock Text="{Binding UserName, Converter={StaticResource FirstCharConverter}}" 
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                    <!-- DisplayName -->
                    <TextBlock Text="{Binding UserName}" 
                               FontSize="13" 
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <!-- UID and Role -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="UserIdText"
                                   Text="{Binding UserId}" 
                                   FontSize="10" 
                                   Foreground="{StaticResource InfoBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,6,0"/>
                        <TextBlock Text="|" 
                                   FontSize="10" 
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding UserRole}" 
                                   FontSize="10" 
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Logout Button -->
                    <Button x:Name="LogoutButton"
                            Content="Logout" 
                            Width="70" 
                            Style="{StaticResource Template.HeaderActionButton}"
                            Background="{StaticResource ErrorBrush}"
                            Margin="0,0,4,0"
                            Click="LogoutButton_Click"/>

                    <!-- Switch User Button -->
                    <Button x:Name="SwitchUserButton"
                            Width="70" 
                            Style="{StaticResource Template.HeaderActionButton}"
                            Background="{StaticResource InfoBrush}"
                            Margin="0,0,8,0"
                            Click="SwitchUserButton_Click">
                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="&#x21BB;" 
                                       FontSize="13"
                                       Margin="0,0,3,0"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe UI Symbol"/>
                            <TextBlock Text="Switch" 
                                       FontSize="11"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Minimize Button -->
                    <Button x:Name="MinimizeButton"
                            Content="-" 
                            Width="30" 
                            Style="{StaticResource Template.HeaderWindowButton}"
                            Background="{StaticResource WarningBrush}"
                            Margin="0,0,2,0"
                            Click="MinimizeButton_Click"/>

                    <!-- Fullscreen Button -->
                    <Button x:Name="FullscreenButton"
                            Width="30" 
                            Style="{StaticResource Template.HeaderWindowButton}"
                            Background="{StaticResource SuccessBrush}"
                            Margin="0,0,2,0"
                            Click="FullscreenButton_Click"
                            ToolTip="Exit Fullscreen">
                        <!-- Default: currently fullscreen, show "exit fullscreen" icon -->
                        <Path Data="F0 M2,5 H11 V14 H2 Z M4,7 V12 H9 V7 Z M7,2 H16 V11 H7 Z M9,4 V9 H14 V4 Z"
                              Fill="{StaticResource TextPrimaryBrush}"
                              Stretch="Uniform"
                              Width="16"
                              Height="16"/>
                    </Button>

                    <!-- Close Button -->
                    <Button x:Name="CloseButton"
                            Content="X" 
                            Width="30" 
                            Style="{StaticResource Template.HeaderWindowButton}"
                            Background="{StaticResource ErrorBrush}"
                            Click="CloseButton_Click"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
