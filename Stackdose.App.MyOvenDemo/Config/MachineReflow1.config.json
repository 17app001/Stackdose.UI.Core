{
  "machine": {
    "id": "OVEN1",
    "name": "Reflow Oven A",
    "enable": true
  },
  "plc": {
    "ip": "192.168.22.39",
    "port": 3000,
    "pollIntervalMs": 200,
    "autoConnect": false,
    "monitorAddresses": [
      "D100,4",
      "M200,204"
    ]
  },
  "commands": {
    "Start": "M400",
    "Stop": "M401",
    "EmergencyStop": "M402",
    "Reset": "M403"
  },
  "processMonitor": {
    "isRunning": "M200",
    "isCompleted": "M202",
    "isAlarm": "M201"
  },
  "detailLabels": {
    "Oven Temp": "D100",
    "Cooling Temp": "D101",
    "Conveyor Speed": "D102",
    "Product Count": "D103"
  },
  "tags": {
    "status": {
      "isRunning": {
        "address": "M200",
        "type": "bool",
        "access": "read"
      },
      "isAlarm": {
        "address": "M201",
        "type": "bool",
        "access": "read"
      },
      "heartbeat": {
        "address": "D300",
        "type": "int16",
        "access": "read",
        "length": 1
      }
    },
    "process": {
      "batchNo": {
        "address": "D400",
        "type": "string",
        "access": "read",
        "length": 8
      },
      "recipeNo": {
        "address": "D410",
        "type": "string",
        "access": "read",
        "length": 8
      }
    }
  },
  "modules": [
    "processControl"
  ],
  "showPlcEditor": true
}