<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Stackdose.UI.Core;component/Themes/Theme.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Legacy-compatible brush keys mapped from UI.Core semantic/domain tokens -->
    <!-- ?? FIX: Use direct color values instead of Binding to avoid design-time issues -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#00E5FF"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#0088D4"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="#0D0D16"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#262640"/>
    <SolidColorBrush x:Key="DarkBackgroundBrush" Color="#1C1C2E"/>
    <SolidColorBrush x:Key="HoverBackgroundBrush" Color="#22000000"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B8C5D0"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#A8A8A8"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#B8C5D0"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="#00B876"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFB03A"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#FF5F5F"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#00CED1"/>

    <SolidColorBrush x:Key="BorderBrush" Color="#4A6078"/>
    <SolidColorBrush x:Key="BorderSecondaryBrush" Color="#5A8AB0"/>

    <SolidColorBrush x:Key="DisabledBackgroundBrush" Color="#2B000000"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#A8A8A8"/>
    <SolidColorBrush x:Key="DangerAccentBrush" Color="#FF5F5F"/>

</ResourceDictionary>
