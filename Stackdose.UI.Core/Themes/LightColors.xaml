<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light Theme Colors - Modern Unified Version -->
    
    <!-- ========== CyberFramework Specific Colors (Light) ========== -->
    <SolidColorBrush x:Key="Cyber.Bg.Dark"         Color="#DEE1E6"/>
    <SolidColorBrush x:Key="Cyber.Bg.Page"         Color="#DEE1E6"/>
    <SolidColorBrush x:Key="Cyber.Bg.Panel"        Color="#ECEFF1"/>
    <SolidColorBrush x:Key="Cyber.Bg.Card"         Color="#F5F7F9"/>
    <SolidColorBrush x:Key="Cyber.Border"          Color="#CFD8DC"/>
    <SolidColorBrush x:Key="Cyber.Border.Strong"   Color="#90A4AE"/>
    <SolidColorBrush x:Key="Cyber.Text.Main"       Color="#263238"/>
    <SolidColorBrush x:Key="Cyber.Text.Muted"      Color="#546E7A"/>
    <SolidColorBrush x:Key="Cyber.Text.Bright"     Color="#000000"/>
    <SolidColorBrush x:Key="Cyber.NeonBlue"       Color="#1976D2"/>
    <SolidColorBrush x:Key="Cyber.NeonGreen"      Color="#388E3C"/>
    <SolidColorBrush x:Key="Cyber.NeonRed"        Color="#D32F2F"/>

    <!-- ========== PLC / Hardware Specific (Light) ========== -->
    <SolidColorBrush x:Key="Plc.Bg.Dark"           Color="#DEE1E6"/>
    <SolidColorBrush x:Key="Plc.Bg.Main"           Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Plc.Bg"                Color="#F5F7F9"/>
    <SolidColorBrush x:Key="Plc.Border"            Color="#CFD8DC"/>
    <SolidColorBrush x:Key="Plc.Text.Label"        Color="#546E7A"/>
    <SolidColorBrush x:Key="Plc.Text.Value"        Color="#1976D2"/>
    <SolidColorBrush x:Key="Plc.Text.Default"      Color="#263238"/>
    <SolidColorBrush x:Key="Plc.Text.Gray"         Color="#90A4AE"/>

    <!-- ========== Sensor / Alarm Viewer (Light) ========== -->
    <SolidColorBrush x:Key="Sensor.Bg.Main"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Sensor.Bg.Header"      Color="#ECEFF1"/>
    <SolidColorBrush x:Key="Sensor.Border"          Color="#CFD8DC"/>
    <SolidColorBrush x:Key="Sensor.Text.Title"      Color="#263238"/>
    <SolidColorBrush x:Key="Sensor.Text.Label"      Color="#455A64"/>
    <SolidColorBrush x:Key="Sensor.Text.Group"      Color="#1976D2"/>

    <!-- ========== Log Viewer (Light) ========== -->
    <SolidColorBrush x:Key="Log.Bg.Main"           Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Log.Bg.Header"         Color="#ECEFF1"/>
    <SolidColorBrush x:Key="Log.Border"            Color="#CFD8DC"/>
    <SolidColorBrush x:Key="Log.Text.Normal"       Color="#263238"/>
    <SolidColorBrush x:Key="Log.Text.Time"         Color="#78909C"/>
    <SolidColorBrush x:Key="Log.Text.System"       Color="#1976D2"/>

    <!-- ========== Overlay / Interactive (Light) ========== -->
    <SolidColorBrush x:Key="Overlay.Bg.Panel"      Color="#10000000"/>
    <SolidColorBrush x:Key="Overlay.Bg.Light"      Color="#05000000"/>
    <SolidColorBrush x:Key="Overlay.Highlight.Info" Color="#201976D2"/>
    <SolidColorBrush x:Key="Overlay.Bg.Scrim"      Color="#60000000"/>

    <!-- ========== Semantic Alias Tokens (v1) ========== -->
    <!-- Surface -->
    <SolidColorBrush x:Key="Surface.Bg.Page"        Color="#DEE1E6"/>
    <SolidColorBrush x:Key="Surface.Bg.Panel"       Color="#ECEFF1"/>
    <SolidColorBrush x:Key="Surface.Bg.Card"        Color="#F5F7F9"/>
    <SolidColorBrush x:Key="Surface.Bg.Control"     Color="#FFFFFF"/>

    <!-- Border -->
    <SolidColorBrush x:Key="Surface.Border.Default" Color="#CFD8DC"/>
    <SolidColorBrush x:Key="Surface.Border.Strong"  Color="#90A4AE"/>

    <!-- Text -->
    <SolidColorBrush x:Key="Text.Primary"           Color="#263238"/>
    <SolidColorBrush x:Key="Text.Secondary"         Color="#546E7A"/>
    <SolidColorBrush x:Key="Text.Tertiary"          Color="#78909C"/>

    <!-- Accent / Action -->
    <SolidColorBrush x:Key="Accent.Primary"         Color="#1976D2"/>
    <SolidColorBrush x:Key="Action.Primary"         Color="#2196F3"/>
    <SolidColorBrush x:Key="Action.Success"         Color="#4CAF50"/>
    <SolidColorBrush x:Key="Action.Warning"         Color="#FF9800"/>
    <SolidColorBrush x:Key="Action.Error"           Color="#F44336"/>
    <SolidColorBrush x:Key="Action.Info"            Color="#00BCD4"/>
    <SolidColorBrush x:Key="Button.Text"            Color="#FFFFFF"/>

    <!-- Status Colors -->
    <SolidColorBrush x:Key="Status.Success"         Color="#388E3C"/>
    <SolidColorBrush x:Key="Status.Warning"         Color="#F57C00"/>
    <SolidColorBrush x:Key="Status.Error"           Color="#D32F2F"/>
    <SolidColorBrush x:Key="Status.Info"            Color="#1976D2"/>
    <SolidColorBrush x:Key="Status.Offline"         Color="#78909C"/>

</ResourceDictionary>
