<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- ================================================================ -->
    <!-- Dark Theme Implementation                                         -->
    <!-- ================================================================ -->
    <!-- This file provides Dark theme values for Semantic Tokens -->

    <!-- ========== Surface ========== -->
    <SolidColorBrush x:Key="Surface.Bg.Page" Color="#0D0D16" />
    <SolidColorBrush x:Key="Surface.Bg.Panel" Color="#1C1C2E" />
    <SolidColorBrush x:Key="Surface.Bg.Card" Color="#262640" />
    <SolidColorBrush x:Key="Surface.Bg.Control" Color="#1F1F32" />
    <SolidColorBrush x:Key="Surface.Bg.Elevated" Color="#2A2A42" />

    <!-- ========== Border ========== -->
    <SolidColorBrush x:Key="Surface.Border.Default" Color="#4A6078" />
    <SolidColorBrush x:Key="Surface.Border.Strong" Color="#5A8AB0" />
    <SolidColorBrush x:Key="Surface.Border.Weak" Color="#3A4A5F" />
    <SolidColorBrush x:Key="Surface.Border.Accent" Color="#00E5FF" />

    <!-- ========== Text ========== -->
    <SolidColorBrush x:Key="Text.Primary" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Text.Secondary" Color="#B8C5D0" />
    <SolidColorBrush x:Key="Text.Tertiary" Color="#95A5BA" />
    <SolidColorBrush x:Key="Text.Disabled" Color="#808080" />
    <SolidColorBrush x:Key="Text.Inverse" Color="#0D0D16" />

    <!-- ========== Accent ========== -->
    <SolidColorBrush x:Key="Accent.Primary" Color="#00E5FF" />
    <SolidColorBrush x:Key="Accent.Secondary" Color="#00CED1" />
    <SolidColorBrush x:Key="Accent.Tertiary" Color="#1976D2" />

    <!-- ========== Action Buttons ========== -->
    <SolidColorBrush x:Key="Action.Primary.Bg" Color="#0088D4" />
    <SolidColorBrush x:Key="Action.Primary.Fg" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Action.Success.Bg" Color="#00B876" />
    <SolidColorBrush x:Key="Action.Success.Fg" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Action.Warning.Bg" Color="#FFB03A" />
    <SolidColorBrush x:Key="Action.Warning.Fg" Color="#000000" />
    <SolidColorBrush x:Key="Action.Error.Bg" Color="#FF5F5F" />
    <SolidColorBrush x:Key="Action.Error.Fg" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Action.Info.Bg" Color="#00CED1" />
    <SolidColorBrush x:Key="Action.Info.Fg" Color="#FFFFFF" />

    <!-- ========== Status ========== -->
    <SolidColorBrush x:Key="Status.Success" Color="#5FD37A" />
    <SolidColorBrush x:Key="Status.Warning" Color="#FFB03A" />
    <SolidColorBrush x:Key="Status.Error" Color="#FF5F5F" />
    <SolidColorBrush x:Key="Status.Info" Color="#00CED1" />
    <SolidColorBrush x:Key="Status.Offline" Color="#858585" />
    <SolidColorBrush x:Key="Status.Running" Color="#5FD37A" />
    <SolidColorBrush x:Key="Status.Standby" Color="#FFB03A" />

    <!-- ========== Overlay ========== -->
    <SolidColorBrush x:Key="Overlay.Bg.Scrim" Color="#CC000000" />
    <SolidColorBrush x:Key="Overlay.Bg.Panel" Color="#2B000000" />
    <SolidColorBrush x:Key="Overlay.Bg.Medium" Color="#2A000000" />
    <SolidColorBrush x:Key="Overlay.Bg.Light" Color="#22000000" />
    <SolidColorBrush x:Key="Overlay.Highlight.Info" Color="#2000BCD4" />

    <!-- ========== Component-Specific ========== -->
    <SolidColorBrush x:Key="Component.PrintHead.Voltage" Color="#FFD700" />
    <SolidColorBrush x:Key="Component.PrintHead.Encoder" Color="#00FF7F" />
    <SolidColorBrush x:Key="Component.PrintHead.PrintIndex" Color="#FF69B4" />

    <SolidColorBrush x:Key="Component.PlcLabel.Default" Color="#95A5BA" />
    <SolidColorBrush x:Key="Component.PlcLabel.NeonBlue" Color="#00E5FF" />
    <SolidColorBrush x:Key="Component.PlcLabel.Warning" Color="#FFB03A" />
    <SolidColorBrush x:Key="Component.PlcLabel.Success" Color="#5FD37A" />
    <SolidColorBrush x:Key="Component.PlcLabel.Error" Color="#FF5F5F" />

</ResourceDictionary>
